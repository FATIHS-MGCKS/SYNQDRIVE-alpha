{
  "mcpServers": {
    "didit": {
      "url": "https://mcp.didit.me/mcp"
    },
    "dimo": {
      "command": "npx",
      "args": ["-y", "mcp-dimo@1.5.5"],
      "env": {
        "DIMO_CLIENT_ID": "${env:DIMO_CLIENT_ID}",
        "DIMO_DOMAIN": "${env:DIMO_DOMAIN}",
        "DIMO_PRIVATE_KEY": "${env:DIMO_PRIVATE_KEY}"
      }
    },
    "hostinger-api": {
      "command": "npx",
      "args": ["-y", "hostinger-api-mcp@1.5.5"],
      "env": {
        "DEBUG": "false",
        "API_TOKEN": "${env:HOSTINGER_API_TOKEN}"
      }
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "resend-mcp@2.11.0"],
      "env": {
        "RESEND_API_KEY": "${env:RESEND_API_KEY}"
      }
    },
    "stripe": {
      "url": "https://mcp.stripe.com",
      "headers": {
        "Authorization": "Bearer ${env:STRIPE_SECRET_KEY}"
      }
    }
  }
}
