# SynqDrive Prometheus — example scrape configuration
#
# Copy to prometheus.yml and customize targets + bearer token file for your
# environment. Intended for INTERNAL monitoring networks only.
#
#   cp prometheus.yml.example prometheus.yml
#   echo -n "$METRICS_BEARER_TOKEN" > /etc/prometheus/secrets/metrics_bearer_token
#
# Local docker-compose (monitoring profile):
#   docker compose --profile monitoring up -d prometheus

global:
  scrape_interval: 30s
  scrape_timeout: 10s
  evaluation_interval: 30s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: synqdrive-backend
    metrics_path: /api/v1/metrics
    scheme: http
    scrape_interval: 30s
    # Bind to internal backend host — never expose /metrics on a public listener.
    static_configs:
      - targets:
          - 'backend:3000'
    bearer_token_file: /etc/prometheus/secrets/metrics_bearer_token
    # Optional TLS when scraping through an internal reverse proxy:
    # scheme: https
    # tls_config:
    #   insecure_skip_verify: false
