      "targets": [{ "expr": "sum(rate(synqdrive_document_upload_total[5m]))", "refId": "A" }],
      "title": "Uploads accepted/s",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
