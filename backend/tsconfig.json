{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@modules/*": ["src/modules/*"],
      "@workers/*": ["src/workers/*"],
      "@config/*": ["src/config/*"],
      "@synq/evaluations-metrics/*": ["../shared/evaluations-metrics/*"],
      "@synq/evaluations-periods/*": ["../shared/evaluations-periods/*"],
      "@synq/money/*": ["../shared/money/*"],
      "@synq/receivables/*": ["../shared/receivables/*"],
      "@synq/finance/*": ["../shared/finance/*"]
    }
  },
  "include": ["src", "../shared/evaluations-metrics/**/*.ts", "../shared/evaluations-periods/**/*.ts", "../shared/money/**/*.ts", "../shared/receivables/**/*.ts", "../shared/finance/**/*.ts"]
}
