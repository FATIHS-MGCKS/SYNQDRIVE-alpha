# Voice AI staging host template (Prompt 9A)
# Copy keys into VPS backend.env via secure sync — never commit real secrets.
# See docs/audits/voice-ai-staging-preflight.md

NODE_ENV=production

# --- Feature gates (staging-only; live calls remain off) ---
VOICE_AI_PROVISIONING_STAGING_ENABLED=true
VOICE_NATIVE_TWILIO_INTEGRATION=true
VOICE_MCP_GATEWAY=true
VOICE_WEBHOOK_INGESTION_ENABLED=true
VOICE_AI_SUBACCOUNTS=true
VOICE_LEGACY_DIAGNOSTIC_CALLS=false
VOICE_E2E_ALLOW_LIVE_CALLS=false

# --- Staging tenant ---
VOICE_E2E_ORG_ID=org-voice-staging-e2e
VOICE_E2E_FORBIDDEN_ORG_IDS=
# Comma-separated E.164 test destinations only
VOICE_E2E_ALLOWLIST_E164=

# --- Provider region (IE1 / Dublin) ---
TWILIO_REGION=ie1
TWILIO_EDGE=dublin
TWILIO_VOICE_WEBHOOK_BASE_URL=https://app.synqdrive.eu

# --- Secrets (Runtime Secret / backend.env — values never in git) ---
# ELEVENLABS_API_KEY=
# ELEVENLABS_WEBHOOK_SECRET=
# VOICE_MCP_TOKEN_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=
# TWILIO_AUTH_TOKEN=
# VOICE_STAGING_SUBACCOUNT_SECRET_REF=env-json://voice-staging-subaccount
