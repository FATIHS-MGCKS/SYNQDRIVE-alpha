# ------------------------------------------------
# SynqDrive Backend Environment Configuration
# ------------------------------------------------

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://synqdrive:synqdrive@localhost:5432/synqdrive?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse local/self-hosted analytics mirror
# Optional analytics/telemetry mirror — PostgreSQL stays the canonical truth.
# The values below are DEV DEFAULTS that match docker-compose.yml so local
# development works out of the box. In production use a STRONG password and
# never expose the ClickHouse ports publicly.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=synqdrive
CLICKHOUSE_PASSWORD=synqdrive_clickhouse_dev
CLICKHOUSE_DATABASE=synqdrive
# Analysis read hardening (P22) — env URL only, no Docker assumption
# CLICKHOUSE_ANALYSIS_QUERY_TIMEOUT_MS=5000
# CLICKHOUSE_CIRCUIT_FAILURE_THRESHOLD=3
# CLICKHOUSE_CIRCUIT_COOLDOWN_MS=30000
# CLICKHOUSE_ANALYSIS_TIMEOUT_WINDOW_MS=60000

# Notification Engine V2 (shadow mode — writes V2 tables, legacy dashboard unchanged)
NOTIFICATIONS_V2=false
# Async channel delivery (email/push outbox) — requires NOTIFICATIONS_V2=true and WORKERS_ENABLED=true
NOTIFICATIONS_DELIVERY_ENABLED=false
NOTIFICATIONS_DELIVERY_MAX_ATTEMPTS=5
NOTIFICATIONS_DELIVERY_BACKOFF_MS=60000
NOTIFICATION_QUIET_HOURS_START=22:00
NOTIFICATION_QUIET_HOURS_END=07:00
NOTIFICATION_DIGEST_HOUR_LOCAL=8

# Notification evaluation runtime (BullMQ + Redis lock)
NOTIFICATION_EVALUATION_QUEUE_ENABLED=true
NOTIFICATION_EVALUATION_DEBOUNCE_MS=120000
NOTIFICATION_EVALUATION_LOCK_TTL_MS=300000
NOTIFICATION_EVALUATION_LOCK_HEARTBEAT_MS=60000
NOTIFICATION_EVALUATION_JOB_ATTEMPTS=4
NOTIFICATION_EVALUATION_JOB_BACKOFF_MS=5000
NOTIFICATION_EVALUATION_BOOT_STAGGER_MS=15000

# ── Stations V2 rollout flags (Prompt 74/78 — all default OFF in production) ───
# Org canary: comma-separated UUIDs; when set, only listed orgs receive enabled flags.
# STATIONS_V2_ORG_ALLOWLIST=
STATIONS_V2_SCHEMA_ENABLED=false
STATIONS_V2_SCOPE_ENABLED=false
STATIONS_V2_LIFECYCLE_ENABLED=false
STATIONS_V2_SUMMARY_READ_MODEL_ENABLED=false
STATIONS_V2_DELTA_ASSIGNMENT_ENABLED=false
STATIONS_V2_POSITIONING_ENABLED=false
STATIONS_V2_BOOKING_RULES_ENABLED=false
# off | shadow | warning | enforce
STATIONS_V2_BOOKING_RULES_ENFORCEMENT=off
STATIONS_V2_CAPACITY_WARNINGS_ENABLED=false
STATIONS_V2_TRANSFERS_ENABLED=false
STATIONS_V2_AUDIT_TRAIL_ENABLED=false
STATIONS_V2_GEOFENCE_SHADOW_ENABLED=false
STATIONS_V2_UI_ENABLED=false
# Legacy endpoint hard-disable (step 10)
STATIONS_V2_SET_VEHICLES_DISABLED=false
# Jest: defaults all flags ON unless set to off
# STATIONS_V2_FLAGS_TEST_DEFAULT=off

# ClickHouse trip assist (explicit architecture exception — default on).
# When true, guarded CH-assisted detectors may influence PostgreSQL trip
# start, continuity guard, and repair candidates. Does NOT affect canonical
# scores. Live trip END remains FSM + DIMO CUSUM (CH does not accelerate end).
# See architecture/CLICKHOUSE_TRIP_ASSIST_AND_TRIP_END_2026-07-08.md
# CLICKHOUSE_TRIP_ASSIST_ENABLED=true

# ClickHouse trip-end assist tuning (optional — defaults in worker.config.ts)
# TRIP_END_CH_ASSIST_MIN_STATIONARY_MS=45000
# TRIP_END_CH_ASSIST_MIN_TRIP_DURATION_MS=60000
# TRIP_END_CH_ASSIST_STABILITY_MS=30000
# TRIP_END_CH_ASSIST_HIGH_STATIONARY_MS=90000

# Post-trip HF analytics mirror (optional — does NOT affect canonical scores).
# HF_MIRROR_ENABLED=false

# Driving Intelligence V2 — post-trip pipeline only (never affects live trip FSM).
# DRIVING_INTELLIGENCE_V2_ENABLED=false
# DRIVING_V2_DIMO_SEGMENT_VALIDATION_ENABLED=false
# DRIVING_V2_ENGINE_DETECTOR_SHADOW_ENABLED=true
# DRIVING_V2_HF_DETECTOR_SHADOW_ENABLED=true

# Post-trip route waypoint mirror (optional — from PG trip waypoints only).
# WAYPOINT_MIRROR_ENABLED=false

# Post-trip activity window evidence mirror (optional).
# ACTIVITY_WINDOW_MIRROR_ENABLED=false

# Prometheus metrics scrape (internal only — required in production & staging)
# METRICS_BEARER_TOKEN=change-me-long-random-secret
# Local dev only: allow /metrics without token when explicitly enabled:
# METRICS_ALLOW_OPEN_IN_DEV=true

# Grafana (VPS ops only — localhost UI via SSH tunnel; set on prod backend.env)
# GRAFANA_ADMIN_PASSWORD=change-me-long-random-secret
# GRAFANA_INTERNAL_URL=http://127.0.0.1:3000
# PROMETHEUS_INTERNAL_URL=http://127.0.0.1:9090

# Authentication
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_SECRET=change-me-in-production
# IAM org-bound refresh sessions (Prompt 7). Default: enabled.
ENABLE_IAM_ORG_BOUND_REFRESH_SESSIONS=true
# One-time LEGACY_UNSCOPED refresh upgrade when org is determinable. Default: off.
ENABLE_IAM_LEGACY_UNSCOPED_REFRESH_GRACE=false

# IAM MFA (TOTP + step-up) — gradual rollout via org allowlist
IAM_MFA_ENROLLMENT_ENABLED=false
IAM_MFA_STEP_UP_ENFORCED=false
IAM_MFA_PRIVILEGED_ENROLLMENT_REQUIRED=false
IAM_MFA_ORG_ALLOWLIST=
# Optional dedicated AES key for MFA secret encryption (falls back to JWT_SECRET)
IAM_MFA_ENCRYPTION_KEY=

# IAM data retention & data subject rights — disabled by default; dry-run when enabled
IAM_DATA_RETENTION_ENABLED=false
IAM_DATA_RETENTION_DRY_RUN=true
IAM_DATA_RETENTION_BATCH_SIZE=500
IAM_DATA_RETENTION_MAX_BATCHES=50
IAM_DATA_RETENTION_MAX_RETRIES=3
IAM_DATA_RETENTION_SESSION_GRACE_DAYS=7
IAM_DATA_RETENTION_INVITE_DELIVERY_DAYS=30
# Set in production before enabling IP pseudonymization
IAM_DATA_PSEUDONYMIZATION_SALT=

# Mapbox (backend geocoding, map matching, vendor POI — same token as frontend)
MAPBOX_ACCESS_TOKEN=
MAPBOX_TOKEN=
VITE_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE_URL=

# Elevenlabs
ELEVENLABS_API_KEY=
# HMAC secret for signed ElevenLabs post-call webhooks (workspace webhook secret)
ELEVENLABS_WEBHOOK_SECRET=
# Unified webhook ingestion (Twilio + ElevenLabs + MCP). Production: opt-in only.
VOICE_WEBHOOK_INGESTION_ENABLED=false

# SynqDrive voice MCP gateway (ElevenLabs agent tools)
VOICE_AI_MCP_GATEWAY_ENABLED=false
VOICE_MCP_GATEWAY=false
# Native ElevenLabs-Twilio PSTN orchestration (staging/canary only)
VOICE_NATIVE_TWILIO_INTEGRATION=false
VOICE_AI_NATIVE_TELEPHONY=false
VOICE_AI_PROVISIONING_STAGING_ENABLED=false
# Legacy Twilio Say diagnostic PSTN (disabled in production by default)
VOICE_LEGACY_DIAGNOSTIC_CALLS=false
# Dedicated HMAC/JWT secret for short-lived MCP bearer tokens (falls back to JWT_SECRET)
VOICE_MCP_TOKEN_SECRET=
VOICE_MCP_TOKEN_TTL_SECONDS=900
VOICE_MCP_TOOL_TIMEOUT_MS=10000
VOICE_MCP_RATE_LIMIT_PER_MINUTE=120
# Daily voice privacy retention purge (transcripts/summaries/webhook payloads)
VOICE_RETENTION_ENABLED=true

# Voice staging E2E (Prompt 10B — manual live calls only with explicit gates)
VOICE_E2E_ORG_ID=org-voice-staging-e2e
VOICE_E2E_FORBIDDEN_ORG_IDS=
VOICE_E2E_ALLOW_LIVE_CALLS=false
# Comma-separated E.164 targets permitted for manual staging PSTN tests
VOICE_E2E_ALLOWLIST_E164=

# Twilio (server-side SDK — API Key auth, not Account Auth Token)
# Credentials optional until telephony integration is enabled; IE1 region requires edge dublin.
# See backend/docs/twilio-setup.md
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_REGION=ie1
TWILIO_EDGE=dublin
# Webhook signature validation only — never used for REST SDK calls
TWILIO_AUTH_TOKEN=
# Public app base URL for Twilio voice/status webhooks (defaults to APP_URL).
# Production SynqDrive: https://app.synqdrive.eu
TWILIO_VOICE_WEBHOOK_BASE_URL=https://app.synqdrive.eu

# ── AI Gateway (provider-neutral LLM layer) ───────────────────────────────────
# DIMO remains for vehicle identity/telemetry only — LLM inference uses this gateway.
AI_PROVIDER=mistral
MISTRAL_API_KEY=
# Optional override (default: https://api.mistral.ai)
MISTRAL_BASE_URL=
MISTRAL_ROUTER_MODEL=mistral-small-latest
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_JSON_MODEL=mistral-small-latest
MISTRAL_REASONING_MODEL=mistral-large-latest
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_TIMEOUT_MS=120000
MISTRAL_OCR_MAX_FILE_BYTES=10485760
AI_STREAMING_ENABLED=true
# When true, WhatsApp/email/customer outreach requires explicit approval before send.
AI_EXTERNAL_ACTIONS_REQUIRE_APPROVAL=true

# DIMO Integration (telemetry, identity, webhooks — NOT used as LLM provider)
#
# SECURITY — read before committing:
# - NEVER commit real secrets (.env, *agent*.local.json, *secrets*.json).
# - DIMO_PRIVATE_KEY is server-only — set it in local .env only.
# - If DIMO_PRIVATE_KEY was ever committed to git, rotate it immediately
#   in the DIMO Developer Console (https://console.dimo.org) and update your local .env.
#
DIMO_API_URL=https://identity-api.dimo.zone
DIMO_TELEMETRY_API_URL=https://telemetry-api.dimo.zone/query
DIMO_CLIENT_ID=
DIMO_PRIVATE_KEY=
DIMO_REDIRECT_URI=
DIMO_DOMAIN=
DIMO_ENV=
DIMO_VEHICLE_JWT_TTL_SECONDS=300
DIMO_VEHICLE_JWT_REFRESH_MARGIN_SECONDS=60
DIMO_WEBHOOK_SECRET=
# Optional legacy HMAC for x-dimo-signature when DIMO sends it. Vehicle Triggers API
# authenticates via DIMO_WEBHOOK_VERIFICATION_TOKEN at URL registration — trigger POSTs
# are unsigned by default and are accepted when the verification token is configured.
# Echoed when DIMO Vehicle Triggers verifies the webhook URL ({ "verification": "test" })
DIMO_WEBHOOK_VERIFICATION_TOKEN=
# Optional legacy bootstrap: auto-register DIMO webhooks/triggers on startup (default off)
DIMO_TRIGGER_BOOTSTRAP_ENABLED=false

# Fleet connectivity episode recovery rollout (default: recovery on, reconciliation apply off)
# CONNECTIVITY_EPISODE_RECOVERY_ENABLED=true
# CONNECTIVITY_RECONCILIATION_APPLY_ENABLED=false

# Stripe Integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
# Return URL after Stripe Customer Portal (falls back to APP_URL)
STRIPE_CUSTOMER_PORTAL_RETURN_URL=
# Optional: Stripe Price ID for per-vehicle subscription creation (Prompt 2+)
STRIPE_DEFAULT_PRICE_ID=
# End-customer Connect (modules/payments) — separate from billing webhooks
STRIPE_CONNECT_ACCOUNT_GENERATION=V1
STRIPE_CONNECT_RETURN_URL=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
# App base URL used for portal return URL validation fallback
# Billing notification emails (Resend outbox consumer billing.email)
BILLING_EMAIL_ENABLED=true
BILLING_EMAIL_SUPPORT=support@synqdrive.eu
BILLING_EMAIL_SETTINGS_PATH=/rental/settings?settingsTab=billing
BILLING_EMAIL_MAX_ATTEMPTS=5


# Worker Configuration
WORKER_SNAPSHOT_INTERVAL_MS=30000
WORKER_LIVEMAP_INTERVAL_MS=5000
WORKER_DIMO_SYNC_INTERVAL_MS=300000
WORKER_SNAPSHOT_CONCURRENCY=5
WORKER_LIVEMAP_CONCURRENCY=10
WORKER_ANALYTICS_CONCURRENCY=3
WORKER_DIMO_SYNC_CONCURRENCY=2
WORKER_BATTERY_ENRICHMENT_CONCURRENCY=3
WORKER_BRAKE_ENRICHMENT_CONCURRENCY=3

# V2 Trip Detection — ACTIVE_TICK interval + end-detection tuning (env overrides worker.config defaults)
WORKER_TRIP_TRACKING_INTERVAL_MS=30000
WORKER_TRIP_END_TIMEOUT_MS=1800000
TRIP_END_STABILITY_WINDOW_MS=90000
TRIP_END_MIN_INACTIVITY_BEFORE_CUSUM_MS=120000
TRIP_END_VALIDATION_RETRY_MS=60000
TRIP_END_VALIDATION_MAX_ATTEMPTS=3

# Request Timeouts
DIMO_REQUEST_TIMEOUT_MS=10000
DEFAULT_REQUEST_TIMEOUT_MS=15000

# Logging
# Comma-separated levels. If unset, defaults are env-aware:
#   production  -> error,warn,log   (debug/verbose suppressed)
#   development -> error,warn,log,debug,verbose
# Set explicitly to override, e.g. LOG_LEVEL=error,warn,log
LOG_LEVEL=debug
# Log successful (2xx/3xx) HTTP requests in production too (default: only 4xx/5xx).
HTTP_LOG_SUCCESS=false
# Throttle window (ms) for repeated 5xx stack traces with the same signature.
ERROR_STACK_THROTTLE_MS=60000

# ── HTTP body size limit ──────────────────────────────────────────────────────
# Must accommodate base64 image / signature endpoints (damages, exterior images,
# handover signatures). Applies to JSON and urlencoded bodies.
HTTP_BODY_LIMIT=12mb

# ── Battery Health V2 rollout flags (Prompt 3/78 — defaults safe) ─────────────
# Real CRANK_MIN assessment (OFF = legacy crank has no score/alert/readiness effect)
BATTERY_V2_LEGACY_CRANK_ASSESSMENT_ENABLED=false
# Collect start-window points for future START_DIP_PROXY analysis (diagnostic only)
BATTERY_V2_START_PROXY_ENABLED=false
# LV REST_60M/REST_6H shadow capture only — persist diagnostics, no publication/readiness/alerts
BATTERY_V2_REST_SHADOW_ENABLED=false
# Prompt 44 — LV Battery Health V2 publication (default OFF)
BATTERY_V2_PUBLICATION_ENABLED=false
# Legacy HV ΔEnergy/ΔSOC pairwise capacity assessment (OFF = no new capacity/SOH from snapshots)
BATTERY_V2_HV_LEGACY_PAIRWISE_CAPACITY_ENABLED=false

# ── Battery V2 Retention (BatteryV2RetentionScheduler, daily 04:00) ───────────
# Domain-aware retention with dry-run default. Does NOT run on deploy.
BATTERY_V2_RETENTION_ENABLED=false
BATTERY_V2_RETENTION_DRY_RUN=true
BATTERY_V2_RETENTION_BATCH_SIZE=1000
BATTERY_V2_RETENTION_MAX_BATCHES=200
RETENTION_BATTERY_LV_PROVIDER_SNAPSHOTS_DAYS=90
RETENTION_HV_PROVIDER_SNAPSHOTS_DAYS=365
RETENTION_BATTERY_MEASUREMENTS_LV_DAYS=730
RETENTION_BATTERY_MEASUREMENTS_HV_DAYS=1095
RETENTION_BATTERY_MEASUREMENT_SESSIONS_DAYS=1095
RETENTION_BATTERY_ASSESSMENTS_DAYS=365
RETENTION_HV_CHARGE_SESSIONS_DAYS=1095
RETENTION_HV_CAPACITY_OBSERVATIONS_DAYS=1095
RETENTION_BATTERY_EVIDENCE_SHADOW_DAYS=1095
RETENTION_BATTERY_CAPABILITY_CHANGES_DAYS=90
RETENTION_BATTERY_V2_DEAD_LETTERS_DAYS=90
RETENTION_BATTERY_PUBLICATIONS_DAYS=0
RETENTION_BATTERY_QUALIFIED_EVIDENCE_DAYS=0
RETENTION_BATTERY_RETENTION_AGGREGATES_DAYS=0

# ── Data Retention (DataRetentionScheduler, daily 03:30) ──────────────────────
# Prunes append-only telemetry/log tables. Age windows in DAYS; 0 = disabled.
DATA_RETENTION_ENABLED=true
DATA_RETENTION_BATCH_SIZE=5000
DATA_RETENTION_MAX_BATCHES=500
# Operational logs (sane defaults: enabled)
RETENTION_DIMO_POLL_LOGS_DAYS=30
RETENTION_TRIP_TRACKING_RUNS_DAYS=30
RETENTION_HM_STREAM_SYNC_LOGS_DAYS=14
RETENTION_HM_HEALTH_SYNC_LOGS_DAYS=30
RETENTION_TRIP_REPAIRS_DAYS=365
RETENTION_REFRESH_TOKENS_DAYS=30
# Product / audit / health data (default: disabled — opt in deliberately)
RETENTION_ACTIVITY_LOGS_DAYS=0
RETENTION_TRIP_WAYPOINTS_DAYS=0
RETENTION_TIRE_HEALTH_SNAPSHOTS_DAYS=0
RETENTION_TIRE_WEAR_DATA_POINTS_DAYS=0
RETENTION_BATTERY_EVIDENCE_DAYS=0
RETENTION_HV_BATTERY_SNAPSHOTS_DAYS=0

# ── File Storage ──────────────────────────────────────────────────────────────
# driver: local (disk, default) | s3 (S3-compatible object storage)
STORAGE_DRIVER=local
UPLOADS_DIR=uploads
# Max base64 damage image size (bytes) stored in DB. Default 6 MB.
MAX_DAMAGE_IMAGE_BYTES=6291456
# S3 / S3-compatible (requires: npm i @aws-sdk/client-s3 when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=
# Per-organization storage quota in bytes (0 = disabled)
STORAGE_ORG_QUOTA_BYTES=0

# ── AI Document Upload / Extraction ───────────────────────────────────────────
# Separate, PRIVATE object storage for uploaded vehicle/rental documents
# and generated booking/legal PDFs (DocumentsModule DocumentStoragePort).
# NOT served as public static assets — distinct from STORAGE_DRIVER/S3_* above.
DOCUMENT_STORAGE_PROVIDER=local
# Production: set to s3 and configure DOCUMENT_PRIVATE_S3_* below.
# DOCUMENT_STORAGE_ALLOW_LOCAL_IN_PRODUCTION=false
LOCAL_DOCUMENT_STORAGE_DIR=./storage/documents
LOCAL_DOCUMENT_QUARANTINE_STORAGE_DIR=./storage/documents-quarantine
# Private S3-compatible bucket (production — requires npm i @aws-sdk/client-s3)
# DOCUMENT_PRIVATE_S3_BUCKET=synqdrive-private-documents
# DOCUMENT_PRIVATE_S3_REGION=eu-central-1
# DOCUMENT_PRIVATE_S3_ENDPOINT=
# DOCUMENT_PRIVATE_S3_ACCESS_KEY_ID=
# DOCUMENT_PRIVATE_S3_SECRET_ACCESS_KEY=
# DOCUMENT_PRIVATE_S3_FORCE_PATH_STYLE=true
# DOCUMENT_PRIVATE_S3_KEY_PREFIX=prod
# DOCUMENT_PRIVATE_S3_SSE=AES256
# DOCUMENT_PRIVATE_S3_KMS_KEY_ID=
# DOCUMENT_STORAGE_HEALTH_ALERT_THRESHOLD=5
# Legal document storage integrity (checksum verification + reconciliation)
# DOCUMENT_LEGAL_INTEGRITY_VERIFY_ON_DOWNLOAD=true
# DOCUMENT_LEGAL_INTEGRITY_RECONCILIATION_BATCH_SIZE=50
# DOCUMENT_LEGAL_INTEGRITY_RECONCILIATION_RATE_LIMIT_MS=25
# DOCUMENT_LEGAL_INTEGRITY_ALERT_THRESHOLD=5
# Document storage lifecycle / retention (default OFF; dry-run ON when enabled)
# DOCUMENT_RETENTION_ENABLED=false
# DOCUMENT_RETENTION_DRY_RUN=true
# DOCUMENT_RETENTION_POLICY_VERSION=2026-07-17
# DOCUMENT_DELETE_STRIP_OCR_CACHE=true
# DOCUMENT_RETENTION_OCR_CACHE_AFTER_SOFT_DELETE_DAYS=90
# DOCUMENT_RETENTION_SENSITIVE_EXTRACTED_DATA_DAYS=0
# DOCUMENT_RETENTION_ROW_AFTER_SOFT_DELETE_DAYS=0
# DOCUMENT_RETENTION_REJECTED_WITHOUT_FILE_DAYS=30
# DOCUMENT_RETENTION_BATCH_SIZE=100
# DOCUMENT_RETENTION_MAX_BATCHES=200
# Declared encryption-at-rest + backup metadata (capability flags for audit)
# DOCUMENT_STORAGE_ENCRYPTION_DECLARED=false
# DOCUMENT_STORAGE_ENCRYPTION_PROVIDER=none
# DOCUMENT_STORAGE_ENCRYPTION_KMS_KEY_ID=
# DOCUMENT_STORAGE_BACKUP_STRATEGY=vps-pre-deploy-db
# DOCUMENT_STORAGE_BACKUP_INCLUDES_OBJECTS=false
# DOCUMENT_STORAGE_BACKUP_LAST_VERIFIED_AT=
# DOCUMENT_STORAGE_BACKUP_NOTE=
DOCUMENT_UPLOAD_MAX_MB=10
# PDF text-layer quality gate before falling back to Mistral OCR
DOCUMENT_PDF_MIN_TEXT_CHARS=40
DOCUMENT_PDF_MIN_SENSIBLE_RATIO=0.45
DOCUMENT_PDF_MAX_REPEATED_LINE_RATIO=0.7
# When false, uploads are stored + recorded but no extraction job is enqueued.
DOCUMENT_EXTRACTION_QUEUE_ENABLED=true
# Dev/test only: allow PENDING without enqueue when queue is disabled (never use in production).
# DOCUMENT_EXTRACTION_ALLOW_PENDING_WITHOUT_QUEUE=false
# BullMQ job policy for document.extraction
# DOCUMENT_EXTRACTION_JOB_ATTEMPTS=4
# DOCUMENT_EXTRACTION_JOB_BACKOFF_MS=5000
# DOCUMENT_EXTRACTION_JOB_TIMEOUT_MS=120000
# Recovery scheduler thresholds (ms) and limits
# DOCUMENT_EXTRACTION_STALE_QUEUED_MS=600000
# DOCUMENT_EXTRACTION_STALE_PROCESSING_MS=900000
# DOCUMENT_EXTRACTION_STALE_CONFIRMED_MS=600000
# DOCUMENT_EXTRACTION_MAX_RECOVERY_ATTEMPTS=5
# DOCUMENT_EXTRACTION_RECOVERY_INTERVAL_MS=120000
# Chunking budgets for AI extraction (chars; token estimate ≈ chars/3.5)
# DOCUMENT_EXTRACTION_ACTION_RECOVERY_ENABLED=true

# Upload rate limits (Redis fixed-window; protects storage/queue before OCR)
# DOCUMENT_UPLOAD_RATE_LIMIT_ENABLED=true
# DOCUMENT_UPLOAD_RATE_LIMIT_WINDOW_MS=60000
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_UPLOADS_PER_ORG=40
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_BYTES_PER_ORG=209715200
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_UPLOADS_PER_USER=25
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_BYTES_PER_USER=125829120
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_UPLOADS_PER_IP=30
# DOCUMENT_UPLOAD_RATE_LIMIT_MAX_BYTES_PER_IP=157286400
# DOCUMENT_UPLOAD_RATE_LIMIT_OPERATOR_MULTIPLIER=2
# DOCUMENT_UPLOAD_RATE_LIMIT_ADMIN_MULTIPLIER=4
# DOCUMENT_UPLOAD_THROTTLE_LIMIT_PER_IP=40
# DOCUMENT_UPLOAD_THROTTLE_TTL_MS=60000
# Upload identification / preprocessing (byte-level probes — no PDF execution/decryption)
# DOCUMENT_IDENTIFY_TIMEOUT_MS=5000
# DOCUMENT_IDENTIFY_MAX_PDF_PAGES=50
# DOCUMENT_IDENTIFY_MAX_IMAGE_PIXELS=40000000
# DOCUMENT_IDENTIFY_MAX_DECOMPRESSED_BYTES=83886080
# DOCUMENT_IDENTIFY_MAX_PDF_OBJECTS=5000
# DOCUMENT_IDENTIFY_MAX_PDF_STREAMS=2000
# Malware scan (disabled by default — no ClamAV on current VPS layout)
# DOCUMENT_MALWARE_SCAN_ENABLED=false
# DOCUMENT_MALWARE_SCANNER_PROVIDER=mock
# DOCUMENT_MALWARE_SCAN_TIMEOUT_MS=15000
# DOCUMENT_MALWARE_SCAN_FAIL_OPEN=false
# LOCAL_DOCUMENT_QUARANTINE_STORAGE_DIR=./storage/documents-quarantine

# DOCUMENT_EXTRACTION_CHUNK_TARGET_CHARS=6000
# DOCUMENT_EXTRACTION_CHUNK_MAX_CHARS=8000
# DOCUMENT_EXTRACTION_CHUNK_MAX_PAGES=200
# DOCUMENT_EXTRACTION_CHUNK_MAX_CHUNKS=12
# DOCUMENT_EXTRACTION_CHUNK_OVERLAP_CHARS=0
# When false, the worker skips AI structured extraction (text is still extracted).
DOCUMENT_AI_EXTRACTION_ENABLED=true

# ── Didit Document Verification ───────────────────────────────────────────────
# Server-only. NO selfie, liveness, face match, or biometric flows.
# Workflow IDs via env (preferred) — see docs/didit-setup.md
DIDIT_ENABLED=false
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_WEBHOOK_PUBLIC_URL=https://app.synqdrive.eu/api/v1/webhooks/didit
DIDIT_DEFAULT_RETENTION_DAYS=90
DIDIT_WORKFLOW_ID_DOCUMENT=
DIDIT_WORKFLOW_ID_DRIVING_LICENSE=
DIDIT_WORKFLOW_ID_PROOF_OF_ADDRESS=

# ── Booking Document Lifecycle ────────────────────────────────────────────────
# Generated booking PDFs (invoice, deposit receipt, rental contract, handover
# protocols, final invoice) + uploaded legal documents (AGB / Widerruf). Stored
# in the SAME private storage root as document uploads above; never served
# publicly. The renderer is pure-JS (pdfkit) — no headless browser required.
DOCUMENT_GENERATION_ENABLED=true
# Renderer implementation behind the DOCUMENT_RENDERER port. 'html' = the default
# pdfkit renderer. A future 'chromium' renderer (Playwright/Puppeteer) could be
# added without changing callers. If a browser renderer is added later, set its
# executable path via that renderer's own env (not required for 'html').
DOCUMENT_PDF_RENDERER=html
# Max size (MB) for uploaded legal PDFs (AGB / Widerrufsbelehrung).
DOCUMENT_LEGAL_UPLOAD_MAX_MB=15
# Legal PDF validation limits (Prompt 11/32)
# DOCUMENT_LEGAL_PDF_VALIDATION_TIMEOUT_MS=10000
# DOCUMENT_LEGAL_PDF_MAX_PAGES=200
# Legal document malware scanner (Prompt 12/32) — fail-closed in production
# DOCUMENT_LEGAL_MALWARE_SCAN_ENABLED=false
# DOCUMENT_LEGAL_MALWARE_SCANNER_PROVIDER=development
# Allowed in production: clamav
# DOCUMENT_LEGAL_MALWARE_SCANNER_PROVIDER=clamav
# DOCUMENT_LEGAL_CLAMAV_HOST=127.0.0.1
# DOCUMENT_LEGAL_CLAMAV_PORT=3310
# DOCUMENT_LEGAL_MALWARE_SCAN_TIMEOUT_MS=15000
# DOCUMENT_LEGAL_MALWARE_SCAN_MAX_RETRIES=3
# DOCUMENT_LEGAL_MALWARE_SCAN_RETRY_BACKOFF_MS=500
# DOCUMENT_LEGAL_MALWARE_SCAN_HEALTH_ALERT_THRESHOLD=5
# DOCUMENT_LEGAL_MALWARE_SCAN_FAIL_OPEN=false
# Authorization decision engine (Data Authorization Prompt 13) — fail-closed in production
# DATA_AUTH_DECISION_ENFORCEMENT_ENABLED=true
# DATA_AUTH_DECISION_DEV_BYPASS=false
# DATA_AUTH_DECISION_GLOBAL_DENY=false
# DATA_AUTH_DECISION_CACHE_ENABLED=true
# DATA_AUTH_DECISION_CACHE_TTL_MS=30000
# DATA_AUTH_DECISION_CACHE_MAX_ENTRIES=10000
# DATA_AUTH_DECISION_AUDIT_ENABLED=true
# Telemetry ingest gate (Prompt 17) — shadow mode default; fail-closed gated
# DATA_AUTH_INGEST_SHADOW_MODE=true
# DATA_AUTH_INGEST_FAIL_CLOSED=false
# Trip/location history gate (Prompt 18) — shadow mode default
# DATA_AUTH_TRIP_LOCATION_SHADOW_MODE=true
# DATA_AUTH_TRIP_LOCATION_FAIL_CLOSED=false

# Vehicle health / DTC authorization (Prompt 19)
# DATA_AUTH_HEALTH_SHADOW_MODE=true
# DATA_AUTH_HEALTH_FAIL_CLOSED=false

# Driving behavior / misuse / profiling authorization (Prompt 20)
# DATA_AUTH_DRIVING_BEHAVIOR_SHADOW_MODE=true
# DATA_AUTH_DRIVING_BEHAVIOR_FAIL_CLOSED=false
# Orphan sweep (weekly, Sun 04:00) — disabled + dry-run by default
STORAGE_ORPHAN_SWEEP_ENABLED=false
STORAGE_ORPHAN_SWEEP_DELETE=false
STORAGE_ORPHAN_MIN_AGE_HOURS=24
# Raw payload size guard (bytes, 0 = disabled / unbounded). Opt-in safety valve
# for vehicle_latest_states.raw_payload_json and hm_latest_*.raw_signals_json.
RAW_PAYLOAD_MAX_BYTES=0

# ──────────────────────────────────────────────────────────────────────────────
# High Mobility Integration
# Two independent app containers: Health-APP and Telemetry-APP.
# Each has its own REST/OAuth credentials and its own MQTT V2 client.
# They must NEVER share credentials or certificate files.
#
# MQTT V2 broker: mqtt-v2.high-mobility.com:8883
# Protocol: mqtts (TLS mutual auth), MQTT v5, QoS 1, persistent session
# Certificates: ca_crt.pem + client_crt.pem + client_key.pem per app context
# Client ID must be stable per deployment (for persistent session) and unique
#   per concurrent connection. Use HM_HEALTH_APP_MQTT_UNIQUE_CLIENT_ID=true only
#   when running multiple instances of the same service concurrently.
# ──────────────────────────────────────────────────────────────────────────────

# HM Health-APP — REST / OAuth
# Obtain client_id and client_secret from the HM developer console (Health app container).
# VW Group direct fleet clearance requires `tags.vw-group-customer-name`.
# Default fallback in code is "F.S Mobility Service"; override here if needed.
HM_VW_GROUP_CUSTOMER_NAME=F.S Mobility Service
HM_HEALTH_APP_ENV=live
HM_HEALTH_APP_API_BASE_URL=https://api.high-mobility.com
HM_HEALTH_APP_TOKEN_URL=https://api.high-mobility.com/v1/access_tokens
HM_HEALTH_APP_CLIENT_ID=
HM_HEALTH_APP_CLIENT_SECRET=
HM_HEALTH_APP_WEBHOOK_SECRET=
HM_HEALTH_APP_REQUEST_TIMEOUT_MS=15000
HM_HEALTH_APP_MAX_RETRIES=2

# HM Health-APP — MQTT V2
# Obtain topic, client_id, and certs from the HM console MQTT snippet for the Health app.
# Place cert files under backend/certs/hm-health-app/ (not committed to git).
HM_HEALTH_APP_MQTT_ENABLED=false
HM_HEALTH_APP_MQTT_HOST=mqtt-v2.high-mobility.com
HM_HEALTH_APP_MQTT_PORT=8883
HM_HEALTH_APP_MQTT_APP_ID=
HM_HEALTH_APP_MQTT_TOPIC=
HM_HEALTH_APP_MQTT_CLIENT_ID=
HM_HEALTH_APP_MQTT_CA_CERT_PATH=./certs/hm-health-app/ca_crt.pem
HM_HEALTH_APP_MQTT_CLIENT_CERT_PATH=./certs/hm-health-app/client_crt.pem
HM_HEALTH_APP_MQTT_CLIENT_KEY_PATH=./certs/hm-health-app/client_key.pem
HM_HEALTH_APP_MQTT_CONSUMER_GROUP=synqdrive-hm-health-app
HM_HEALTH_APP_MQTT_DISABLE_CLEAN_SESSION=true
HM_HEALTH_APP_MQTT_QOS=1
HM_HEALTH_APP_MQTT_UNIQUE_CLIENT_ID=false
HM_HEALTH_APP_MQTT_RECONNECT_PERIOD_MS=5000
HM_HEALTH_APP_MQTT_CONNECT_TIMEOUT_MS=30000

# HM Telemetry-APP — REST / OAuth
# Leave CLIENT_ID and CLIENT_SECRET empty until the Telemetry app container is provisioned.
HM_TELEMETRY_APP_ENV=live
HM_TELEMETRY_APP_API_BASE_URL=https://api.high-mobility.com
HM_TELEMETRY_APP_TOKEN_URL=https://api.high-mobility.com/v1/access_tokens
HM_TELEMETRY_APP_CLIENT_ID=
HM_TELEMETRY_APP_CLIENT_SECRET=
HM_TELEMETRY_APP_WEBHOOK_SECRET=
HM_TELEMETRY_APP_REQUEST_TIMEOUT_MS=15000
HM_TELEMETRY_APP_MAX_RETRIES=2

# HM Telemetry-APP — MQTT V2
# Keep ENABLED=false until the Telemetry app container is provisioned and certs are ready.
# When enabling: place cert files under backend/certs/hm-telemetry-app/ and fill all fields.
HM_TELEMETRY_APP_MQTT_ENABLED=false
HM_TELEMETRY_APP_MQTT_HOST=mqtt-v2.high-mobility.com
HM_TELEMETRY_APP_MQTT_PORT=8883
HM_TELEMETRY_APP_MQTT_APP_ID=
HM_TELEMETRY_APP_MQTT_TOPIC=
HM_TELEMETRY_APP_MQTT_CLIENT_ID=
HM_TELEMETRY_APP_MQTT_CA_CERT_PATH=./certs/hm-telemetry-app/ca_crt.pem
HM_TELEMETRY_APP_MQTT_CLIENT_CERT_PATH=./certs/hm-telemetry-app/client_crt.pem
HM_TELEMETRY_APP_MQTT_CLIENT_KEY_PATH=./certs/hm-telemetry-app/client_key.pem
HM_TELEMETRY_APP_MQTT_CONSUMER_GROUP=synqdrive-hm-telemetry-app
HM_TELEMETRY_APP_MQTT_DISABLE_CLEAN_SESSION=true
HM_TELEMETRY_APP_MQTT_QOS=1
HM_TELEMETRY_APP_MQTT_UNIQUE_CLIENT_ID=false
HM_TELEMETRY_APP_MQTT_RECONNECT_PERIOD_MS=5000
HM_TELEMETRY_APP_MQTT_CONNECT_TIMEOUT_MS=30000

# ── Optional: global MQTT V2 defaults ─────────────────────────────────────────
# These are merged as fallbacks only when a per-app key is unset.
# Only set these if you truly want both apps to share a common value.
# Prefer per-app keys (above) for clarity.
# HM_MQTT_V2_HOST=mqtt-v2.high-mobility.com
# HM_MQTT_V2_PORT=8883
# HM_MQTT_V2_CA_PATH=
# HM_MQTT_V2_CERT_PATH=
# HM_MQTT_V2_KEY_PATH=
# HM_MQTT_V2_TOPIC=
# HM_MQTT_V2_SHARED_TOPIC=
# HM_MQTT_V2_CLIENT_ID=
# HM_MQTT_V2_APPLICATION_ID=
# HM_MQTT_V2_QOS=1
# HM_MQTT_V2_DISABLE_CLEAN_SESSION=true
# HM_MQTT_V2_UNIQUE_CLIENT_ID=false
# HM_MQTT_V2_CONSUMER_GROUP=

# ── Strict transport mode (optional) ──────────────────────────────────────────
# Set to true to fail Nest bootstrap if MQTT is ENABLED but config/certs are incomplete.
# Recommended for production to catch misconfiguration early.
# HM_MQTT_V2_STRICT_TRANSPORT=false

# ── Outbound email (Resend + org custom domains) ─────────────────────────────
# Provider: auto (Resend when RESEND_API_KEY set, else dev simulate), resend, dev
# EMAIL_PROVIDER=auto
# RESEND_API_KEY=   # Full access required for custom domain registration (not sending-only)
# EMAIL_DEFAULT_FROM=noreply@synqdrive.eu
# EMAIL_DEFAULT_FROM_NAME=SynqDrive
# EMAIL_DEFAULT_REPLY_TO=support@synqdrive.eu
# RESEND_WEBHOOK_SECRET=
# EMAIL_SIMULATE_ENABLED=true
# EMAIL_MAX_ATTACHMENTS_BYTES=20971520
# EMAIL_MAX_SENDS_PER_HOUR_PER_ORG=60

# ── OEM brand routing ─────────────────────────────────────────────────────────
# VW Group brands (Audi, Volkswagen, Skoda, SEAT, CUPRA) and Porsche do NOT use
# the HM Eligibility API. Their fleet clearance requests use a different HM path.
# The tag "vw-group-customer-name" is automatically included in fleet clearance
# POST bodies for VW Group brands — no env var required (it is a constant tag).
# This behavior is centralized in high-mobility-oem-routing.ts.

# ── Legacy HM keys (backward compat only) ─────────────────────────────────────
# Kept for any service still reading the unprefixed HM_CLIENT_ID / HM_CLIENT_SECRET.
# Prefer HM_HEALTH_APP_CLIENT_ID / HM_HEALTH_APP_CLIENT_SECRET instead.
# HM_CLIENT_ID=
# HM_CLIENT_SECRET=
