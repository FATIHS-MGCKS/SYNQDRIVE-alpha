{
  "name": "synqdrive-backend",
  "version": "0.1.0",
  "description": "SynqDrive multi-tenant SaaS backend — modular monolith",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/modules/document-extraction/**/*.ts\" \"src/modules/ai/documents/**/*.ts\" \"src/modules/ai/providers/mistral/**/*.ts\" \"test/document-extraction*.ts\"",
    "lint:all": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:battery:observation": "jest battery-provider-observation.integration battery-provider-observation.policy battery-freshness.policy hv-snapshot-observation hv-battery-health.service.observation",
    "test:battery:retention": "jest battery-v2-retention",
    "test:battery:retention:integration": "BATTERY_V2_RETENTION_INTEGRATION=1 jest battery-v2-retention.integration",
    "test:battery:v2": "jest --testPathPattern='battery-health|dimo-battery-signal|drive-profile-resolver|battery-policy-profile|lv-battery-chemistry|battery-v2|battery-critical\\.detector' --testPathIgnorePatterns=integration",
    "test:battery:v2:integration": "jest battery-provider-observation.integration && BATTERY_V2_RETENTION_INTEGRATION=1 jest battery-v2-retention.integration",
    "test:stations:v2": "jest --testPathPattern='stations-v2|station-access|station-rule-engine|station-validation|station-geofence-shadow' --testPathIgnorePatterns=integration",
    "test:battery:v2:verify": "bash scripts/test/battery-health-v2-verify.sh all",
    "test:battery:v2:verify:unit": "bash scripts/test/battery-health-v2-verify.sh unit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:billing:sandbox-matrix": "jest billing-stripe-sandbox.matrix",
    "test:iam:security": "jest --testPathPattern='iam-security-regression|iam-multi-org-refresh|iam-tenant-isolation|iam-membership-identity-isolation|iam-session-policy|password-reset\\.service|password-policy|refresh-session-binding\\.policy|refresh-token-org-binding|organization-switch\\.policy|organization-switch\\.service|users\\.controller\\.security|organization-invites\\.controller\\.security|iam-session-invalidation\\.policy|iam-effective-access\\.policy|effective-access-engine|organization-role-version|role-change-impact|organization-role-change|role-assignment-drift-reconciliation|iam-endpoint-enforcement-triage|iam-global-identity\\.policy|org-membership-admin\\.policy|users\\.service\\.spec|organization-invite\\.service\\.spec|organization-role\\.service\\.spec|permissions\\.guard\\.spec|org-admin-protection'",
    "test:voice:security": "jest --testPathPattern='voice-(tenant-isolation|resilience)\\.security|voice-structured-log|voice-secrets-startup|voice-retention|voice-metrics|voice-mcp-gateway\\.security|voice-mcp-privacy|voice-webhook-ingestion\\.(pipeline|util)|twilio-webhook\\.controller\\.characterization|org-scoping\\.voice'",
    "test:voice:staging-e2e": "jest voice-staging-e2e.matrix voice-e2e.config",
    "audit:dependencies": "bash ../scripts/audits/audit-dependencies.sh",
    "audit:voice-secrets": "bash ../scripts/audits/scan-voice-secrets.sh",
    "billing:sandbox:replay-webhook": "ts-node -r tsconfig-paths/register scripts/ops/stripe-billing-e2e-replay-webhook.ts",
    "billing:sandbox:cleanup": "ts-node -r tsconfig-paths/register scripts/ops/stripe-billing-sandbox-cleanup.ts",
    "test:document-extraction:live": "DOCUMENT_EXTRACTION_LIVE_INTEGRATION=1 jest document-extraction.live.integration.spec.ts",
    "test:document-intake:v2": "jest --testPathPattern='modules/document-extraction' --testPathIgnorePatterns='integration|\\.live\\.integration\\.'",
    "test:document-intake:v2:integration": "jest document-extraction.pipeline.integration document-action-plan.state-machine.integration document-intake-v2-race-conditions.integration",
    "test:document-intake:v2:verify": "bash scripts/test/document-intake-v2-verify.sh all",
    "test:document-intake:v2:verify:unit": "bash scripts/test/document-intake-v2-verify.sh unit",
    "test:legal-documents": "jest --testPathPattern='legal-document|legal-documents|booking-document-(bundle|completeness|generation|phase|pointer|task)|booking-pickup-gate|rental-contract-legal|document-storage\\.(contract|config)' --testPathIgnorePatterns='postgres\\.invariants'",
    "test:legal-documents:security": "jest legal-documents-security-negative",
    "test:legal-documents:integration": "jest legal-documents-activation.integration legal-documents-lifecycle-events.integration legal-document-delivery-evidence.integration booking-pickup-gate.integration",
    "test:legal-documents:postgres": "LEGAL_DOCUMENTS_POSTGRES_INTEGRATION=1 jest legal-documents-postgres.invariants.integration",
    "test:legal-documents:verify": "bash scripts/test/legal-documents-backend-verify.sh all",
    "test:legal-documents:verify:unit": "bash scripts/test/legal-documents-backend-verify.sh unit",
    "test:legal-documents:migration": "bash scripts/test/legal-documents-migration-test.sh all",
    "test:legal-documents:migration:empty": "bash scripts/test/legal-documents-migration-test.sh empty",
    "test:legal-documents:migration:legacy": "bash scripts/test/legal-documents-migration-test.sh legacy",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://synqdrive:synqdrive@localhost:5432/synqdrive} prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:prune": "ts-node prisma/prune-master-data.ts",
    "infra:up": "docker compose up -d postgres redis clickhouse",
    "infra:down": "docker compose down",
    "clickhouse:ping:url": "bash scripts/clickhouse-ping-url.sh",
    "clickhouse:ping:docker": "docker compose exec clickhouse clickhouse-client --user ${CLICKHOUSE_USER:-synqdrive} --password ${CLICKHOUSE_PASSWORD:-synqdrive_clickhouse_dev} --query \"SELECT 1\"",
    "clickhouse:backup:docker": "bash scripts/clickhouse-backup-local.sh",
    "clickhouse:restore:docker": "bash scripts/clickhouse-restore-local.sh",
    "clickhouse:ping": "npm run clickhouse:ping:docker",
    "clickhouse:backup:local": "npm run clickhouse:backup:docker",
    "clickhouse:restore:local": "npm run clickhouse:restore:docker"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@dimo-network/data-sdk": "^1.6.0",
    "@mistralai/mistralai": "^1.15.1",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "ethers": "^6.16.0",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.15.1",
    "otplib": "^12.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.7.0",
    "twilio": "^6.0.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.9.0",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "prisma": "^5.20.0",
    "rimraf": "^6.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.39.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@workers/(.*)$": "<rootDir>/workers/$1",
      "^@config/(.*)$": "<rootDir>/config/$1"
    }
  }
}
