  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription BillingSubscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  resolvedBy   User?                     @relation("BillingReconciliationDriftsResolved", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, resolvedAt, detectedAt])
  @@index([subscriptionId, resolvedAt])
  @@index([driftType, severity])
  @@map("billing_reconciliation_drifts")
}

/// Billing command inbox — idempotent mutation tracking for master subscription API.
model BillingCommand {
  id              String               @id @default(uuid())
  organizationId  String               @map("organization_id")
  commandType     String               @map("command_type")
  idempotencyKey  String               @map("idempotency_key")
  requestHash     String               @map("request_hash")
  requestPayload  Json                 @map("request_payload")
  actorUserId     String?              @map("actor_user_id")
  requestId       String?              @map("request_id")
  status          BillingCommandStatus @default(PENDING)
  resultReference String?              @map("result_reference")
  resultJson      Json?                @map("result_json")
  errorCode       String?              @map("error_code")
  errorMessage    String?              @map("error_message")
  aggregateId     String?              @map("aggregate_id")
  lockVersion     Int?                 @map("lock_version")
  createdAt       DateTime             @default(now()) @map("created_at")
  completedAt     DateTime?            @map("completed_at")
  failedAt        DateTime?            @map("failed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, commandType, createdAt])
  @@index([status, createdAt])
  @@index([aggregateId])
  @@map("billing_commands")
}

model BillingOrganizationPriceOverride {
  id                        String                        @id @default(uuid())
  organizationId            String                        @map("organization_id")
  priceBookId               String?                       @map("price_book_id")
  priceVersionId            String?                       @map("price_version_id")
  customUnitPriceCents      Int?                          @map("custom_unit_price_cents")
  customMonthlyMinimumCents Int?                          @map("custom_monthly_minimum_cents")
  reason                    String?
  validFrom                 DateTime                      @map("valid_from")
  validTo                   DateTime?                     @map("valid_to")
  status                    BillingOrgPriceOverrideStatus @default(ACTIVE)
  createdAt                 DateTime                      @default(now()) @map("created_at")
  updatedAt                 DateTime                      @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  priceBook    BillingPriceBook?    @relation(fields: [priceBookId], references: [id], onDelete: SetNull)
  priceVersion BillingPriceVersion? @relation(fields: [priceVersionId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@map("billing_organization_price_overrides")
}

// ------------------------------------------------
// PROSPECTS
// ------------------------------------------------

model Prospect {
  id                String           @id @default(uuid())
  companyName       String           @map("company_name")
  businessType      BusinessType     @map("business_type")
  website           String?
  phone             String?
  email             String?
  contactName       String?          @map("contact_name")
  city              String?
  country           String?
  fleetSizeEstimate Int?             @map("fleet_size_estimate")
  status            ProspectStatus   @default(NEW)
  priority          ProspectPriority @default(MEDIUM)
  notes             String?
  lastContactedAt   DateTime?        @map("last_contacted_at")
  convertedOrgId    String?          @map("converted_org_id")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([priority])
  @@index([businessType])
  @@map("prospects")
}

// ------------------------------------------------
// CUSTOMERS (rental/org-scoped)
// ------------------------------------------------

model Customer {
  id                        String                     @id @default(uuid())
  organizationId            String                     @map("organization_id")
  firstName                 String                     @map("first_name")
  lastName                  String                     @map("last_name")
  email                     String?
  phone                     String?
  licenseNumber             String?                    @map("license_number")
  dateOfBirth               DateTime?                  @map("date_of_birth")
  address                   String?
  city                      String?
  zip                       String?
  country                   String?
  company                   String?
  taxId                     String?                    @map("tax_id")
  customerType              CustomerType               @default(INDIVIDUAL) @map("customer_type")
  riskLevel                 CustomerRiskLevel          @default(NOT_ASSESSED) @map("risk_level")
  riskSource                CustomerRiskSource         @default(NONE) @map("risk_source")
  riskReason                String?                    @map("risk_reason")
  riskUpdatedAt             DateTime?                  @map("risk_updated_at")
  riskUpdatedByUserId       String?                    @map("risk_updated_by_user_id")
  notes                     String?
  licenseExpiry             DateTime?                  @map("license_expiry")
  licenseIssuedAt           DateTime?                  @map("license_issued_at")
  licenseClass              String?                    @map("license_class")
  idType                    String?                    @map("id_type")
  idNumber                  String?                    @map("id_number")
  idExpiry                  DateTime?                  @map("id_expiry")
  idVerified                Boolean                    @default(false) @map("id_verified")
  licenseVerified           Boolean                    @default(false) @map("license_verified")
  idVerificationStatus      CustomerVerificationStatus @default(NOT_SUBMITTED) @map("id_verification_status")
  licenseVerificationStatus CustomerVerificationStatus @default(NOT_SUBMITTED) @map("license_verification_status")
  // Legacy KYC URLs — read/backward-compat only; new uploads use CustomerDocument.
  idFrontUrl                String?                    @map("id_front_url")
  idBackUrl                 String?                    @map("id_back_url")
  licenseFrontUrl           String?                    @map("license_front_url")
  licenseBackUrl            String?                    @map("license_back_url")
  emailNormalized           String?                    @map("email_normalized")
  phoneNormalized           String?                    @map("phone_normalized")
  licenseNumberNormalized   String?                    @map("license_number_normalized")
  idNumberNormalized        String?                    @map("id_number_normalized")
  fullNameNormalized        String?                    @map("full_name_normalized")
  archivedAt                DateTime?                  @map("archived_at")
  archivedByUserId          String?                    @map("archived_by_user_id")
  archiveReason             String?                    @map("archive_reason")
  piiAnonymizedAt           DateTime?                  @map("pii_anonymized_at")
  piiAnonymizedByUserId     String?                    @map("pii_anonymized_by_user_id")
  retentionUntil            DateTime?                  @map("retention_until")
  status                    CustomerStatus             @default(ACTIVE)
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  organization           Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings               Booking[]
  rentalDrivingAnalyses  RentalDrivingAnalysis[]
  documents              CustomerDocument[]
  verificationChecks     CustomerVerificationCheck[]
  timelineEvents         CustomerTimelineEvent[]
  misuseCases            MisuseCase[]
  outboundEmails         OutboundEmail[]
  bookingPaymentRequests BookingPaymentRequest[]

  vehicleDamages        VehicleDamage[]
  whatsappConversations WhatsAppConversation[]
  whatsappConsents      WhatsAppConsent[]

  @@index([organizationId])
  @@index([email])
  @@index([organizationId, emailNormalized])
  @@index([organizationId, phoneNormalized])
  @@index([organizationId, licenseNumberNormalized])
  @@index([organizationId, idNumberNormalized])
  @@index([organizationId, fullNameNormalized])
  @@index([organizationId, archivedAt])
  @@index([organizationId, status])
  @@index([organizationId, riskLevel])
  @@map("customers")
}

model CustomerDocument {
  id               String                 @id @default(uuid())
  organizationId   String                 @map("organization_id")
  customerId       String                 @map("customer_id")
  type             CustomerDocumentType
  status           CustomerDocumentStatus @default(UPLOADED)
  fileKey          String                 @map("file_key")
  originalFileName String?                @map("original_file_name")
  mimeType         String?                @map("mime_type")
  sizeBytes        Int?                   @map("size_bytes")
  extractedJson    Json?                  @map("extracted_json")
  uploadedByUserId String?                @map("uploaded_by_user_id")
  reviewedByUserId String?                @map("reviewed_by_user_id")
  reviewedAt       DateTime?              @map("reviewed_at")
  rejectedReason   String?                @map("rejected_reason")
  expiresAt        DateTime?              @map("expires_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([type])
  @@index([status])
  @@map("customer_documents")
}

model CustomerVerificationCheck {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  customerId     String  @map("customer_id")
  bookingId      String? @map("booking_id")

  provider CustomerVerificationProvider
  kind     CustomerVerificationCheckKind
  status   CustomerVerificationCheckStatus @default(NOT_STARTED)

  providerSessionId  String? @map("provider_session_id")
  providerWorkflowId String? @map("provider_workflow_id")
  providerStatus     String? @map("provider_status")
  providerUrl        String? @map("provider_url")
  vendorData         String? @map("vendor_data")

  extractedJson Json? @map("extracted_json")
  decisionJson  Json? @map("decision_json")
  warnings      Json?

  checkedByUserId String?   @map("checked_by_user_id")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  expiresAt       DateTime? @map("expires_at")
  retentionUntil  DateTime? @map("retention_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([provider, providerSessionId])
  @@index([organizationId, customerId, kind, status])
  @@index([bookingId])
  @@map("customer_verification_checks")
}

model DiditWebhookEvent {
  id             String    @id @default(uuid())
  eventId        String?   @map("event_id")
  sessionId      String?   @map("session_id")
  eventType      String?   @map("event_type")
  providerStatus String?   @map("provider_status")
  payloadHash    String    @map("payload_hash")
  signatureValid Boolean   @default(false) @map("signature_valid")
  processedAt    DateTime? @map("processed_at")
  rawPayload     Json      @map("raw_payload")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([payloadHash])
  @@unique([eventId])
  @@index([sessionId])
  @@map("didit_webhook_events")
}

model CustomerTimelineEvent {
  id              String                    @id @default(uuid())
  organizationId  String                    @map("organization_id")
  customerId      String                    @map("customer_id")
  type            CustomerTimelineEventType
  title           String
  description     String?
  metadata        Json?
  createdByUserId String?                   @map("created_by_user_id")
  createdAt       DateTime                  @default(now()) @map("created_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([createdAt])
  @@map("customer_timeline_events")
}

model CustomerEligibilityPolicy {
  id                                        String   @id @default(uuid())
  organizationId                            String   @unique @map("organization_id")
  requireVerifiedIdForConfirmedBooking      Boolean  @default(false) @map("require_verified_id_for_confirmed_booking")
  requireVerifiedLicenseForConfirmedBooking Boolean  @default(false) @map("require_verified_license_for_confirmed_booking")
  requireVerifiedIdForPickup                Boolean  @default(true) @map("require_verified_id_for_pickup")
  requireVerifiedLicenseForPickup           Boolean  @default(true) @map("require_verified_license_for_pickup")
  blockExpiredLicense                       Boolean  @default(true) @map("block_expired_license")
  blockExpiredId                            Boolean  @default(true) @map("block_expired_id")
  warnLicenseExpiringWithinDays             Int      @default(30) @map("warn_license_expiring_within_days")
  warnIdExpiringWithinDays                  Int      @default(30) @map("warn_id_expiring_within_days")
  blockHighRiskCustomer                     Boolean  @default(false) @map("block_high_risk_customer")
  blockOpenOverdueInvoices                  Boolean  @default(false) @map("block_open_overdue_invoices")
  blockOpenFines                            Boolean  @default(false) @map("block_open_fines")
  createdAt                                 DateTime @default(now()) @map("created_at")
  updatedAt                                 DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("customer_eligibility_policies")
}

// ------------------------------------------------
// RENTAL RULES & VEHICLE ELIGIBILITY
// ------------------------------------------------

enum RentalForeignTravelPolicy {
  ALLOWED
  APPROVAL_REQUIRED
  NOT_ALLOWED
}

enum RentalAdditionalDriverPolicy {
  ALLOWED
  APPROVAL_REQUIRED
  NOT_ALLOWED
}

enum RentalYoungDriverPolicy {
  ALLOWED
  FEE_REQUIRED
  NOT_ALLOWED
}

enum RentalVehicleCategoryType {
  ECONOMY
  COMPACT
  TRANSPORTER
  PREMIUM
  PERFORMANCE
  LUXURY
  EV_PERFORMANCE
  CUSTOM
}

model OrganizationRentalRules {
  id                          String                        @id @default(uuid())
  organizationId              String                        @unique @map("organization_id")
  minimumAgeYears             Int?                          @map("minimum_age_years")
  minimumLicenseHoldingMonths Int?                          @map("minimum_license_holding_months")
  depositAmountCents          Int?                          @map("deposit_amount_cents")
  depositCurrency             String                        @default("EUR") @map("deposit_currency")
  creditCardRequired          Boolean?
  foreignTravelPolicy         RentalForeignTravelPolicy?
  additionalDriverPolicy      RentalAdditionalDriverPolicy?
  youngDriverPolicy           RentalYoungDriverPolicy?
  insuranceRequirement        String?                       @map("insurance_requirement")
  manualApprovalRequired      Boolean?                      @map("manual_approval_required")
  notes                       String?
  isActive                    Boolean                       @default(true) @map("is_active")
  createdAt                   DateTime                      @default(now()) @map("created_at")
  updatedAt                   DateTime                      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_rental_rules")
}

model RentalVehicleCategory {
  id                          String                        @id @default(uuid())
  organizationId              String                        @map("organization_id")
  name                        String
  description                 String?
  type                        RentalVehicleCategoryType?
  color                       String?
  icon                        String?
  minimumAgeYears             Int?                          @map("minimum_age_years")
  minimumLicenseHoldingMonths Int?                          @map("minimum_license_holding_months")
  depositAmountCents          Int?                          @map("deposit_amount_cents")
  depositCurrency             String?                       @map("deposit_currency")
  creditCardRequired          Boolean?                      @map("credit_card_required")
  foreignTravelPolicy         RentalForeignTravelPolicy?
  additionalDriverPolicy      RentalAdditionalDriverPolicy?
  youngDriverPolicy           RentalYoungDriverPolicy?
  insuranceRequirement        String?                       @map("insurance_requirement")
  manualApprovalRequired      Boolean?                      @map("manual_approval_required")
  notes                       String?
  isActive                    Boolean                       @default(true) @map("is_active")
  createdAt                   DateTime                      @default(now()) @map("created_at")
  updatedAt                   DateTime                      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("rental_vehicle_categories")
}

model VehicleRentalRequirementOverride {
  id                          String                        @id @default(uuid())
  organizationId              String                        @map("organization_id")
  vehicleId                   String                        @unique @map("vehicle_id")
  minimumAgeYears             Int?                          @map("minimum_age_years")
  minimumLicenseHoldingMonths Int?                          @map("minimum_license_holding_months")
  depositAmountCents          Int?                          @map("deposit_amount_cents")
  depositCurrency             String?                       @map("deposit_currency")
  creditCardRequired          Boolean?                      @map("credit_card_required")
  foreignTravelPolicy         RentalForeignTravelPolicy?
  additionalDriverPolicy      RentalAdditionalDriverPolicy?
  youngDriverPolicy           RentalYoungDriverPolicy?
  insuranceRequirement        String?                       @map("insurance_requirement")
  manualApprovalRequired      Boolean?                      @map("manual_approval_required")
  notes                       String?
  createdAt                   DateTime                      @default(now()) @map("created_at")
  updatedAt                   DateTime                      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("vehicle_rental_requirement_overrides")
}

// ------------------------------------------------
// BOOKINGS
// ------------------------------------------------

model Booking {
  id                      String                @id @default(uuid())
  organizationId          String                @map("organization_id")
  customerId              String                @map("customer_id")
  vehicleId               String                @map("vehicle_id")
  pickupStationId         String?               @map("pickup_station_id")
  returnStationId         String?               @map("return_station_id")
  actualPickupStationId   String?               @map("actual_pickup_station_id")
  actualReturnStationId   String?               @map("actual_return_station_id")
  pickupAddressOverride   String?               @map("pickup_address_override")
  returnAddressOverride   String?               @map("return_address_override")
  isOneWayRental          Boolean               @default(false) @map("is_one_way_rental")
  stationTransferFeeCents Int?                  @map("station_transfer_fee_cents")
  startDate               DateTime              @map("start_date")
  endDate                 DateTime              @map("end_date")
  dailyRateCents          Int?                  @map("daily_rate_cents")
  totalPriceCents         Int?                  @map("total_price_cents")
  kmIncluded              Int?                  @map("km_included")
  kmDriven                Int?                  @map("km_driven")
  insuranceOptions        Json?                 @map("insurance_options")
  extrasJson              Json?                 @map("extras_json")
  currency                String                @default("eur")
  status                  BookingStatus         @default(PENDING)
  /// Derived summary from BookingPaymentRequest / invoice state — not financial source of truth.
  paymentStatus           BookingPaymentStatus  @default(UNPAID) @map("payment_status")
  /// Checkout payment intent from wizard — does not imply money received.
  paymentIntent           BookingPaymentIntent? @map("payment_intent")
  notes                   String?
  cancelledAt             DateTime?             @map("cancelled_at")
  completedAt             DateTime?             @map("completed_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  organization            Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer                Customer                    @relation(fields: [customerId], references: [id])
  vehicle                 Vehicle                     @relation(fields: [vehicleId], references: [id])
  pickupStation           Station?                    @relation("BookingPickupStation", fields: [pickupStationId], references: [id], onDelete: SetNull)
  returnStation           Station?                    @relation("BookingReturnStation", fields: [returnStationId], references: [id], onDelete: SetNull)
  actualPickupStation     Station?                    @relation("BookingActualPickupStation", fields: [actualPickupStationId], references: [id], onDelete: SetNull)
  actualReturnStation     Station?                    @relation("BookingActualReturnStation", fields: [actualReturnStationId], references: [id], onDelete: SetNull)
  rentalDrivingAnalysis   RentalDrivingAnalysis?
  handoverProtocols       BookingHandoverProtocol[]
  verificationChecks      CustomerVerificationCheck[]
  misuseCases             MisuseCase[]
  priceSnapshots          BookingPriceSnapshot[]
  pricingQuote            PricingQuote?               @relation("PricingQuoteConsumedBooking")
  vehicleDamages          VehicleDamage[]
  whatsappConversations   WhatsAppConversation[]
  outboundEmails          OutboundEmail[]
  bookingPaymentRequests  BookingPaymentRequest[]
  drivingIntelligenceJobs DrivingIntelligenceJob[]

  @@index([organizationId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([pickupStationId])
  @@index([returnStationId])
  // Service-window detector and availability lookups filter by
  // vehicleId + status + startDate.
  @@index([vehicleId, status, startDate])
  @@index([organizationId, status])
  @@map("bookings")
}

// ------------------------------------------------
// PRICING & TARIFFS (V4.8.22)
// ------------------------------------------------

enum PriceTariffVersionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  ARCHIVED
}

enum PriceOptionPricingType {
  PER_DAY
  PER_BOOKING
}

enum BookingPriceLineItemType {
  BASE_RENTAL
  INSURANCE
  EXTRA
  MILEAGE_PACKAGE
  DISCOUNT
  TAX
  DEPOSIT
  MANUAL_ADJUSTMENT
  EXTRA_KM
}

model PriceBook {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  currency       String   @default("EUR")
  taxRatePercent Int      @default(19) @map("tax_rate_percent")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tariffGroups          PriceTariffGroup[]
  tariffVersions        PriceTariffVersion[]
  vehicleAssignments    VehicleTariffAssignment[]
  bookingPriceSnapshots BookingPriceSnapshot[]

  @@index([organizationId])
  @@map("price_books")
}

model PriceTariffGroup {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  priceBookId    String   @map("price_book_id")
  name           String
  description    String?
  category       String?
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  priceBook             PriceBook                 @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  versions              PriceTariffVersion[]
  vehicleAssignments    VehicleTariffAssignment[]
  bookingPriceSnapshots BookingPriceSnapshot[]

  @@index([organizationId])
  @@index([priceBookId])
  @@map("price_tariff_groups")
}

model PriceTariffVersion {
  id             String                   @id @default(uuid())
  organizationId String                   @map("organization_id")
  priceBookId    String                   @map("price_book_id")
  tariffGroupId  String                   @map("tariff_group_id")
  versionNumber  Int                      @map("version_number")
  status         PriceTariffVersionStatus @default(DRAFT)
  validFrom      DateTime                 @map("valid_from")
  validTo        DateTime?                @map("valid_to")
  createdBy      String?                  @map("created_by")
  updatedBy      String?                  @map("updated_by")
  publishedBy    String?                  @map("published_by")
  publishedAt    DateTime?                @map("published_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  priceBook             PriceBook               @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  tariffGroup           PriceTariffGroup        @relation(fields: [tariffGroupId], references: [id], onDelete: Cascade)
  rate                  TariffRate?
  mileagePackages       MileagePackage[]
  insuranceOptions      TariffInsuranceOption[]
  extraOptions          TariffExtraOption[]
  bookingPriceSnapshots BookingPriceSnapshot[]
  pricingQuotes         PricingQuote[]

  @@unique([tariffGroupId, versionNumber])
  @@index([organizationId])
  @@index([tariffGroupId, status])
  @@map("price_tariff_versions")
}

model TariffRate {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  tariffVersionId    String   @unique @map("tariff_version_id")
  dailyRateCents     Int      @map("daily_rate_cents")
  weeklyRateCents    Int      @default(0) @map("weekly_rate_cents")
  monthlyRateCents   Int      @default(0) @map("monthly_rate_cents")
  includedKmPerDay   Int      @default(200) @map("included_km_per_day")
  extraKmPriceCents  Int      @default(0) @map("extra_km_price_cents")
  depositAmountCents Int      @default(0) @map("deposit_amount_cents")
  minimumRentalDays  Int?     @map("minimum_rental_days")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tariffVersion PriceTariffVersion @relation(fields: [tariffVersionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("tariff_rates")
}

model MileagePackage {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  tariffVersionId String   @map("tariff_version_id")
  label           String
  includedKm      Int      @map("included_km")
  priceCents      Int      @map("price_cents")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tariffVersion PriceTariffVersion @relation(fields: [tariffVersionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([tariffVersionId])
  @@map("mileage_packages")
