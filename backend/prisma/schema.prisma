// ------------------------------------------------
// DRIVING INTELLIGENCE V2 — additive enums (Prompt 12/76)
// Spec: docs/architecture/driving-intelligence-v2-prisma-plan.md
// No models/columns in this phase — enum types only.
// ------------------------------------------------

/// Per-vehicle analysis capability gate (Ebene 5).
enum DrivingCapabilityStatus {
  UNKNOWN
  SUPPORTED
  LIMITED
  UNSUPPORTED
  DEGRADED
}

/// Which V2 evaluation dimension a run or evidence row belongs to.
enum DrivingAnalysisDimension {
  CAPABILITY
  ASSESSABILITY
  VEHICLE_LOAD
  DRIVER_CONDUCT
  MISUSE_EVIDENCE
  ATTRIBUTION
  DECISION_SUMMARY
  RENTAL_AGGREGATE
  HEALTH_IMPACT
}

/// Trip analysis data-quality gate (Ebene 6) — not a conduct verdict.
enum DrivingAssessabilityStatus {
  FULL
  LIMITED
  NOT_ASSESSABLE
}

/// Central evidence provenance kind (Driving Intelligence V2 P15).
/// Replaces the unused P12 placeholder values — no columns referenced the prior set.
enum DrivingEvidenceSourceType {
  MEASURED_SIGNAL
  PROVIDER_CLASSIFIED_EVENT
  RECONSTRUCTED_EVENT
  ESTIMATED_PROXY
  CONTEXT_SIGNAL
  MANUAL_VERIFIED
  WORKSHOP_VERIFIED
}

/// Publication / conduct eligibility strength for V2 evidence and summaries.
enum DrivingEvidenceStrength {
  NONE
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

/// Shadow / publish lifecycle for V2 analysis artifacts.
enum DrivingAnalysisMaturity {
  SHADOW
  CANDIDATE
  PUBLISHED
  SUPERSEDED
  FAILED
}

/// Trip attribution subject level (Ebene 10).
enum DrivingAttributionType {
  CONFIRMED_DRIVER
  BOOKING_CUSTOMER
  ASSIGNED_DRIVER
  VEHICLE_ONLY
  PRIVATE_UNASSIGNED
  UNKNOWN
}

/// Attribution confidence — distinct from `MisuseCaseConfidence` / `DetectionConfidence` (domain separation).
enum DrivingAttributionConfidence {
  HIGH
  MEDIUM
  LOW
}

/// Operator recommendation (Ebene 12) — no automatic sanction.
enum DrivingDecisionRecommendation {
  KEINE_MASSNAHME
  BEOBACHTEN
  KUNDENGESPRAECH
  MANUELLE_MIETFREIGABE
  FAHRZEUGPRUEFUNG
  TECHNISCHE_DATENPRUEFUNG
}

/// Dimension B — vehicle mechanical load level.
enum VehicleLoadLevel {
  SCHONEND
  NORMAL
  ERHOHT
  STARK_ERHOHT
}

/// Dimension C — driver conduct level (requires assessability + attribution gates in app logic).
enum DriverConductLevel {
  UNAUFFAELLIG
  DYNAMISCH
  AUFFAELLIG
  STARK_AUFFAELLIG
  NICHT_BEWERTBAR
}

/// Dimension D — misuse / damage evidence level.
enum MisuseEvidenceLevel {
  KEINE
  EINZELNER_HINWEIS
  MEHRERE_BELASTBARE_HINWEISE
  STARKER_VERDACHT
  SCHADENSPRUEFUNG
}

/// Per-vehicle empirical capability probe (signal or detector) — Driving Intelligence V2 P13.
model VehicleDrivingCapability {
  id                   String                  @id @default(uuid())
  organizationId       String                  @map("organization_id")
  vehicleId            String                  @map("vehicle_id")
  /// Hardware class at last probe — informational; does not alone imply availability.
  hardwareProfile      HardwareType            @map("hardware_profile")
  providerSource       String                  @map("provider_source")
  signalName           String?                 @map("signal_name")
  detectorName         String?                 @map("detector_name")
  /// Stable key: `signalName` or `detectorName` (exactly one required at write time).
  capabilityKey        String                  @map("capability_key")
  capabilityStatus     DrivingCapabilityStatus @default(UNKNOWN) @map("capability_status")
  firstSeenAt          DateTime                @map("first_seen_at")
  lastSeenAt           DateTime                @map("last_seen_at")
  checkedAt            DateTime                @map("checked_at")
  effectiveCadenceMs   Int?                    @map("effective_cadence_ms")
  p95CadenceMs         Int?                    @map("p95_cadence_ms")
  coverage             Float?                  @map("coverage")
  nativeEventAvailable Boolean                 @default(false) @map("native_event_available")
  metadata             Json?                   @map("metadata")
  capabilityVersion    String                  @map("capability_version")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([organizationId, vehicleId, providerSource, capabilityKey])
  @@index([organizationId])
  @@index([vehicleId, capabilityStatus])
  @@index([vehicleId, checkedAt])
  @@index([providerSource, capabilityKey])
  @@map("vehicle_driving_capabilities")
}

/// Per-dimension trip analysis gate (Driving Intelligence V2 P14).
enum TripAssessabilityDimension {
  TRIP_BOUNDARY
  ROUTE
  VEHICLE_LOAD
  NATIVE_BEHAVIOR
  RECONSTRUCTED_BEHAVIOR
  ENGINE_MISUSE
  BRAKING_INTENSITY
  CORNERING
  DAMAGE_RISK
  DRIVER_CONDUCT
  ATTRIBUTION
}

/// Per-dimension assessability status — distinct from legacy `DrivingAssessabilityStatus`.
enum TripAssessabilityDimensionStatus {
  ASSESSABLE
  LIMITED
  INSUFFICIENT_DATA
  UNSUPPORTED
  PROVIDER_ERROR
  NOT_APPLICABLE
}

/// Materialized per-dimension assessability for one trip (Driving Intelligence V2 P14).
model TripAssessability {
  id                 String                           @id @default(uuid())
  organizationId     String                           @map("organization_id")
  vehicleId          String                           @map("vehicle_id")
  tripId             String                           @map("trip_id")
  dimension          TripAssessabilityDimension
  status             TripAssessabilityDimensionStatus
  reasonsJson        Json                             @default("[]") @map("reasons_json")
  coverage           Float?                           @map("coverage")
  effectiveCadenceMs Int?                             @map("effective_cadence_ms")
  p95CadenceMs       Int?                             @map("p95_cadence_ms")
  capabilityVersion  String                           @map("capability_version")
  inputWindowStart   DateTime                         @map("input_window_start")
  inputWindowEnd     DateTime?                        @map("input_window_end")
  calculatedAt       DateTime                         @map("calculated_at")
  policyVersion      String                           @map("policy_version")
  analysisRunId      String?                          @map("analysis_run_id")
  createdAt          DateTime                         @default(now()) @map("created_at")
  updatedAt          DateTime                         @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip         VehicleTrip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  analysisRun  DrivingAnalysisRun? @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)

  @@unique([organizationId, tripId, dimension])
  @@index([organizationId])
  @@index([vehicleId, calculatedAt])
  @@index([tripId, dimension])
  @@index([tripId, status])
  @@map("trip_assessabilities")
}

/// Trip-scoped analysis pipeline type (Driving Intelligence V2 P16).
enum DrivingAnalysisType {
  TRIP_ENRICHMENT
  TRIP_ASSESSABILITY
  TRIP_DECISION_SUMMARY
  DRIVING_IMPACT
  MISUSE_DETECTION
}

/// Deterministic run lifecycle status — distinct from `DrivingAnalysisMaturity`.
enum DrivingAnalysisRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SUPERSEDED
}

/// Deterministic provenance envelope for V2 analysis outputs (P16).
model DrivingAnalysisRun {
  id                String                   @id @default(uuid())
  organizationId    String                   @map("organization_id")
  vehicleId         String                   @map("vehicle_id")
  tripId            String                   @map("trip_id")
  analysisType      DrivingAnalysisType      @map("analysis_type")
  modelVersion      String                   @map("model_version")
  inputFingerprint  String                   @map("input_fingerprint")
  capabilityVersion String                   @map("capability_version")
  startedAt         DateTime                 @map("started_at")
  completedAt       DateTime?                @map("completed_at")
  maturity          DrivingAnalysisMaturity  @default(SHADOW)
  status            DrivingAnalysisRunStatus @default(PENDING)
  stageSummaryJson  Json?                    @map("stage_summary_json")
  recomputeReason   String?                  @map("recompute_reason")
  supersedesRunId   String?                  @map("supersedes_run_id")
  errorCode         String?                  @map("error_code")
  errorMessage      String?                  @map("error_message")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle             Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip                VehicleTrip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supersedesRun       DrivingAnalysisRun?      @relation("DrivingAnalysisRunSupersedes", fields: [supersedesRunId], references: [id], onDelete: SetNull)
  supersededByRuns    DrivingAnalysisRun[]     @relation("DrivingAnalysisRunSupersedes")
  tripAssessabilities TripAssessability[]
  drivingEvidence     DrivingEvidence[]
  intelligenceJobs    DrivingIntelligenceJob[]

  @@index([organizationId, startedAt])
  @@index([tripId, analysisType, status])
  @@index([vehicleId, startedAt])
  @@index([inputFingerprint])
  @@index([supersedesRunId])
  @@map("driving_analysis_runs")
}

/// Typed persistent job envelope for Driving Intelligence V2 queue refactor (P18).
enum DrivingIntelligenceJobType {
  DRIVING_NATIVE_EVENTS_INGEST
  DRIVING_EVENT_CONTEXT_ENRICH
  DRIVING_ROUTE_ENRICH
  DRIVING_IMPACT_COMPUTE
  DRIVING_MISUSE_RECONCILE
  DRIVING_ASSESSABILITY_COMPUTE
  DRIVING_ATTRIBUTION_RESOLVE
  DRIVING_DECISION_SUMMARY_COMPUTE
  RENTAL_DRIVING_ANALYSIS_RECOMPUTE
  DRIVING_HEALTH_IMPACT_PUBLISH
  DIMO_TRIP_SEGMENT_VALIDATE
}

enum DrivingIntelligenceJobStatus {
  PENDING
  ENQUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model DrivingIntelligenceJob {
  id             String                       @id @default(uuid())
  organizationId String                       @map("organization_id")
  vehicleId      String                       @map("vehicle_id")
  tripId         String?                      @map("trip_id")
  bookingId      String?                      @map("booking_id")
  analysisRunId  String                       @map("analysis_run_id")
  jobType        DrivingIntelligenceJobType   @map("job_type")
  modelVersion   String                       @map("model_version")
  idempotencyKey String                       @map("idempotency_key")
  correlationId  String                       @map("correlation_id")
  requestedAt    DateTime                     @map("requested_at")
  status         DrivingIntelligenceJobStatus @default(PENDING)
  bullJobId      String?                      @map("bull_job_id")
  errorCode      String?                      @map("error_code")
  errorMessage   String?                      @map("error_message")
  completedAt    DateTime?                    @map("completed_at")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip         VehicleTrip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking      Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  analysisRun  DrivingAnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, jobType, status])
  @@index([vehicleId, requestedAt])
  @@index([tripId, jobType])
  @@index([bookingId, jobType])
  @@index([analysisRunId])
  @@index([correlationId])
  @@map("driving_intelligence_jobs")
}

/// Immutable normalized evidence index — references source rows, never full provider payloads (P15).
model DrivingEvidence {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  vehicleId      String                    @map("vehicle_id")
  tripId         String?                   @map("trip_id")
  bookingId      String?                   @map("booking_id")
  customerId     String?                   @map("customer_id")
  dimension      DrivingAnalysisDimension? @map("dimension")
  analysisRunId  String?                   @map("analysis_run_id")

  sourceType         DrivingEvidenceSourceType @map("source_type")
  strength           DrivingEvidenceStrength
  observedAt         DateTime                  @map("observed_at")
  providerSource     String                    @map("provider_source")
  capabilityVersion  String                    @map("capability_version")
  modelVersion       String                    @map("model_version")
  coverage           Float?                    @map("coverage")
  effectiveCadenceMs Int?                      @map("effective_cadence_ms")
  p95CadenceMs       Int?                      @map("p95_cadence_ms")
  /// Detector or classifier confidence in [0, 1] when applicable.
  confidence         Float?                    @map("confidence")
  /// Pointer to canonical source row — not a payload copy.
  sourceEntityJson   Json                      @map("source_entity_json")
  /// Bounded operational context — no raw provider payloads.
  contextJson        Json?                     @map("context_json")
  idempotencyKey     String                    @map("idempotency_key")
  /// False for CONTEXT_SIGNAL and other context-only rows that cannot alone justify misuse.
  misuseCaseEligible Boolean                   @default(true) @map("misuse_case_eligible")
  contractVersion    String                    @map("contract_version")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip         VehicleTrip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  analysisRun  DrivingAnalysisRun? @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([vehicleId, observedAt])
  @@index([tripId, dimension])
  @@index([sourceType, observedAt])
  @@index([analysisRunId])
  @@map("driving_evidence")
}

model MisuseCase {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  vehicleId      String  @map("vehicle_id")
  tripId         String? @map("trip_id")
  bookingId      String? @map("booking_id")
  customerId     String? @map("customer_id")

  category   MisuseCaseCategory
  type       MisuseCaseType
  severity   MisuseCaseSeverity
  confidence MisuseCaseConfidence

  title             String
  description       String?
  recommendedAction String? @map("recommended_action")

  attributionScope              MisuseAttributionScope     @map("attribution_scope")
  assignmentStatusSnapshot      TripAssignmentStatus?      @map("assignment_status_snapshot")
  assignmentSubjectTypeSnapshot TripAssignmentSubjectType? @map("assignment_subject_type_snapshot")
  assignmentSubjectIdSnapshot   String?                    @map("assignment_subject_id_snapshot")
  assignedBookingIdSnapshot     String?                    @map("assigned_booking_id_snapshot")
  isPrivateTripSnapshot         Boolean                    @default(false) @map("is_private_trip_snapshot")

  firstDetectedAt DateTime @map("first_detected_at")
  lastDetectedAt  DateTime @map("last_detected_at")
  eventCount      Int      @default(1) @map("event_count")

  evidenceSummary   Json?   @map("evidence_summary")
  fingerprint       String  @unique
  informationalOnly Boolean @default(true) @map("informational_only")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip         VehicleTrip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking      Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer     Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  evidence     MisuseCaseEvidence[]

  @@index([organizationId])
  @@index([vehicleId])
  @@index([tripId])
  @@index([bookingId])
  @@index([customerId])
  @@index([category])
  @@index([type])
  @@index([severity])
  @@index([lastDetectedAt])
  @@map("misuse_cases")
}

model MisuseCaseEvidence {
  id             String                   @id @default(uuid())
  caseId         String                   @map("case_id")
  sourceType     MisuseEvidenceSourceType @map("source_type")
  sourceId       String?                  @map("source_id")
  organizationId String                   @map("organization_id")
  vehicleId      String                   @map("vehicle_id")
  tripId         String?                  @map("trip_id")
  bookingId      String?                  @map("booking_id")
  customerId     String?                  @map("customer_id")

  eventType    String
  severity     MisuseCaseSeverity?
  confidence   MisuseCaseConfidence?
  occurredAt   DateTime              @map("occurred_at")
  snapshotJson Json?                 @map("snapshot_json")

  createdAt DateTime @default(now()) @map("created_at")

  misuseCase MisuseCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([organizationId])
  @@index([vehicleId])
  @@index([tripId])
  @@index([sourceType, sourceId])
  @@map("misuse_case_evidence")
}

