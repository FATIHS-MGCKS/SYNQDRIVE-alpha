  tractionBatteryPowerKw                Float?    @map("traction_battery_power_kw")
  /// Provider-reported HV battery SOH (%) when available.
  tractionBatterySohPercent             Float?    @map("traction_battery_soh_percent")
  /// Average HV battery temperature in Celsius.
  tractionBatteryTemperatureC           Float?    @map("traction_battery_temperature_c")
  /// Charging power in kW while charging.
  tractionBatteryChargingPowerKw        Float?    @map("traction_battery_charging_power_kw")
  /// Added charging energy for current session in kWh.
  tractionBatteryAddedEnergyKwh         Float?    @map("traction_battery_added_energy_kwh")
  /// Whether charging is currently active.
  tractionBatteryIsCharging             Boolean?  @map("traction_battery_is_charging")
  /// Whether charging cable is currently connected.
  tractionBatteryChargingCableConnected Boolean?  @map("traction_battery_charging_cable_connected")
  /// Current HV battery voltage.
  tractionBatteryCurrentVoltage         Float?    @map("traction_battery_current_voltage")
  /// Provider-reported gross HV capacity in kWh.
  tractionBatteryGrossCapacityKwh       Float?    @map("traction_battery_gross_capacity_kwh")
  /// Provider-reported current HV battery energy in kWh.
  tractionBatteryCurrentEnergyKwh       Float?    @map("traction_battery_current_energy_kwh")
