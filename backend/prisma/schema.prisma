// ------------------------------------------------
// ORGANIZATIONS
// ------------------------------------------------

model Organization {
  id                String             @id @default(uuid())
  companyName       String             @map("company_name")
  shortCode         String?            @unique @map("short_code")
  businessType      BusinessType       @map("business_type")
  address           String?
  city              String?
  state             String?
  zip               String?
  country           String?
  taxId             String?            @map("tax_id")
  legalCompanyName  String?            @map("legal_company_name")
  legalForm         String?            @map("legal_form")
  taxNumber         String?            @map("tax_number")
  vatId             String?            @map("vat_id")
  isSmallBusiness   Boolean            @default(false) @map("is_small_business")
  defaultVatRate    Float?             @map("default_vat_rate")
  invoicePrefix     String?            @map("invoice_prefix")
  nextInvoiceNumber Int                @default(1) @map("next_invoice_number")
  paymentTermsDays  Int                @default(7) @map("payment_terms_days")
  invoiceEmail      String?            @map("invoice_email")
  bankName          String?            @map("bank_name")
  iban              String?
  bic               String?
  pdfFooterText     String?            @map("pdf_footer_text")
  emailSignature    String?            @map("email_signature")
  accentColor       String?            @map("accent_color")
  logoDarkUrl       String?            @map("logo_dark_url")
  pdfLogoUrl        String?            @map("pdf_logo_url")
  phone             String?
  email             String?
  website           String?
  timezone          String?
  language          String?
  managerName       String?            @map("manager_name")
  managerEmail      String?            @map("manager_email")
  logoUrl           String?            @map("logo_url")
  status            OrganizationStatus @default(ACTIVE)
  /// End-customer Stripe Connect payments — disabled by default; enable via platform admin only.
  paymentsEnabled   Boolean            @default(false) @map("payments_enabled")
  lastActiveAt      DateTime?          @map("last_active_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  memberships                       OrganizationMembership[]
  organizationProducts              OrganizationProduct[]
  stations                          Station[]
  vehicles                          Vehicle[]
  vehicleComplaints                 VehicleComplaint[]
  vehicleDrivingAssessmentQualities VehicleDrivingAssessmentQuality[]
  orgIntegrations                   OrganizationIntegration[]
  subscriptions                     BillingSubscription[]
  billingSubscriptionItems          BillingSubscriptionItem[]
  billingUsageSnapshots             BillingUsageSnapshot[]
  billingBillableVehicleAssignments BillingBillableVehicleAssignment[]
  billingQuantityEvents             BillingQuantityEvent[]
  billingPaymentMethods             BillingPaymentMethod[]
  billingDisputes                   BillingDispute[]
  billingOrgPriceOverrides          BillingOrganizationPriceOverride[]
  billingAuditLogs                  BillingAuditLog[]
  billingCommands                   BillingCommand[]
  billingReconciliationDrifts       BillingReconciliationDrift[]
  billingReconciliationRuns         BillingReconciliationRun[]
  customers                         Customer[]
  customerDocuments                 CustomerDocument[]
  customerVerificationChecks        CustomerVerificationCheck[]
  customerTimelineEvents            CustomerTimelineEvent[]
  customerEligibilityPolicy         CustomerEligibilityPolicy?
  organizationRentalRules           OrganizationRentalRules?
  rentalVehicleCategories           RentalVehicleCategory[]
  vehicleRentalRequirementOverrides VehicleRentalRequirementOverride[]
  bookings                          Booking[]
  bookingHandoverProtocols          BookingHandoverProtocol[]
  activityLogs                      ActivityLog[]
  rentalDrivingAnalyses             RentalDrivingAnalysis[]
  vendors                           Vendor[]
