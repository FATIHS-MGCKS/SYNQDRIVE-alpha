// ------------------------------------------------
// DRIVING EVENTS
// ------------------------------------------------

model DrivingEvent {
  id             String             @id @default(uuid())
  vehicleId      String             @map("vehicle_id")
  organizationId String?            @map("organization_id")
  eventType      DrivingEventType   @map("event_type")
  // V3: which hardware/pipeline produced this event
  source         DrivingEventSource @default(TELEMETRY_EVENTS) @map("source")
  severity       Float              @default(0)
  latitude       Float?
  longitude      Float?
  speedKmh       Float?             @map("speed_kmh")
  deltaKmh       Float?             @map("delta_kmh")
  durationMs     Int?               @map("duration_ms")
  driverName     String?            @map("driver_name")
  tripId         String?            @map("trip_id")
  // V3: contextual enrichment (e.g. coldEngine badge from HF context on LTE_R1)
  metadataJson   Json?              @map("metadata_json")
  recordedAt     DateTime           @map("recorded_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  vehicle Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([recordedAt])
  @@index([eventType])
  @@index([tripId])
  @@index([source])
  // Most driving-event reads are per-vehicle over a time range (analytics,
  // enrichment recovery) or per-trip (rental analysis). Composite indexes.
  @@index([vehicleId, recordedAt])
  @@index([tripId, eventType])
  @@map("driving_events")
}

// ------------------------------------------------
// BATTERY HEALTH SNAPSHOTS
// ------------------------------------------------

model BatteryHealthSnapshot {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  voltageV        Float    @map("voltage_v")
  sohPercent      Float?   @map("soh_percent")
  restingVoltage  Float?   @map("resting_voltage")
  crankingVoltage Float?   @map("cranking_voltage")
  chargingVoltage Float?   @map("charging_voltage")
  engineRunning   Boolean  @default(false) @map("engine_running")
  temperatureC    Float?   @map("temperature_c")
  estimatedCca    Int?     @map("estimated_cca")
  rawPayload      Json?    @map("raw_payload")
  recordedAt      DateTime @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([recordedAt])
  @@map("battery_health_snapshots")
}

enum SohPublicationState {
  INITIAL_CALIBRATION
  STABILIZING
  STABLE
}

enum BatteryEvidenceScope {
  LV
  HV
}

enum BatteryEvidenceSourceType {
  PROVIDER_REPORTED
  TELEMETRY_DERIVED
  MODEL_DERIVED
  MANUAL_REPORT
  DOCUMENT_CONFIRMED
  WORKSHOP_MEASUREMENT
  HM_SUPPLEMENTARY
}

enum BatteryEvidenceValueType {
  SOH_PERCENT
  SOC_PERCENT
  RANGE_KM
  VOLTAGE_V
  RESTING_VOLTAGE_V
  CRANKING_VOLTAGE_V
  CHARGING_VOLTAGE_V
  BATTERY_TEMPERATURE_C
  CHARGING_POWER_KW
  ADDED_ENERGY_KWH
  CURRENT_ENERGY_KWH
  CURRENT_VOLTAGE_V
  GROSS_CAPACITY_KWH
}

/// Per-vehicle battery feature store for V2 health scoring.
/// One row per vehicle, updated in-place (upsert pattern).
model BatteryFeatures {
  id        String @id @default(uuid())
  vehicleId String @unique @map("vehicle_id")

  // Rest-window tracking
  restWindowStartedAt DateTime? @map("rest_window_started_at")
  rest60mCapturedAt   DateTime? @map("rest_60m_captured_at")
  rest6hCapturedAt    DateTime? @map("rest_6h_captured_at")
  vOff60m             Float?    @map("v_off_60m")
  vOff6h              Float?    @map("v_off_6h")
  deltaVRest          Float?    @map("delta_v_rest")

  // Crank features (populated on trip start)
  crankTripId  String?   @map("crank_trip_id")
  crankAt      DateTime? @map("crank_at")
  vPreCrank    Float?    @map("v_pre_crank")
  vMinCrank    Float?    @map("v_min_crank")
  crankDrop    Float?    @map("crank_drop")
  vRecovery5s  Float?    @map("v_recovery_5s")
  vRecovery30s Float?    @map("v_recovery_30s")

  // Computed health (refreshed after each feature update)
  estimatedSocPct Float?    @map("estimated_soc_pct")
  estimatedSohPct Float?    @map("estimated_soh_pct")
  confidence      String?   @map("confidence")
  badge           String?   @map("badge")
  scoredAt        DateTime? @map("scored_at")

  // Three-layer SOH publication model
  rawSohPct                Float?              @map("raw_soh_pct")
  stabilizedSohPct         Float?              @map("stabilized_soh_pct")
  publishedSohPct          Float?              @map("published_soh_pct")
  publicationState         SohPublicationState @default(INITIAL_CALIBRATION) @map("publication_state")
  maturityConfidence       String?             @map("maturity_confidence")
  qualifiedEventCount      Int                 @default(0) @map("qualified_event_count")
  restObservationCount     Int                 @default(0) @map("rest_observation_count")
  crankObservationCount    Int                 @default(0) @map("crank_observation_count")
  firstUsableMeasurementAt DateTime?           @map("first_usable_measurement_at")
  lastPublishedAt          DateTime?           @map("last_published_at")
  outlierSuppressedCount   Int                 @default(0) @map("outlier_suppressed_count")
  ewmaAlpha                Float               @default(0.25) @map("ewma_alpha")

  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("battery_features")
}

// ------------------------------------------------
// HV BATTERY HEALTH SNAPSHOTS (EV traction battery)
// ------------------------------------------------

model HvBatteryHealthSnapshot {
  id                   String   @id @default(uuid())
  vehicleId            String   @map("vehicle_id")
  socPercent           Float    @map("soc_percent")
  energyUsedKwh        Float?   @map("energy_used_kwh")
  estimatedCapacityKwh Float?   @map("estimated_capacity_kwh")
  sohPercent           Float?   @map("soh_percent")
  rangeKm              Float?   @map("range_km")
  chargingPowerKw      Float?   @map("charging_power_kw")
  isCharging           Boolean  @default(false) @map("is_charging")
  odometerKm           Float?   @map("odometer_km")
  temperatureC         Float?   @map("temperature_c")
  recordedAt           DateTime @map("recorded_at")
  createdAt            DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([recordedAt])
  @@map("hv_battery_health_snapshots")
}

/// Per-vehicle HV (traction) battery publication state.
/// One row per vehicle, updated in-place.
model HvBatteryHealthCurrent {
  id                       String              @id @default(uuid())
  vehicleId                String              @unique @map("vehicle_id")
  rawSohPct                Float?              @map("raw_soh_pct")
  stabilizedSohPct         Float?              @map("stabilized_soh_pct")
  publishedSohPct          Float?              @map("published_soh_pct")
  publicationState         SohPublicationState @default(INITIAL_CALIBRATION) @map("publication_state")
  publicationMethod        String?             @map("publication_method")
  maturityConfidence       String?             @map("maturity_confidence")
  signalConfidence         String?             @map("signal_confidence")
  validEstimateCount       Int                 @default(0) @map("valid_estimate_count")
  firstUsableMeasurementAt DateTime?           @map("first_usable_measurement_at")
  lastPublishedAt          DateTime?           @map("last_published_at")
  outlierSuppressedCount   Int                 @default(0) @map("outlier_suppressed_count")
  ewmaAlpha                Float               @default(0.20) @map("ewma_alpha")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("hv_battery_health_current")
}

model BatteryEvidence {
  id                   String                    @id @default(uuid())
  vehicleId            String                    @map("vehicle_id")
  scope                BatteryEvidenceScope
  sourceType           BatteryEvidenceSourceType @map("source_type")
  valueType            BatteryEvidenceValueType  @map("value_type")
  numericValue         Float                     @map("numeric_value")
  unit                 String?
  observedAt           DateTime                  @map("observed_at")
  provider             String?
  confidence           String?
  quality              String?
  documentExtractionId String?                   @map("document_extraction_id")
  serviceEventId       String?                   @map("service_event_id")
  metadataJson         Json?                     @map("metadata_json")
  createdAt            DateTime                  @default(now()) @map("created_at")

  vehicle            Vehicle                    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentExtraction VehicleDocumentExtraction? @relation(fields: [documentExtractionId], references: [id], onDelete: SetNull)
  serviceEvent       VehicleServiceEvent?       @relation(fields: [serviceEventId], references: [id], onDelete: SetNull)

  @@unique([vehicleId, scope, valueType, sourceType, observedAt], name: "battery_evidence_dedup_key", map: "battery_evidence_dedup_key")
  @@index([vehicleId, scope, valueType, observedAt])
  @@index([sourceType, observedAt])
  @@index([documentExtractionId])
  @@index([serviceEventId])
  @@map("battery_evidence")
}

