// ------------------------------------------------
// VEHICLE PROVIDER CONSENT / ACCESS GRANTS
// ------------------------------------------------
// Canonical ledger of every provider access grant for a vehicle.
// Records who granted access, via which mechanism, and current status.
// One row per grant event — revocation creates a new row or updates status.

enum VehicleProviderConsentStatus {
  ACTIVE
  REVOKED
  EXPIRED
  REJECTED
  PENDING
}

enum VehicleProviderConsentGrantType {
  DIMO_OAUTH // DIMO vehicle linked via OAuth token flow
  DIMO_DIRECT // DIMO vehicle linked directly by admin
  HM_FLEET_CLEARANCE // High Mobility fleet clearance (webhook-approved)
  HM_MANUAL // High Mobility manually approved by admin
  MANUAL // manually recorded by platform admin
}

model VehicleProviderConsent {
  id                       String                          @id @default(uuid())
  vehicleId                String                          @map("vehicle_id")
  organizationId           String                          @map("organization_id")
  provider                 String                          @map("provider") // DIMO | HIGH_MOBILITY | ...
  grantType                VehicleProviderConsentGrantType @map("grant_type")
  status                   VehicleProviderConsentStatus    @default(ACTIVE) @map("status")
  scopes                   String[]                        @map("scopes") // list of accessible signals/permissions
  grantedByUserId          String?                         @map("granted_by_user_id") // internal user who triggered grant
  grantedByExternalSubject String?                         @map("granted_by_external_subject") // e.g. vehicle owner DID / external identity
  grantedAt                DateTime                        @default(now()) @map("granted_at")
  expiresAt                DateTime?                       @map("expires_at")
  revokedAt                DateTime?                       @map("revoked_at")
  revokedByUserId          String?                         @map("revoked_by_user_id")
  proofReference           String?                         @map("proof_reference") // external tx/event ID
  proofHash                String?                         @map("proof_hash") // hash of signed approval payload
  providerVehicleRef       String?                         @map("provider_vehicle_ref") // external vehicle ID at provider
  metadataJson             Json?                           @map("metadata_json")
  createdAt                DateTime                        @default(now()) @map("created_at")
  updatedAt                DateTime                        @updatedAt @map("updated_at")

  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([organizationId])
  @@index([provider, status])
  @@index([grantedAt])
  @@map("vehicle_provider_consents")
}

