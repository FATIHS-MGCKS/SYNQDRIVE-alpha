// ------------------------------------------------
// USERS
// ------------------------------------------------

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String?
  firstName          String?          @map("first_name")
  lastName           String?          @map("last_name")
  passwordHash       String?          @map("password_hash")
  avatarUrl          String?          @map("avatar_url")
  authProviderId     String?          @unique @map("auth_provider_id")
  platformRole       UserPlatformRole @default(USER) @map("platform_role")
  status             UserStatus       @default(ACTIVE)
  phone              String?
  mobile             String?
  address            String?
  language           String?          @default("de")
  timezone           String?          @default("Europe/Berlin")
  dateFormat         String?          @default("DD.MM.YYYY") @map("date_format")
  mustChangePassword Boolean          @default(false) @map("must_change_password")
  lastLoginAt        DateTime?        @map("last_login_at")
  lastLoginIp        String?          @map("last_login_ip")
  lastLoginDevice    String?          @map("last_login_device")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  memberships                         OrganizationMembership[]
  activityLogs                        ActivityLog[]
  refreshTokens                       RefreshToken[]
  accountPreferences                  UserAccountPreference[]
  notificationPreferences             UserNotificationPreference[]
  invitesSent                         OrganizationUserInvite[]                @relation("InvitesSent")
  invitesAccepted                     OrganizationUserInvite[]                @relation("InvitesAccepted")
  organizationRolesCreated            OrganizationRole[]                      @relation("RolesCreated")
  billingPriceVersionsCreated         BillingPriceVersion[]                   @relation("BillingPriceVersionsCreated")
  billingPriceVersionsPublished       BillingPriceVersion[]                   @relation("BillingPriceVersionsPublished")
  billingSubscriptionsCreated         BillingSubscription[]                   @relation("BillingSubscriptionsCreated")
  billingSubscriptionsUpdated         BillingSubscription[]                   @relation("BillingSubscriptionsUpdated")
  billingDiscountsCreated             BillingDiscount[]                       @relation("BillingDiscountsCreated")
  billingQuantityEventsActed          BillingQuantityEvent[]                  @relation("BillingQuantityEventsActed")
  billingPaymentsRecorded             BillingPayment[]                        @relation("BillingPaymentsRecorded")
  billingReconciliationDriftsResolved BillingReconciliationDrift[]            @relation("BillingReconciliationDriftsResolved")
  billingUsageSnapshotsCreated        BillingUsageSnapshot[]                  @relation("BillingUsageSnapshotsCreated")
  billingVehicleAssignmentsApproved   BillingBillableVehicleAssignment[]      @relation("BillingVehicleAssignmentsApproved")
  outboundEmailsSent                  OutboundEmail[]                         @relation("OutboundEmailSentBy")
  pricingQuotesCreated                PricingQuote[]                          @relation("PricingQuotesCreated")
  notificationReceipts                NotificationReceipt[]
  taskAutomationRuleOverridesCreated  OrgTaskAutomationRuleOverride[]         @relation("TaskAutomationRuleOverrideCreated")
  taskAutomationRuleOverridesUpdated  OrgTaskAutomationRuleOverride[]         @relation("TaskAutomationRuleOverrideUpdated")
  taskAutomationRuleOverrideRevisions OrgTaskAutomationRuleOverrideRevision[] @relation("TaskAutomationRuleOverrideRevisionChanged")

  @@map("users")
}

// ------------------------------------------------
// REFRESH TOKENS
// ------------------------------------------------

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash") // bcrypt hash of the actual token
  family     String    @map("family") // rotation family — revoke all on reuse detection
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by") // id of the next token in chain
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ------------------------------------------------
// ACCOUNT SELF-SERVICE (per-user, per-org preferences)
// ------------------------------------------------

model UserAccountPreference {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  organizationId     String   @map("organization_id")
  defaultStationId   String?  @map("default_station_id")
  defaultLandingPage String?  @map("default_landing_page")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultStation Station?     @relation(fields: [defaultStationId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("user_account_preferences")
}

model UserNotificationPreference {
  id             String               @id @default(uuid())
  userId         String               @map("user_id")
  organizationId String               @map("organization_id")
  category       NotificationCategory
  inApp          Boolean              @default(true) @map("in_app")
  email          Boolean              @default(true)
  push           Boolean              @default(false)
  sms            Boolean              @default(false)
  criticalOnly   Boolean              @default(false) @map("critical_only")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, category])
  @@index([userId, organizationId])
  @@map("user_notification_preferences")
}

// ------------------------------------------------
// ORGANIZATION MEMBERSHIPS
// ------------------------------------------------

model OrganizationMembership {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  organizationId     String           @map("organization_id")
