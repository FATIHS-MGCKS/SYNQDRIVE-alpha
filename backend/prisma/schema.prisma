model OutboundEmail {
  id                          String                  @id @default(uuid())
  organizationId              String                  @map("organization_id")
  bookingId                   String?                 @map("booking_id")
  customerId                  String?                 @map("customer_id")
  invoiceId                   String?                 @map("invoice_id")
  bookingPaymentRequestId     String?                 @map("booking_payment_request_id")
  billingInvoiceId            String?                 @map("billing_invoice_id")
  billingSubscriptionId       String?                 @map("billing_subscription_id")
  billingOutboxDeliveryId     String?                 @map("billing_outbox_delivery_id")
  billingOutboxEventId        String?                 @map("billing_outbox_event_id")
  billingOutboxIdempotencyKey String?                 @unique @map("billing_outbox_idempotency_key")
  sourceType                  OutboundEmailSourceType @map("source_type")
  status                      OutboundEmailStatus     @default(QUEUED)
  fromEmail                   String                  @map("from_email")
  fromName                    String?                 @map("from_name")
  replyToEmail                String?                 @map("reply_to_email")
  toEmail                     String                  @map("to_email")
  ccEmails                    String[]                @default([]) @map("cc_emails")
  bccEmails                   String[]                @default([]) @map("bcc_emails")
  subject                     String
  bodyText                    String?                 @map("body_text")
  bodyHtml                    String?                 @map("body_html")
  provider                    String?
  providerMessageId           String?                 @map("provider_message_id")
  errorCode                   String?                 @map("error_code")
  errorMessage                String?                 @map("error_message")
  sentByUserId                String?                 @map("sent_by_user_id")
  sentAt                      DateTime?               @map("sent_at")
  createdAt                   DateTime                @default(now()) @map("created_at")
  updatedAt                   DateTime                @updatedAt @map("updated_at")

  organization             Organization                      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  booking                  Booking?                          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer                 Customer?                         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice                  OrgInvoice?                       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  bookingPaymentRequest    BookingPaymentRequest?            @relation(fields: [bookingPaymentRequestId], references: [id], onDelete: SetNull)
  billingInvoice           BillingInvoice?                   @relation(fields: [billingInvoiceId], references: [id], onDelete: SetNull)
  billingSubscription      BillingSubscription?              @relation(fields: [billingSubscriptionId], references: [id], onDelete: SetNull)
  billingOutboxDelivery    BillingDomainEventOutboxDelivery? @relation(fields: [billingOutboxDeliveryId], references: [id], onDelete: SetNull)
  sentByUser               User?                             @relation("OutboundEmailSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  attachments              OutboundEmailAttachment[]
  events                   OutboundEmailEvent[]
  paymentEmailOutbox       PaymentEmailOutbox[]
  billingEmailSuppressions BillingEmailSuppression[]

  @@index([organizationId])
  @@index([organizationId, bookingId])
  @@index([organizationId, customerId])
  @@index([organizationId, invoiceId])
  @@index([billingInvoiceId])
  @@index([billingSubscriptionId])
  @@index([billingOutboxDeliveryId])
  @@index([bookingPaymentRequestId])
  @@index([status])
  @@index([createdAt])
  @@map("outbound_emails")
}

model OutboundEmailAttachment {
