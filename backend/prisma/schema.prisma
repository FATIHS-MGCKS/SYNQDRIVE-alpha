  country        String?
  latitude       Float?
  longitude      Float?
  website        String?
  phone          String?
  email          String?
  notes          String?
  serviceAreas   String[]         @default([]) @map("service_areas")
  contactName    String?          @map("contact_name")
  contactRole    String?          @map("contact_role")
  contactPhone   String?          @map("contact_phone")
  contactEmail   String?          @map("contact_email")
