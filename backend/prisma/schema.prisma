  dimoDeviceConnectionEvents        DimoDeviceConnectionEvent[]
  tripDetectionState                VehicleTripDetectionState?
  tripTrackingRuns                  VehicleTripTrackingRun[]
  tripBehaviorEvents                TripBehaviorEvent[]
  misuseCases                       MisuseCase[]
  tripRepairs                       TripRepair[]
  energyEvents                      VehicleEnergyEvent[]
  logbookConfig                     VehicleLogbookConfig?
  documentExtractions               VehicleDocumentExtraction[]
