// ── Trip Repair / Reconciliation Audit Trail ──────────────────────────────────
//
// Records every proposed or applied repair action taken by the reconciliation
// and repair layer. Provides full auditable history of what changed and why.
// The repair layer may never directly create trips — it always goes through
// TripDecisionEngine, which stamps tripSource: REPAIRED on the resulting trip.

/// Audit record for one repair action proposed or applied by the reconciliation layer.
model TripRepair {
  id        String  @id @default(uuid())
  vehicleId String  @map("vehicle_id")
  // Linked to an existing trip when repairing an end-time or merge.
  // Null when creating a brand-new trip from a gap.
  tripId    String? @map("trip_id")

  // MISSING_TRIP | MISSING_END | SPLIT_MERGE | DUPLICATE | STALE_ONGOING
  repairType String   @map("repair_type")
  // PROPOSED | APPLIED | REJECTED | EXPIRED
  status     String   @default("PROPOSED")
  reason     String
  // LOW | MEDIUM | HIGH
  confidence String
  windowFrom DateTime @map("window_from")
  windowTo   DateTime @map("window_to")

  // Full detector evidence payload (findings array from all detectors that ran)
  detectorEvidence Json?     @map("detector_evidence")
  appliedAt        DateTime? @map("applied_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  vehicle Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([tripId])
  @@index([status])
  @@index([repairType])
  @@index([createdAt])
  @@map("trip_repairs")
}

// ── Driving Impact Engine V1 ──────────────────────────────────────────────────
//
// These two models form the shared normalization layer between
// HF post-trip enrichment and the Tire Health / Brake Health modules.
// Neither Tire nor Brake stores driving aggressiveness on their own tables;
// they read from these shared structures instead.

/// One row per finalized trip. Computed after HF enrichment, never overwritten.
model TripDrivingImpact {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  vehicleId      String    @map("vehicle_id")
  tripId         String    @unique @map("trip_id")
  tripStartedAt  DateTime  @map("trip_started_at")
  tripEndedAt    DateTime? @map("trip_ended_at")
  distanceKm     Float     @map("distance_km")

  // Usage split (from VehicleTrip city/highway/country percent fields)
  citySharePct        Float? @map("city_share_pct")
  highwaySharePct     Float? @map("highway_share_pct")
  countryRoadSharePct Float? @map("country_road_share_pct")

  // Normalized per-100 km event rates
  hardAccelPer100Km    Float? @map("hard_accel_per_100km")
  extremeAccelPer100Km Float? @map("extreme_accel_per_100km")
  hardBrakePer100Km    Float? @map("hard_brake_per_100km")
  extremeBrakePer100Km Float? @map("extreme_brake_per_100km")
  fullBrakingPer100Km  Float? @map("full_braking_per_100km")
  kickdownPer100Km     Float? @map("kickdown_per_100km")
  launchLikePer100Km   Float? @map("launch_like_per_100km")

  // Braking behavior metrics (derived from TripBehaviorEvent rows)
  brakesPer100Km       Float? @map("brakes_per_100km")
  stopDensity          Float? @map("stop_density")
  highSpeedBrakeShare  Float? @map("high_speed_brake_share")
  meanBrakeEnergyPerKm Float? @map("mean_brake_energy_per_km")
  p95NegativeDecel     Float? @map("p95_negative_decel")

  // Normalized stress scores 0–100
  longitudinalStressScore Float? @map("longitudinal_stress_score")
  brakingStressScore      Float? @map("braking_stress_score")
  stopGoStressScore       Float? @map("stop_go_stress_score")
  highSpeedStressScore    Float? @map("high_speed_stress_score")
  thermalBrakeStressScore Float? @map("thermal_brake_stress_score")
  drivingStyleScore       Float? @map("driving_style_score")
  safetyScore             Float? @map("safety_score")
  speedingExposurePct     Float? @map("speeding_exposure_pct")
  speedingSeverityScore   Float? @map("speeding_severity_score")
  speedingSectionCount    Int?   @map("speeding_section_count")

  // Traceability
  modelVersion      String @map("model_version")
  sourceSummaryJson Json?  @map("source_summary_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, tripStartedAt])
  @@index([organizationId, vehicleId])
  @@map("trip_driving_impact")
}

/// Rolling 30-day aggregate per vehicle. One row, upserted after each trip impact row.
/// Read by Tire Health and Brake Health to get current driving behavior context.
model VehicleDrivingImpactCurrent {
  vehicleId      String  @id @map("vehicle_id")
  organizationId String? @map("organization_id")

  windowDays       Int       @default(30) @map("window_days")
  windowStartedAt  DateTime? @map("window_started_at")
  windowEndedAt    DateTime? @map("window_ended_at")
  distanceKmWindow Float?    @map("distance_km_window")

  // Rolling usage split
  citySharePct        Float? @map("city_share_pct")
  highwaySharePct     Float? @map("highway_share_pct")
  countryRoadSharePct Float? @map("country_road_share_pct")

  // Rolling per-100 km rates (distance-weighted)
  hardAccelPer100Km    Float? @map("hard_accel_per_100km")
  extremeAccelPer100Km Float? @map("extreme_accel_per_100km")
  hardBrakePer100Km    Float? @map("hard_brake_per_100km")
  extremeBrakePer100Km Float? @map("extreme_brake_per_100km")
  fullBrakingPer100Km  Float? @map("full_braking_per_100km")
  kickdownPer100Km     Float? @map("kickdown_per_100km")
  launchLikePer100Km   Float? @map("launch_like_per_100km")

  // Rolling behavior metrics
  brakesPer100Km       Float? @map("brakes_per_100km")
  stopDensity          Float? @map("stop_density")
  highSpeedBrakeShare  Float? @map("high_speed_brake_share")
  meanBrakeEnergyPerKm Float? @map("mean_brake_energy_per_km")
  p95NegativeDecel     Float? @map("p95_negative_decel")

  // Rolling stress scores (distance-weighted)
  longitudinalStressScore Float? @map("longitudinal_stress_score")
  brakingStressScore      Float? @map("braking_stress_score")
  stopGoStressScore       Float? @map("stop_go_stress_score")
  highSpeedStressScore    Float? @map("high_speed_stress_score")
  thermalBrakeStressScore Float? @map("thermal_brake_stress_score")
  drivingStyleScore       Float? @map("driving_style_score")

  modelVersion String   @map("model_version")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId])
  @@map("vehicle_driving_impact_current")
}

