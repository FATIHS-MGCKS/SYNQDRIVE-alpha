  licensePlate                      String?           @map("license_plate")
  mileageKm                         Int?              @map("mileage_km")
  dailyRateEur                      Float?            @map("daily_rate_eur")
  weeklyRateEur                     Float?            @map("weekly_rate_eur")
  monthlyRateEur                    Float?            @map("monthly_rate_eur")
