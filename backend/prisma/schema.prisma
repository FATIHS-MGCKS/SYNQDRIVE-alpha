model VehicleTripTrackingRun {
  id             String  @id @default(uuid())
  vehicleId      String  @map("vehicle_id")
  organizationId String? @map("organization_id")
  tripId         String? @map("trip_id")

  stateAtRun TripDetectionState  @map("state_at_run")
  runType    TripTrackingRunType @map("run_type")

  requestedFrom      DateTime? @map("requested_from")
  requestedTo        DateTime? @map("requested_to")
  corePointsCount    Int?      @map("core_points_count")
  routePointsCount   Int?      @map("route_points_count")
  drivingPointsCount Int?      @map("driving_points_count")

  resultState   TripDetectionState? @map("result_state")
