model OrganizationChatAgent {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  agentName      String   @map("agent_name")
  dimoAgentId    String   @map("dimo_agent_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_chat_agents")
}

model ChatMessage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  role           String
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("chat_messages")
}

// ------------------------------------------------
// DATA AUTHORIZATION
// ------------------------------------------------

enum DataAuthorizationStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

enum DataAuthorizationSourceType {
  DIMO
  SYNQDRIVE_SYSTEM
  CUSTOMER_CONSENT
  PARTNER_ACCESS
  MANUAL_UPLOAD
  API_INTEGRATION
}

enum DataAuthorizationProcessorType {
  SYNQDRIVE
  EXTERNAL_PARTNER
  INTERNAL_SYSTEM
}

enum DataAuthorizationRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DataAuthorizationScope {
  ORGANIZATION
  CONNECTED_VEHICLES
  VEHICLE
  CUSTOMER
  BOOKING
}

enum DataAuthorizationAccessPattern {
  ONE_TIME
  ONGOING
  RECURRING
  EVENT_DRIVEN
}

model OrgDataAuthorization {
  id                String                          @id @default(uuid())
  organizationId    String                          @map("organization_id")
  title             String?
  description       String?
  sourceType        DataAuthorizationSourceType?    @map("source_type")
  processorType     DataAuthorizationProcessorType? @map("processor_type")
  processorName     String?                         @map("processor_name")
  purposes          Json?
  riskLevel         DataAuthorizationRiskLevel      @default(MEDIUM) @map("risk_level")
  customerIds       Json?                           @map("customer_ids")
  bookingIds        Json?                           @map("booking_ids")
  systemKey         String?                         @map("system_key")
  isSystemGenerated Boolean                         @default(false) @map("is_system_generated")
  lastAccessAt      DateTime?                       @map("last_access_at")
  accessCount       Int                             @default(0) @map("access_count")
  revokeReason      String?                         @map("revoke_reason")
  requestingEntity  String                          @map("requesting_entity")
  moduleOrigin      String                          @map("module_origin")
  purpose           String
  scope             DataAuthorizationScope          @default(ORGANIZATION)
  dataCategories    Json                            @map("data_categories")
  destination       String
  vehicleIds        Json?                           @map("vehicle_ids")
  accessPattern     DataAuthorizationAccessPattern  @default(ONGOING) @map("access_pattern")
  status            DataAuthorizationStatus         @default(PENDING)
  grantedById       String?                         @map("granted_by_id")
  grantedByName     String?                         @map("granted_by_name")
  grantedAt         DateTime?                       @map("granted_at")
  revokedById       String?                         @map("revoked_by_id")
  revokedByName     String?                         @map("revoked_by_name")
  revokedAt         DateTime?                       @map("revoked_at")
  expiresAt         DateTime?                       @map("expires_at")
  notes             String?
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")

  @@unique([organizationId, systemKey])
  @@index([organizationId])
  @@index([status])
  @@index([moduleOrigin])
  @@index([requestingEntity])
  @@index([sourceType])
  @@index([riskLevel])
  @@map("org_data_authorizations")
}

// ─── Workflow Automation ──────────────────────────

enum WorkflowStatus {
  ACTIVE
  DRAFT
  DISABLED
  INVALID
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
  WAITING_APPROVAL
}

enum WorkflowActionRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
  WAITING_APPROVAL
}

enum WorkflowApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model OrgWorkflow {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  name            String
  description     String?
  category        String
  trigger         Json
  conditions      Json           @default("[]")
  actions         Json
  scope           Json           @default("{\"type\":\"organization\"}")
  status          WorkflowStatus @default(DRAFT)
  enabled         Boolean        @default(false)
  version         Int            @default(1)
  createdById     String?        @map("created_by_id")
  createdByName   String?        @map("created_by_name")
  updatedById     String?        @map("updated_by_id")
  updatedByName   String?        @map("updated_by_name")
  lastTriggeredAt DateTime?      @map("last_triggered_at")
  triggerCount    Int            @default(0) @map("trigger_count")
  isTemplate      Boolean        @default(false) @map("is_template")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  runs OrgWorkflowRun[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, enabled])
  @@index([status])
  @@index([category])
  @@map("org_workflows")
}

model OrgWorkflowRun {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  workflowId      String            @map("workflow_id")
  workflowVersion Int               @map("workflow_version")
  eventType       String            @map("event_type")
  entityType      String?           @map("entity_type")
  entityId        String?           @map("entity_id")
  status          WorkflowRunStatus @default(PENDING)
  inputPayload    Json              @map("input_payload")
  conditionResult Json?             @map("condition_result")
  errorMessage    String?           @map("error_message")
  idempotencyKey  String            @map("idempotency_key")
  startedAt       DateTime          @default(now()) @map("started_at")
  finishedAt      DateTime?         @map("finished_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  workflow   OrgWorkflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actionRuns OrgWorkflowActionRun[]
  approvals  OrgWorkflowApproval[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([workflowId])
  @@index([organizationId, workflowId])
  @@index([status])
  @@index([createdAt])
  @@map("org_workflow_runs")
}

model OrgWorkflowActionRun {
  id               String                  @id @default(uuid())
  organizationId   String                  @map("organization_id")
  workflowRunId    String                  @map("workflow_run_id")
  workflowId       String                  @map("workflow_id")
  actionType       String                  @map("action_type")
  actionIndex      Int                     @map("action_index")
  status           WorkflowActionRunStatus @default(PENDING)
  input            Json?
  output           Json?
  errorMessage     String?                 @map("error_message")
  requiresApproval Boolean                 @default(false) @map("requires_approval")
  approvedByUserId String?                 @map("approved_by_user_id")
  approvedAt       DateTime?               @map("approved_at")
  startedAt        DateTime?               @map("started_at")
  finishedAt       DateTime?               @map("finished_at")
  createdAt        DateTime                @default(now()) @map("created_at")

  workflowRun OrgWorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

