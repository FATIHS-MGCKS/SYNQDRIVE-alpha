// ============================================================
// HIGH MOBILITY — Phase 1 Integration
// ============================================================

// Identifies which HM application container a record belongs to.
// HM_HEALTH_APP  → add-on health signals for DIMO-backed vehicles (HM_HEALTH_APP_* credentials)
// HM_TELEMETRY_APP → independent full-telemetry pipeline (HM_TELEMETRY_APP_* credentials)
enum HmAppContainerType {
  HM_HEALTH_APP
  HM_TELEMETRY_APP
}

enum HmPackageType {
  HEALTH
  FULL_TELEMETRY
}

enum HmSourceMode {
  DIMO_PLUS_HM
  HM_ONLY
}

enum HmEligibilityStatus {
  UNKNOWN
  PENDING
  ELIGIBLE
  INELIGIBLE
  ERROR
}

enum HmDeliveryMode {
  PULL
  PUSH
  BOTH
}

enum HmClearanceStatus {
  DRAFT
  CLEARANCE_PENDING
  APPROVED
  REJECTED
  ERROR
  REVOKING
  REVOKED
  CANCELED
}

enum HmSyncType {
  MANUAL
  SCHEDULED
  POST_APPROVAL_INITIAL
}

enum HmSyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

// Primary managed vehicle record for High Mobility
model HighMobilityVehicle {
  id                 String  @id @default(uuid())
  // null = Master Admin global scope (not tied to a specific org)
  organizationId     String? @map("organization_id")
  // null until linked to a SynqDrive registered vehicle
  synqdriveVehicleId String? @map("synqdrive_vehicle_id")

  vin   String
  brand String

  // Which HM app-container manages this vehicle record.
  // Null for legacy rows created before dual-app split; treat as HM_HEALTH_APP when null.
  appContainerType HmAppContainerType? @map("app_container_type")

  packageType HmPackageType @map("package_type")
  sourceMode  HmSourceMode  @default(DIMO_PLUS_HM) @map("source_mode")

  eligibilityStatus       HmEligibilityStatus @default(UNKNOWN) @map("eligibility_status")
  eligibilityDeliveryMode HmDeliveryMode?     @map("eligibility_delivery_mode")
  eligibilityCheckedAt    DateTime?           @map("eligibility_checked_at")

  clearanceStatus        HmClearanceStatus @default(DRAFT) @map("clearance_status")
  clearanceRequestedAt   DateTime?         @map("clearance_requested_at")
  clearanceApprovedAt    DateTime?         @map("clearance_approved_at")
  clearanceLastCheckedAt DateTime?         @map("clearance_last_checked_at")

  // Identifier returned by the High Mobility provider (e.g. internal HM fleet vehicle ID)
  hmVehicleReference  String? @map("hm_vehicle_reference")
  // Raw provider payload (eligibility + clearance responses)
  providerPayloadJson Json?   @map("provider_payload_json")

  isLinked Boolean   @default(false) @map("is_linked")
  linkedAt DateTime? @map("linked_at")
  isActive Boolean   @default(true) @map("is_active")

  // Phase 2 — registration and streaming state
  registrationState      HmRegistrationState @default(NOT_REGISTERED) @map("registration_state")
  registeredAt           DateTime?           @map("registered_at")
  streamingState         HmStreamingState    @default(NOT_CONFIGURED) @map("streaming_state")
  // Provider-returned mode identifier (e.g. "fleet", "personal", etc.)
  providerMode           String?             @map("provider_mode")
  // Telemetry/streaming readiness metadata (MQTT topic, subscription state, etc.)
  telemetryReadinessJson Json?               @map("telemetry_readiness_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  statusHistory     HighMobilityStatusHistory[]
  syncLogs          HighMobilityHealthSyncLog[]
  dataSourceLinks   VehicleDataSourceLink[]
  streamSyncLogs    HighMobilityStreamSyncLog[]
  signalGroupStates HmSignalGroupState[]

  // Unique: only one active clearance record per VIN + package + source mode
  @@unique([vin, packageType, sourceMode, isActive], name: "uq_hm_vehicle_active")
  @@index([vin])
  @@index([clearanceStatus])
  @@index([packageType])
  @@index([sourceMode])
  @@index([appContainerType])
  @@index([vin, appContainerType])
  @@index([organizationId])
  @@index([synqdriveVehicleId])
  @@map("high_mobility_vehicles")
}

// Status change history for audit trail
model HighMobilityStatusHistory {
  id                    String   @id @default(uuid())
  highMobilityVehicleId String   @map("high_mobility_vehicle_id")
  eventType             String   @map("event_type")
  oldStatus             String?  @map("old_status")
  newStatus             String?  @map("new_status")
  payloadJson           Json?    @map("payload_json")
  createdAt             DateTime @default(now()) @map("created_at")

  vehicle HighMobilityVehicle @relation(fields: [highMobilityVehicleId], references: [id], onDelete: Cascade)

  @@index([highMobilityVehicleId])
  @@index([createdAt])
  @@map("high_mobility_status_history")
}

// Per-sync log for HEALTH data fetches
model HighMobilityHealthSyncLog {
  id                    String       @id @default(uuid())
  highMobilityVehicleId String       @map("high_mobility_vehicle_id")
  syncType              HmSyncType   @map("sync_type")
  syncStatus            HmSyncStatus @map("sync_status")
  requestedAt           DateTime     @map("requested_at")
  completedAt           DateTime?    @map("completed_at")
  errorMessage          String?      @map("error_message")
  payloadJson           Json?        @map("payload_json")

  vehicle HighMobilityVehicle @relation(fields: [highMobilityVehicleId], references: [id], onDelete: Cascade)

  @@index([highMobilityVehicleId])
  @@index([requestedAt])
  @@map("high_mobility_health_sync_logs")
}

// ── Phase 2 enums ──────────────────────────────────────────────────────────

enum HmRegistrationState {
  NOT_REGISTERED
  REGISTRATION_PENDING
  REGISTERED
  REGISTRATION_FAILED
}

enum HmStreamingState {
  NOT_CONFIGURED
  CONFIGURED
  CONNECTING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum HmIngestStatus {
  RECEIVED
  PARSED
  STORED
  FAILED
  DEDUPLICATED
}

enum HmMqttConnectionState {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
  DISABLED
}

// Extensible vehicle data source link table
// Supports HIGH_MOBILITY now, extendable for future sources
// Canonical provider binding structure for all external data sources.
// Covers both DIMO and High Mobility. Extended per provider in sourceSubtype.
model VehicleDataSourceLink {
  id                String    @id @default(uuid())
  vehicleId         String    @map("vehicle_id")
  // Provider canonical name: DIMO | HIGH_MOBILITY | MANUAL | ...
  provider          String    @default("UNKNOWN") @map("provider")
  sourceType        String    @map("source_type") // e.g. HIGH_MOBILITY, DIMO
  sourceSubtype     String?   @map("source_subtype") // e.g. HM_HEALTH_APP, HM_TELEMETRY_APP
  sourceReferenceId String    @map("source_reference_id")
  // FK to the consent record that authorized this binding
  consentId         String?   @map("consent_id")
  isActive          Boolean   @default(true) @map("is_active")
  activatedAt       DateTime  @default(now()) @map("activated_at")
  deactivatedAt     DateTime? @map("deactivated_at")
  // Provenance: who set up this binding and when it was verified
  linkedByUserId    String?   @map("linked_by_user_id")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  metadata          Json?     @map("metadata")

  // Direct FK to Vehicle enables DB-level ownership enforcement
  vehicle   Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  hmVehicle HighMobilityVehicle? @relation(fields: [sourceReferenceId], references: [id])

  // Only one active link per vehicle + source type + subtype
  @@unique([vehicleId, sourceType, sourceSubtype, isActive], name: "uq_data_source_link_active")
  @@index([vehicleId])
  @@index([sourceType])
  @@index([provider])
  @@index([sourceReferenceId])
  @@index([consentId])
  @@map("vehicle_data_source_links")
}

// Phase 2 — raw MQTT stream message log
model HighMobilityStreamSyncLog {
  id                    String              @id @default(uuid())
  // null for messages received before vehicle linkage is complete
  highMobilityVehicleId String?             @map("high_mobility_vehicle_id")
  vin                   String?
  messageId             String              @map("message_id")
  topic                 String
  messageTimestamp      DateTime?           @map("message_timestamp")
  ingestStatus          HmIngestStatus      @default(RECEIVED) @map("ingest_status")
  // true if message_id was seen before (deduplicated)
  isDuplicate           Boolean             @default(false) @map("is_duplicate")
  payloadJson           Json?               @map("payload_json")
  // Extracted normalized summary (source-agnostic fields)
  normalizedSummaryJson Json?               @map("normalized_summary_json")
  errorMessage          String?             @map("error_message")
  // Which HM app-container ingested this message
  appContainerType      HmAppContainerType? @map("app_container_type")
  createdAt             DateTime            @default(now()) @map("created_at")

  vehicle HighMobilityVehicle? @relation(fields: [highMobilityVehicleId], references: [id], onDelete: SetNull)

  @@unique([messageId], name: "uq_hm_stream_message_id")
  @@index([highMobilityVehicleId])
  @@index([vin])
  @@index([topic])
  @@index([createdAt])
  @@index([ingestStatus])
  @@index([appContainerType])
  @@map("high_mobility_stream_sync_logs")
}

// Phase 3 — Signal group fetch state (cache + freshness tracking per vehicle per group)
enum HmSignalGroup {
  SERVICE
  TIRE_PRESSURE
  AI_HEALTH_CARE
}

model HmSignalGroupState {
  id               String        @id @default(uuid())
  vehicleId        String        @map("vehicle_id") // SynqDrive vehicle ID
  hmVehicleId      String        @map("hm_vehicle_id") // FK to high_mobility_vehicles
  signalGroup      HmSignalGroup @map("signal_group")
  lastFetchedAt    DateTime?     @map("last_fetched_at")
  lastSuccessAt    DateTime?     @map("last_success_at")
  lastErrorAt      DateTime?     @map("last_error_at")
  lastErrorMessage String?       @map("last_error_message")
  dataJson         Json?         @map("data_json") // Normalized cached signal payload
  fetchCount       Int           @default(0) @map("fetch_count")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  hmVehicle HighMobilityVehicle @relation(fields: [hmVehicleId], references: [id], onDelete: Cascade)
  // Direct FK to Vehicle enables join-free ownership checks
  vehicle   Vehicle?            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, signalGroup], name: "uq_signal_group_vehicle")
  @@index([vehicleId])
  @@index([hmVehicleId])
  @@index([signalGroup])
  @@map("hm_signal_group_states")
}

// Per-VIN latest normalized health state written by HM Health-APP MQTT consumer
model HmLatestHealthState {
  id                       String             @id @default(uuid())
  vin                      String
  appContainerType         HmAppContainerType @default(HM_HEALTH_APP) @map("app_container_type")
  hmVehicleId              String?            @map("hm_vehicle_id")
  lastMessageId            String?            @map("last_message_id")
  lastReceivedAt           DateTime           @map("last_received_at")
  dashboardLightsJson      Json?              @map("dashboard_lights_json")
  brakeLiningPreWarning    Boolean?           @map("brake_lining_pre_warning")
  engineLimpMode           Boolean?           @map("engine_limp_mode")
  engineOilLevelJson       Json?              @map("engine_oil_level_json")
  distanceToNextServiceKm  Float?             @map("distance_to_next_service_km")
  timeToNextServiceDays    Int?               @map("time_to_next_service_days")
  tirePressureStatusesJson Json?              @map("tire_pressure_statuses_json")
  tirePressuresJson        Json?              @map("tire_pressures_json")
  rawSignalsJson           Json?              @map("raw_signals_json")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  @@unique([vin, appContainerType], name: "uq_hm_latest_health_vin_app")
  @@index([vin])
  @@index([appContainerType])
  @@map("hm_latest_health_states")
}

// Per-VIN latest normalized telemetry state written by HM Telemetry-APP MQTT consumer
model HmLatestTelemetryState {
  id               String             @id @default(uuid())
  vin              String
  appContainerType HmAppContainerType @default(HM_TELEMETRY_APP) @map("app_container_type")
  hmVehicleId      String?            @map("hm_vehicle_id")
  lastMessageId    String?            @map("last_message_id")
  lastReceivedAt   DateTime           @map("last_received_at")
  latitude         Float?
  longitude        Float?
  speedKmh         Float?             @map("speed_kmh")
  ignitionOn       Boolean?           @map("ignition_on")
  odometerKm       Float?             @map("odometer_km")
  fuelLevelPercent Float?             @map("fuel_level_percent")
  batteryVoltage   Float?             @map("battery_voltage")
  rawSignalsJson   Json?              @map("raw_signals_json")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@unique([vin, appContainerType], name: "uq_hm_latest_telemetry_vin_app")
  @@index([vin])
  @@index([appContainerType])
  @@map("hm_latest_telemetry_states")
}

// MQTT consumer connection state — one row per app-container per environment
model HighMobilityStreamConsumerState {
  id               String                @id @default(uuid())
  environment      String // "sandbox" | "live"
  applicationId    String                @map("application_id")
  consumerGroup    String                @map("consumer_group")
  // Which HM app-container this consumer belongs to
  appContainerType HmAppContainerType?   @map("app_container_type")
  connectionState  HmMqttConnectionState @default(DISCONNECTED) @map("connection_state")
  lastConnectedAt  DateTime?             @map("last_connected_at")
  lastMessageAt    DateTime?             @map("last_message_at")
  lastErrorAt      DateTime?             @map("last_error_at")
  lastErrorMessage String?               @map("last_error_message")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@unique([environment, applicationId, consumerGroup], name: "uq_hm_consumer_state")
  @@index([environment])
  @@index([appContainerType])
  @@map("high_mobility_stream_consumer_states")
}
