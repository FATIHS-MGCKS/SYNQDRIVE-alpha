  expectedLifeKm          Int?            @map("expected_life_km")
  initialTreadDepthMm     Float?          @map("initial_tread_depth_mm")
  isStaggered             Boolean         @default(false) @map("is_staggered")
  kFactorFront            Float           @default(1.0) @map("k_factor_front")
  kFactorRear             Float           @default(1.0) @map("k_factor_rear")
  kFactorCalibrationCount Int             @default(0) @map("k_factor_calibration_count")
  regenBrakingFactor      Float           @default(1.0) @map("regen_braking_factor")
  regenBrakingFactorFront Float?          @map("regen_braking_factor_front")
  regenBrakingFactorRear  Float?          @map("regen_braking_factor_rear")
  initialTreadFrontMm     Float?          @map("initial_tread_front_mm")
  initialTreadRearMm      Float?          @map("initial_tread_rear_mm")
  expectedLifeKmFront     Int?            @map("expected_life_km_front")
  expectedLifeKmRear      Int?            @map("expected_life_km_rear")
  frontTireWidthMm        Int?            @map("front_tire_width_mm")
  rearTireWidthMm         Int?            @map("rear_tire_width_mm")
  installedAt             DateTime?       @map("installed_at")
  removedAt               DateTime?       @map("removed_at")
  installedOdometerKm     Float?          @map("installed_odometer_km")
  removedOdometerKm       Float?          @map("removed_odometer_km")
  status                  TireSetupStatus @default(ACTIVE)
  notes                   String?
  createdBy               String?         @map("created_by")
  updatedBy               String?         @map("updated_by")

  totalKmOnSet      Float @default(0) @map("total_km_on_set")
  cityKm            Float @default(0) @map("city_km")
  highwayKm         Float @default(0) @map("highway_km")
  ruralKm           Float @default(0) @map("rural_km")
  harshAccelEvents  Int   @default(0) @map("harsh_accel_events")
  harshBrakeEvents  Int   @default(0) @map("harsh_brake_events")
  harshCornerEvents Int   @default(0) @map("harsh_corner_events")
  burnoutEvents     Int   @default(0) @map("burnout_events")

  overallHealthPercent Float?           @map("overall_health_percent")
  overallRemainingKm   Int?             @map("overall_remaining_km")
  healthStatus         TireHealthStatus @default(EXCELLENT) @map("health_status")
  confidenceScore      Float?           @map("confidence_score")
  confidenceLabel      String?          @map("confidence_label")
  lastRecalculatedAt   DateTime?        @map("last_recalculated_at")
  wearRateMmPer1000km  Float?           @map("wear_rate_mm_per_1000km")

  // ── Load / Speed index per axle ──────────────────────────────────────────────
  loadIndexFront  String? @map("load_index_front")
  speedIndexFront String? @map("speed_index_front")
  loadIndexRear   String? @map("load_index_rear")
  speedIndexRear  String? @map("speed_index_rear")
  dotCodeFront    String? @map("dot_code_front")
  dotCodeRear     String? @map("dot_code_rear")

  // ── Tire condition at setup ─────────────────────────────────────────────────
  tireCondition TireSetupCondition @default(UNKNOWN) @map("tire_condition")

  // ── AI tire spec (structured JSON blob) ─────────────────────────────────────
  aiTireSpec Json? @map("ai_tire_spec")

  // ── Reference / threshold fields resolved from spec + manual ────────────────
  referenceNewTreadMm      Float? @map("reference_new_tread_mm")
  legalMinimumMm           Float? @map("legal_minimum_mm")
  recommendedReplacementMm Float? @map("recommended_replacement_mm")
  operationalReplacementMm Float? @map("operational_replacement_mm")

  // ── Source tracking ─────────────────────────────────────────────────────────
  initialTreadSource         String? @map("initial_tread_source")
  referenceNewTreadSource    String? @map("reference_new_tread_source")
  replacementThresholdSource String? @map("replacement_threshold_source")

  // ── Multi-dimensional confidence ────────────────────────────────────────────
  tireSpecConfidence         Float? @map("tire_spec_confidence")
  dataCompletenessConfidence Float? @map("data_completeness_confidence")
  modelConfidence            Float? @map("model_confidence")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle         Vehicle                       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  measurements    VehicleTireTreadMeasurement[]
  tires           Tire[]
  positionHistory TirePositionHistory[]
  events          TireEvent[]
  snapshots       TireHealthSnapshot[]
  wearDataPoints  TireWearDataPoint[]

  @@index([vehicleId])
  @@index([organizationId, vehicleId])
  @@index([status])
  @@map("vehicle_tire_setups")
}

