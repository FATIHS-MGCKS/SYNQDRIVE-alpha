// ------------------------------------------------
// TASKS
// ------------------------------------------------

enum TaskStatus {
  OPEN
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// V4.8.3 — Task Action Layer. Canonical task taxonomy. Operationally typed so
// UI, automation and templates can branch on a stable value instead of the
// legacy free-form `category` string (which is kept for backward compat).
enum TaskType {
  VEHICLE_SERVICE
  VEHICLE_INSPECTION
  TIRE_CHECK
  BRAKE_CHECK
  BATTERY_CHECK
  VEHICLE_CLEANING
  BOOKING_PREPARATION
  BOOKING_PICKUP
  BOOKING_RETURN
  DOCUMENT_REVIEW
  INVOICE_REQUIRED
  CUSTOMER_FOLLOWUP
  REPAIR
  CUSTOM
}

// Origin domain of a task. Coarser than the free-form `source` string (which
// keeps the exact detector provenance like INSIGHT_SERVICE for the auto-close
// whitelist); `sourceType` is the stable category used by API/UI filters.
enum TaskSource {
  MANUAL
  SYSTEM
  ALERT
  HEALTH
  BOOKING
  DOCUMENT
  VENDOR
}

// Task Domain V2 — how a terminal task reached DONE/CANCELLED (maps to spec
// `resolutionKind`). NULL while the task is active or for legacy rows.
enum TaskCompletionMode {
  MANUAL
  AUTO_RESOLVED
  SUPERSEDED
}

model OrgTask {
  id                        String              @id @default(uuid())
  organizationId            String              @map("organization_id")
  title                     String
  description               String?
  /// Legacy free-form category string — prefer `type` for new code.
  category                  String?
  type                      TaskType            @default(CUSTOM)
  status                    TaskStatus          @default(OPEN)
  priority                  TaskPriority        @default(NORMAL)
  // Canonical link targets. All optional — a task may link to a vehicle, a
  // booking, a customer, a vendor, an alert (DashboardInsight) or a document,
  // but never has to have all of them. Stored as plain scoped ids (org
  // ownership validated in TasksService) mirroring OrgInvoice's link columns.
  vehicleId                 String?             @map("vehicle_id")
  bookingId                 String?             @map("booking_id")
  customerId                String?             @map("customer_id")
  vendorId                  String?             @map("vendor_id")
  alertId                   String?             @map("alert_id")
  documentId                String?             @map("document_id")
  fineId                    String?             @map("fine_id")
  invoiceId                 String?             @map("invoice_id")
  assignedUserId            String?             @map("assigned_to")
  dueDate                   DateTime?           @map("due_date")
  startedAt                 DateTime?           @map("started_at")
  completedAt               DateTime?           @map("completed_at")
  cancelledAt               DateTime?           @map("cancelled_at")
  estimatedCostCents        Int?                @map("estimated_cost_cents")
  actualCostCents           Int?                @map("actual_cost_cents")
  resolutionNote            String?             @map("resolution_note")
  // V4.9.17 — When true, operators should treat this task as blocking vehicle
  // rental/availability until resolved. Default false for all legacy rows.
  blocksVehicleAvailability Boolean             @default(false) @map("blocks_vehicle_availability")
  metadata                  Json?
  createdByUserId           String?             @map("created_by_user_id")
  updatedByUserId           String?             @map("updated_by_user_id")
  // V4.7.59 — Auto-task provenance. `source` distinguishes operator-created
  // tasks (null) from system-generated ones (e.g. INSIGHT_SERVICE,
  // INSIGHT_COMPLIANCE). `dedupKey` is the idempotency key the Insight→Task
  // bridge uses to upsert/escalate a single task per (vehicle, condition)
  // instead of duplicating it on every insight run. `sourceType` is the
  // coarse origin domain (V4.8.3).
  /// Legacy provenance string (e.g. INSIGHT_SERVICE) — prefer `sourceType` for filters.
  source                    String?             @map("source")
  sourceType                TaskSource          @default(MANUAL) @map("source_type")
  dedupKey                  String?             @map("dedup_key")
  serviceCaseId             String?             @map("service_case_id")
  // Task Domain V2 — additive lifecycle / completion columns (nullable for
  // legacy rows; business rules enforced in TasksService, not DB constraints).
  activatesAt               DateTime            @map("activates_at")
  completionMode            TaskCompletionMode? @map("completion_mode")
  resolutionCode            String?             @map("resolution_code")
  completedByUserId         String?             @map("completed_by_user_id")
  supersededByTaskId        String?             @map("superseded_by_task_id")
  estimatedDurationMinutes  Int?                @map("estimated_duration_minutes")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  fine           Fine?               @relation(fields: [fineId], references: [id], onDelete: SetNull)
  invoice        OrgInvoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  serviceCase    ServiceCase?        @relation(fields: [serviceCaseId], references: [id], onDelete: SetNull)
  supersededBy   OrgTask?            @relation("TaskSupersession", fields: [supersededByTaskId], references: [id], onDelete: SetNull)
  supersedes     OrgTask[]           @relation("TaskSupersession")
  checklistItems TaskChecklistItem[]
  comments       TaskComment[]
  attachments    TaskAttachment[]
  events         TaskEvent[]
  vehicleDamages VehicleDamage[]

  @@unique([organizationId, dedupKey], name: "org_tasks_org_dedup_key")
  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([sourceType])
  @@index([dueDate])
  @@index([fineId])
  @@index([invoiceId])
  @@index([vehicleId])
  @@index([bookingId])
  @@index([customerId])
  @@index([vendorId])
  @@index([alertId])
  @@index([documentId])
  @@index([assignedUserId])
  @@index([createdByUserId])
  @@index([serviceCaseId])
  // Task list is per-org filtered by status; dueDate is the common sort.
  @@index([organizationId, status])
  @@index([organizationId, assignedUserId])
  @@index([organizationId, dueDate])
  @@index([organizationId, source])
  @@index([organizationId, status, activatesAt])
  @@index([completionMode])
  @@index([supersededByTaskId])
  @@map("org_tasks")
}

// ─── Task child resources (V4.8.3) ───────────────────────────────────────

model TaskChecklistItem {
  id                String    @id @default(uuid())
  taskId            String    @map("task_id")
  title             String
  description       String?
  sortOrder         Int       @default(0) @map("sort_order")
  isDone            Boolean   @default(false) @map("is_done")
  isRequired        Boolean   @default(false) @map("is_required")
  completedAt       DateTime? @map("completed_at")
  completedByUserId String?   @map("completed_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  task OrgTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklist_items")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String?  @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task OrgTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model TaskAttachment {
  id               String   @id @default(uuid())
  taskId           String   @map("task_id")
  fileUrl          String   @map("file_url")
  fileName         String?  @map("file_name")
  mimeType         String?  @map("mime_type")
  size             Int?
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  task OrgTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_attachments")
}

// Immutable timeline of what happened to a task (status changes, assignment,
// comments, completion). `type` is a free string so new event kinds don't need
// a migration.
model TaskEvent {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  type        String
  actorUserId String?  @map("actor_user_id")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  task OrgTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_events")
}

// ------------------------------------------------
// SERVICE CASES (V4.9.49 — canonical maintenance/repair cases)
// ------------------------------------------------
// A ServiceCase groups related OrgTasks under one operational workshop case.
// Tasks remain the unit of work; serviceCaseId on OrgTask is optional so legacy
// rows and standalone tasks keep working without backfill.

enum ServiceCaseCategory {
  SERVICE
  REPAIR
  INSPECTION
  TUV_HU
  TIRES
  BRAKES
  BATTERY
  DAMAGE
  DIAGNOSTIC
}

enum ServiceCaseStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  WAITING_VENDOR
  WAITING_PARTS
  COMPLETED
  CANCELLED
}

enum ServiceCaseSource {
  MANUAL
  HEALTH
  DTC
  DAMAGE
  BOOKING
  DOCUMENT
  SERVICE_COMPLIANCE
}

model ServiceCase {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  vehicleId          String              @map("vehicle_id")
  vendorId           String?             @map("vendor_id")
  title              String
  description        String?
  category           ServiceCaseCategory
  status             ServiceCaseStatus   @default(OPEN)
  priority           TaskPriority        @default(NORMAL)
  source             ServiceCaseSource   @default(MANUAL)
  openedAt           DateTime            @default(now()) @map("opened_at")
  scheduledAt        DateTime?           @map("scheduled_at")
  expectedReadyAt    DateTime?           @map("expected_ready_at")
  completedAt        DateTime?           @map("completed_at")
  cancelledAt        DateTime?           @map("cancelled_at")
  estimatedCostCents Int?                @map("estimated_cost_cents")
  actualCostCents    Int?                @map("actual_cost_cents")
  downtimeStart      DateTime?           @map("downtime_start")
  downtimeEnd        DateTime?           @map("downtime_end")
  blocksRental       Boolean             @default(false) @map("blocks_rental")
  completionNotes    String?             @map("completion_notes")
  documentId         String?             @map("document_id")
  metadata           Json?
  createdByUserId    String?             @map("created_by_user_id")
  updatedByUserId    String?             @map("updated_by_user_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tasks       OrgTask[]
  comments    ServiceCaseComment[]
  attachments ServiceCaseAttachment[]

  @@index([organizationId])
  @@index([vehicleId])
  @@index([vendorId])
  @@index([status])
  @@index([category])
  @@index([organizationId, status])
  @@index([organizationId, vehicleId])
  @@index([organizationId, vendorId])
  @@map("service_cases")
}

model ServiceCaseComment {
  id            String   @id @default(uuid())
  serviceCaseId String   @map("service_case_id")
  userId        String?  @map("user_id")
  body          String
  createdAt     DateTime @default(now()) @map("created_at")

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)

  @@index([serviceCaseId])
  @@map("service_case_comments")
}

model ServiceCaseAttachment {
  id               String   @id @default(uuid())
  serviceCaseId    String   @map("service_case_id")
  fileUrl          String   @map("file_url")
  fileName         String?  @map("file_name")
  mimeType         String?  @map("mime_type")
  size             Int?
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  serviceCase ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Cascade)

  @@index([serviceCaseId])
  @@map("service_case_attachments")
}

// ------------------------------------------------
// ORG INVOICES
// ------------------------------------------------

enum OrgInvoiceType {
  OUTGOING_BOOKING
  OUTGOING_MANUAL
  OUTGOING_FINAL
  INCOMING_VENDOR
  INCOMING_UPLOADED
}

enum OrgInvoiceStatus {
  // Outgoing lifecycle
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  CREDITED
  VOID
  // Incoming lifecycle
  UPLOADED
  NEEDS_REVIEW
  APPROVED
  BOOKED
  REJECTED
}

enum InvoicePaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  STRIPE
  OTHER
}

// ------------------------------------------------
// END-CUSTOMER PAYMENTS (Connect) — separate from modules/billing
// ------------------------------------------------

enum PaymentProvider {
  STRIPE
}

enum StripeAccountGeneration {
  V1
  V2
}

enum OrganizationPaymentAccountStatus {
  PENDING
  ONBOARDING
  ACTIVE
  RESTRICTED
  DISABLED
  REJECTED
}

enum BookingPaymentStatus {
  UNPAID
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum BookingPaymentRequestStatus {
  DRAFT
  OPEN
  LINK_PENDING
  CHECKOUT_READY
  LINK_SENT
  PROCESSING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum PaymentEmailType {
  BOOKING_PAYMENT_REQUEST
  PAYMENT_CONFIRMATION
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  PAYMENT_REFUND
  PAYMENT_DISPUTE
}

enum PaymentEmailOutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  DEAD_LETTER
}

enum BookingPaymentPurpose {
  RENTAL_PAYMENT
  BOOKING_INVOICE
  INVOICE_SETTLEMENT
}

enum PaymentTransactionType {
  CHARGE
  APPLICATION_FEE
  REFUND
  REFUND_APPLICATION_FEE
  DISPUTE
  DISPUTE_REVERSAL
  ADJUSTMENT
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum StripeConnectWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
  UNRESOLVED_ACCOUNT
}

model OrganizationPaymentAccount {
  id                              String                           @id @default(uuid())
  organizationId                  String                           @map("organization_id")
  provider                        PaymentProvider                  @default(STRIPE)
  status                          OrganizationPaymentAccountStatus @default(PENDING)
  stripeConnectedAccountId        String?                          @map("stripe_connected_account_id")
  stripeAccountGeneration         StripeAccountGeneration          @default(V1) @map("stripe_account_generation")
  livemode                        Boolean                          @default(false)
  country                         String?
  defaultCurrency                 String                           @default("EUR") @map("default_currency")
  detailsSubmitted                Boolean                          @default(false) @map("details_submitted")
  chargesEnabled                  Boolean                          @default(false) @map("charges_enabled")
  payoutsEnabled                  Boolean                          @default(false) @map("payouts_enabled")
  disabledReason                  String?                          @map("disabled_reason")
  requirementsCurrentlyDue        Json?                            @map("requirements_currently_due")
  requirementsPastDue             Json?                            @map("requirements_past_due")
  requirementsPendingVerification Json?                            @map("requirements_pending_verification")
  bankAccountLast4                String?                          @map("bank_account_last4")
  lastSyncedAt                    DateTime?                        @map("last_synced_at")
  lastStripeEventAt               DateTime?                        @map("last_stripe_event_at")
  createdAt                       DateTime                         @default(now()) @map("created_at")
  updatedAt                       DateTime                         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@unique([stripeConnectedAccountId])
  @@index([organizationId, status])
  @@map("organization_payment_accounts")
}

model BookingPaymentRequest {
  id                        String                      @id @default(uuid())
  organizationId            String                      @map("organization_id")
  bookingId                 String                      @map("booking_id")
  invoiceId                 String?                     @map("invoice_id")
  customerId                String                      @map("customer_id")
  provider                  PaymentProvider             @default(STRIPE)
  purpose                   BookingPaymentPurpose
  status                    BookingPaymentRequestStatus @default(DRAFT)
  amountCents               Int                         @map("amount_cents")
  paidAmountCents           Int                         @default(0) @map("paid_amount_cents")
  refundedAmountCents       Int                         @default(0) @map("refunded_amount_cents")
  currency                  String                      @default("EUR")
  stripeConnectedAccountId  String?                     @map("stripe_connected_account_id")
  stripeCheckoutSessionId   String?                     @map("stripe_checkout_session_id")
  stripePaymentIntentId     String?                     @map("stripe_payment_intent_id")
  stripeChargeId            String?                     @map("stripe_charge_id")
  stripeApplicationFeeId    String?                     @map("stripe_application_fee_id")
  commissionableAmountCents Int?                        @map("commissionable_amount_cents")
  applicationFeeAmountCents Int?                        @map("application_fee_amount_cents")
  feeRateBps                Int?                        @map("fee_rate_bps")
  fixedFeeCents             Int?                        @map("fixed_fee_cents")
  feePolicyVersion          String?                     @map("fee_policy_version")
  feeBasis                  String?                     @map("fee_basis")
  checkoutUrl               String?                     @map("checkout_url")
  checkoutCreatedAt         DateTime?                   @map("checkout_created_at")
  checkoutExpiresAt         DateTime?                   @map("checkout_expires_at")
  checkoutIdempotencyKey    String?                     @map("checkout_idempotency_key")
  stripeLivemode            Boolean?                    @map("stripe_livemode")
  recipientEmail            String?                     @map("recipient_email")
  sendEmailOnLink           Boolean                     @default(false) @map("send_email_on_link")
  lastSentAt                DateTime?                   @map("last_sent_at")
  sendAttemptCount          Int                         @default(0) @map("send_attempt_count")
  lastEmailErrorAt          DateTime?                   @map("last_email_error_at")
  lastEmailErrorMessage     String?                     @map("last_email_error_message")
  paidAt                    DateTime?                   @map("paid_at")
  failedAt                  DateTime?                   @map("failed_at")
  cancelledAt               DateTime?                   @map("cancelled_at")
  idempotencyKey            String                      @map("idempotency_key")
  version                   Int                         @default(1)
  createdAt                 DateTime                    @default(now()) @map("created_at")
  updatedAt                 DateTime                    @updatedAt @map("updated_at")

  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking            Booking              @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  invoice            OrgInvoice?          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  customer           Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  transactions       PaymentTransaction[]
  invoicePayment     OrgInvoicePayment?
  paymentEmailOutbox PaymentEmailOutbox[]
  outboundEmails     OutboundEmail[]

  @@unique([organizationId, idempotencyKey])
  @@unique([stripeConnectedAccountId, stripeCheckoutSessionId], map: "booking_payment_requests_stripe_acct_checkout_session_key")
  @@unique([stripeConnectedAccountId, stripePaymentIntentId], map: "booking_payment_requests_stripe_acct_payment_intent_key")
  @@unique([stripeConnectedAccountId, stripeChargeId], map: "booking_payment_requests_stripe_acct_charge_key")
  @@index([organizationId])
  @@index([bookingId, purpose, status])
  @@index([invoiceId])
  @@index([customerId])
  @@index([status])
  @@map("booking_payment_requests")
}

model PaymentEmailOutbox {
  id               String                   @id @default(uuid())
  organizationId   String                   @map("organization_id")
  paymentRequestId String                   @map("payment_request_id")
  emailType        PaymentEmailType         @map("email_type")
  status           PaymentEmailOutboxStatus @default(PENDING)
  idempotencyKey   String                   @unique @map("idempotency_key")
  attempts         Int                      @default(0)
  availableAt      DateTime                 @default(now()) @map("available_at")
  outboundEmailId  String?                  @map("outbound_email_id")
  errorMessage     String?                  @map("error_message")
  sentByUserId     String?                  @map("sent_by_user_id")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  processedAt      DateTime?                @map("processed_at")

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paymentRequest BookingPaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Cascade)
  outboundEmail  OutboundEmail?        @relation(fields: [outboundEmailId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([paymentRequestId])
  @@index([status, availableAt])
  @@map("payment_email_outbox")
}

/// Append-only financial ledger — never update or delete rows in application code.
model PaymentTransaction {
  id                        String                   @id @default(uuid())
  organizationId            String                   @map("organization_id")
  paymentRequestId          String                   @map("payment_request_id")
  type                      PaymentTransactionType
  status                    PaymentTransactionStatus @default(PENDING)
  amountCents               Int                      @map("amount_cents")
  currency                  String                   @default("EUR")
  provider                  PaymentProvider          @default(STRIPE)
  providerObjectType        String?                  @map("provider_object_type")
  providerObjectId          String?                  @map("provider_object_id")
  providerEventId           String?                  @map("provider_event_id")
  parentTransactionId       String?                  @map("parent_transaction_id")
  balanceImpactCents        Int                      @default(0) @map("balance_impact_cents")
  applicationFeeImpactCents Int                      @default(0) @map("application_fee_impact_cents")
  occurredAt                DateTime                 @map("occurred_at")
  metadata                  Json?
  createdAt                 DateTime                 @default(now()) @map("created_at")

  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  paymentRequest    BookingPaymentRequest @relation(fields: [paymentRequestId], references: [id], onDelete: Restrict)
  parentTransaction PaymentTransaction?   @relation("PaymentTransactionChain", fields: [parentTransactionId], references: [id], onDelete: Restrict)
  childTransactions PaymentTransaction[]  @relation("PaymentTransactionChain")

  @@unique([provider, providerEventId, type])
  @@index([organizationId, occurredAt])
  @@index([paymentRequestId])
  @@index([providerObjectType, providerObjectId])
  @@map("payment_transactions")
}

model StripeConnectWebhookEvent {
  id                       String                               @id @default(uuid())
  stripeEventId            String                               @unique @map("stripe_event_id")
  stripeConnectedAccountId String?                              @map("stripe_connected_account_id")
  organizationId           String?                              @map("organization_id")
  eventType                String                               @map("event_type")
  objectId                 String?                              @map("object_id")
  livemode                 Boolean                              @default(false)
  processingStatus         StripeConnectWebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  attempts                 Int                                  @default(0)
  payloadHash              String?                              @map("payload_hash")
  safeEventData            Json?                                @map("safe_event_data")
  receivedAt               DateTime                             @default(now()) @map("received_at")
  processedAt              DateTime?                            @map("processed_at")
  errorMessage             String?                              @map("error_message")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([processingStatus, receivedAt])
  @@index([organizationId, receivedAt])
  @@index([stripeConnectedAccountId])
  @@map("stripe_connect_webhook_events")
}

model OrgInvoiceSequence {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  sequenceYear   Int      @map("sequence_year")
  lastNumber     Int      @default(0) @map("last_number")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sequenceYear])
  @@map("org_invoice_sequences")
}

model OrgInvoicePayment {
  id                      String               @id @default(uuid())
  organizationId          String               @map("organization_id")
  invoiceId               String               @map("invoice_id")
  amountCents             Int                  @map("amount_cents")
  method                  InvoicePaymentMethod @default(BANK_TRANSFER)
  paidAt                  DateTime             @map("paid_at")
  reference               String?
  note                    String?
  stripePaymentIntentId   String?              @map("stripe_payment_intent_id")
  stripeChargeId          String?              @map("stripe_charge_id")
  bookingPaymentRequestId String?              @unique @map("booking_payment_request_id")
  createdByUserId         String?              @map("created_by_user_id")
  createdAt               DateTime             @default(now()) @map("created_at")

  invoice               OrgInvoice             @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  bookingPaymentRequest BookingPaymentRequest? @relation(fields: [bookingPaymentRequestId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invoiceId])
  @@index([paidAt])
  @@index([stripePaymentIntentId])
  @@index([stripeChargeId])
  @@map("org_invoice_payments")
}

model OrgInvoice {
  id                   String           @id @default(uuid())
  /// @deprecated Legacy global autoincrement — use invoiceNumberDisplay + sequence fields for new invoices.
  invoiceNumber        Int?             @map("invoice_number")
  legacyInvoiceNumber  Int?             @map("legacy_invoice_number")
  invoiceNumberDisplay String?          @map("invoice_number_display")
  sequenceYear         Int?             @map("sequence_year")
  sequenceNumber       Int?             @map("sequence_number")
  organizationId       String           @map("organization_id")
  type                 OrgInvoiceType
  customerId           String?          @map("customer_id")
  vendorId             String?          @map("vendor_id")
  vendorName           String?          @map("vendor_name")
  bookingId            String?          @map("booking_id")
  vehicleId            String?          @map("vehicle_id")
  title                String
  description          String?
  lineItems            Json?            @map("line_items")
  subtotalCents        Int              @default(0) @map("subtotal_cents")
  taxCents             Int              @default(0) @map("tax_cents")
  totalCents           Int              @map("total_cents")
  paidCents            Int              @default(0) @map("paid_cents")
  outstandingCents     Int              @default(0) @map("outstanding_cents")
  currency             String           @default("EUR")
  invoiceDate          DateTime         @default(now()) @map("invoice_date")
  dueDate              DateTime?        @map("due_date")
  status               OrgInvoiceStatus @default(DRAFT)
  templateId           String?          @map("template_id")
  imageUrl             String?          @map("image_url")
  extractedData        Json?            @map("extracted_data")
  documentExtractionId String?          @map("document_extraction_id")
  generatedDocumentId  String?          @unique @map("generated_document_id")
  notes                String?
  paidAt               DateTime?        @map("paid_at")
  issuedAt             DateTime?        @map("issued_at")
  sentAt               DateTime?        @map("sent_at")
  cancelledAt          DateTime?        @map("cancelled_at")
  voidedAt             DateTime?        @map("voided_at")
  creditedAt           DateTime?        @map("credited_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  tasks                  OrgTask[]
  payments               OrgInvoicePayment[]
  bookingPaymentRequests BookingPaymentRequest[]
  vendor                 Vendor?                 @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedDocument      GeneratedDocument?      @relation("InvoiceActiveDocument", fields: [generatedDocumentId], references: [id], onDelete: SetNull)
  documents              GeneratedDocument[]     @relation("InvoiceDocuments")
  outboundEmails         OutboundEmail[]

  @@unique([organizationId, sequenceYear, sequenceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([vendorId])
  @@index([bookingId])
  @@index([status])
  @@index([type])
  @@index([invoiceDate])
  @@index([organizationId, status])
  @@index([organizationId, invoiceDate])
  @@index([organizationId, dueDate])
  @@index([organizationId, type, status])
  @@map("org_invoices")
}

// ------------------------------------------------
// BOOKING DOCUMENT LIFECYCLE
// ------------------------------------------------
// Central document engine: business modules (bookings, invoices, handover)
// own the data; these models own document rendering metadata, uploaded legal
// versions, and the per-booking bundle that tracks which documents exist.
// Status fields use plain strings (values documented inline) to keep the
// migration small and consistent with other recent additions. Cross-entity
// links to Booking/Customer/Vehicle/Invoice/Handover are kept as scalar id
// columns + indexes (no Prisma relations) to avoid migration friction.

model GeneratedDocument {
  id                 String       @id @default(uuid())
  organizationId     String       @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentType       String       @map("document_type") // BOOKING_INVOICE, DEPOSIT_RECEIPT, RENTAL_CONTRACT, TERMS_AND_CONDITIONS, WITHDRAWAL_INFORMATION, HANDOVER_PICKUP, HANDOVER_RETURN, FINAL_INVOICE
  origin             String       @default("GENERATED") // GENERATED, STATIC_LEGAL, UPLOADED_REFERENCE
  status             String       @default("GENERATED") // DRAFT, GENERATED, SENT, VOID, FAILED
  bookingId          String?      @map("booking_id")
  customerId         String?      @map("customer_id")
  vehicleId          String?      @map("vehicle_id")
  invoiceId          String?      @map("invoice_id")
  handoverProtocolId String?      @map("handover_protocol_id")
  rentalContractId   String?      @map("rental_contract_id")
  depositId          String?      @map("deposit_id")
  legalDocumentId    String?      @map("legal_document_id")
  title              String
  documentNumber     String?      @map("document_number")
  fileName           String       @map("file_name")
  mimeType           String       @default("application/pdf") @map("mime_type")
  storageProvider    String       @default("local") @map("storage_provider")
  objectKey          String       @map("object_key")
  sizeBytes          Int?         @map("size_bytes")
  checksum           String?
  templateKey        String?      @map("template_key")
  templateVersion    String?      @map("template_version")
  legalVersionLabel  String?      @map("legal_version_label")
  generatedAt        DateTime?    @map("generated_at")
  generatedByUserId  String?      @map("generated_by_user_id")
  sentAt             DateTime?    @map("sent_at")
  signedAt           DateTime?    @map("signed_at")
  voidedAt           DateTime?    @map("voided_at")
  metadata           Json?
  snapshot           Json?
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  outboundEmailAttachments OutboundEmailAttachment[]
  activeForInvoice         OrgInvoice?               @relation("InvoiceActiveDocument")
  invoiceRecord            OrgInvoice?               @relation("InvoiceDocuments", fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([bookingId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([invoiceId])
  @@index([documentType])
  @@index([status])
  @@map("generated_documents")
}

model OrganizationLegalDocument {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentType     String       @map("document_type") // TERMS_AND_CONDITIONS, WITHDRAWAL_INFORMATION
  title            String
  versionLabel     String       @map("version_label")
  language         String       @default("de")
  status           String       @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED
  fileName         String       @map("file_name")
  mimeType         String       @default("application/pdf") @map("mime_type")
  storageProvider  String       @default("local") @map("storage_provider")
  objectKey        String       @map("object_key")
  checksum         String?
  sizeBytes        Int?         @map("size_bytes")
  activeFrom       DateTime?    @map("active_from")
  uploadedByUserId String?      @map("uploaded_by_user_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([organizationId, documentType, status])
  @@map("organization_legal_documents")
}

model BookingDocumentBundle {
  id                       String       @id @default(uuid())
  organizationId           String       @map("organization_id")
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingId                String       @unique @map("booking_id")
  status                   String       @default("PENDING") // PENDING, PARTIAL, COMPLETE, FAILED
  bookingInvoiceDocumentId String?      @map("booking_invoice_document_id")
  depositReceiptDocumentId String?      @map("deposit_receipt_document_id")
  rentalContractDocumentId String?      @map("rental_contract_document_id")
  termsDocumentId          String?      @map("terms_document_id")
  withdrawalDocumentId     String?      @map("withdrawal_document_id")
  pickupProtocolDocumentId String?      @map("pickup_protocol_document_id")
  returnProtocolDocumentId String?      @map("return_protocol_document_id")
  finalInvoiceDocumentId   String?      @map("final_invoice_document_id")
  generatedAt              DateTime?    @map("generated_at")
  lastError                String?      @map("last_error")
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([bookingId])
  @@index([status])
  @@map("booking_document_bundles")
}

model BookingDeposit {
  id                  String       @id @default(uuid())
  organizationId      String       @map("organization_id")
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingId           String       @unique @map("booking_id")
  customerId          String?      @map("customer_id")
  amountCents         Int          @map("amount_cents")
  currency            String       @default("EUR")
  status              String       @default("REQUESTED") // REQUESTED, RECEIVED, PARTIALLY_USED, REFUNDED, PARTIALLY_REFUNDED, FORFEITED
  paymentMethod       String?      @map("payment_method")
  receivedAt          DateTime?    @map("received_at")
  refundedAt          DateTime?    @map("refunded_at")
  retainedAmountCents Int          @default(0) @map("retained_amount_cents")
  refundAmountCents   Int          @default(0) @map("refund_amount_cents")
  reason              String?
  receiptDocumentId   String?      @map("receipt_document_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([bookingId])
  @@index([customerId])
  @@index([status])
  @@map("booking_deposits")
}

model RentalContract {
  id                   String       @id @default(uuid())
  organizationId       String       @map("organization_id")
