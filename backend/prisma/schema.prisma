model BillingReconciliationDrift {
  id               String                             @id @default(uuid())
  runId            String?                            @map("run_id")
  organizationId   String                             @map("organization_id")
  subscriptionId   String?                            @map("subscription_id")
  driftType        BillingReconciliationDriftType     @map("drift_type")
  severity         BillingReconciliationDriftSeverity
  localValue       String?                            @map("local_value")
  stripeValue      String?                            @map("stripe_value")
  suggestedAction  String                             @map("suggested_action")
  autoFixable      Boolean                            @default(false) @map("auto_fixable")
  detectedAt       DateTime                           @default(now()) @map("detected_at")
  resolvedAt       DateTime?                          @map("resolved_at")
  resolvedByUserId String?                            @map("resolved_by_user_id")
  stripeMode       BillingStripeMode?                 @map("stripe_mode")
  idempotencyKey   String?                            @unique @map("idempotency_key")
  createdAt        DateTime                           @default(now()) @map("created_at")
  updatedAt        DateTime                           @updatedAt @map("updated_at")

