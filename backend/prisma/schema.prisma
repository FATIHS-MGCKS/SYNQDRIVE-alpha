// INSURANCE MODULE
// ════════════════════════════════════════════════════════

enum InsuranceCommunicationChannel {
  EMAIL
  API
  WEBHOOK
  MANUAL
}

enum InsurerHealthStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

enum InsurerEnvironment {
  SANDBOX
  PRODUCTION
}

enum VehicleInsuranceStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  MISSING
  PENDING_INQUIRY
}

enum InsuranceInquiryStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_SENT
  FAILED
  AWAITING_RESPONSE
  RESPONDED
  CLOSED
}

enum InquiryRecipientDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum InquiryRecipientResponseStatus {
  AWAITING
  RECEIVED
  DECLINED
  NO_RESPONSE
}

enum LiveSharingStatus {
  DRAFT
  ACTIVE
  PAUSED
  REVOKED
  EXPIRED
}

model InsurancePartner {
  id                        String                        @id @default(uuid())
  key                       String                        @unique
  displayName               String                        @map("display_name")
  description               String?
  isEnabled                 Boolean                       @default(false) @map("is_enabled")
  countryScope              String[]                      @default([]) @map("country_scope")
  supportedInquiryTypes     String[]                      @default([]) @map("supported_inquiry_types")
  supportedInsuranceModels  String[]                      @default([]) @map("supported_insurance_models")
  acceptedHistoricalData    String[]                      @default([]) @map("accepted_historical_data")
  acceptedLiveData          String[]                      @default([]) @map("accepted_live_data")
  communicationChannel      InsuranceCommunicationChannel @default(EMAIL) @map("communication_channel")
  configJson                Json?                         @map("config_json")
  credentialsJson           Json?                         @map("credentials_json")
  healthStatus              InsurerHealthStatus           @default(UNKNOWN) @map("health_status")
  environment               InsurerEnvironment            @default(SANDBOX)
  lastTestedAt              DateTime?                     @map("last_tested_at")
  lastSuccessAt             DateTime?                     @map("last_success_at")
  lastFailureAt             DateTime?                     @map("last_failure_at")
  lastFailureReason         String?                       @map("last_failure_reason")
  slaInfo                   String?                       @map("sla_info")
  maxLookbackDays           Int?                          @map("max_lookback_days")
  supportsDynamicInsurance  Boolean                       @default(false) @map("supports_dynamic_insurance")
  supportsUsageBased        Boolean                       @default(false) @map("supports_usage_based")
  supportsKilometerBased    Boolean                       @default(false) @map("supports_kilometer_based")
  supportsDrivingScoreBased Boolean                       @default(false) @map("supports_driving_score_based")
  rankingWeight             Int                           @default(100) @map("ranking_weight")
  createdAt                 DateTime                      @default(now()) @map("created_at")
  updatedAt                 DateTime                      @updatedAt @map("updated_at")

  contacts               InsurancePartnerContact[]
  orgAccess              InsurancePartnerOrgAccess[]
  disclosureTemplates    InsuranceDisclosureTemplate[]
  inquiryTemplates       InsuranceInquiryTemplate[]
  inquiryRecipients      InsuranceInquiryRecipient[]
  authorizationLogs      InsuranceDataAuthorizationLog[]
  liveSharingPermissions InsuranceLiveSharingPermission[]

  @@index([isEnabled])
  @@map("insurance_partners")
}

model InsurancePartnerContact {
  id                 String   @id @default(uuid())
  insurancePartnerId String   @map("insurance_partner_id")
  fullName           String   @map("full_name")
  roleTitle          String?  @map("role_title")
  department         String?
  email              String?
  phone              String?
  isPrimary          Boolean  @default(false) @map("is_primary")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  partner InsurancePartner @relation(fields: [insurancePartnerId], references: [id], onDelete: Cascade)

  @@index([insurancePartnerId])
  @@map("insurance_partner_contacts")
}

model InsurancePartnerOrgAccess {
  id                 String   @id @default(uuid())
  insurancePartnerId String   @map("insurance_partner_id")
  organizationId     String   @map("organization_id")
  isEnabled          Boolean  @default(true) @map("is_enabled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  partner InsurancePartner @relation(fields: [insurancePartnerId], references: [id], onDelete: Cascade)

  @@unique([insurancePartnerId, organizationId])
  @@index([organizationId])
  @@map("insurance_partner_org_access")
}

model InsuranceDisclosureTemplate {
  id            String   @id @default(uuid())
  insurerKey    String?  @map("insurer_key")
  inquiryType   String?  @map("inquiry_type")
  version       Int      @default(1)
  title         String
  body          String
  isActive      Boolean  @default(true) @map("is_active")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  partner InsurancePartner? @relation(fields: [insurerKey], references: [key], onDelete: SetNull)

  @@index([insurerKey])
  @@index([isActive])
  @@map("insurance_disclosure_templates")
}

model InsuranceInquiryTemplate {
  id              String   @id @default(uuid())
  insurerKey      String?  @map("insurer_key")
  inquiryType     String?  @map("inquiry_type")
  version         Int      @default(1)
  subjectTemplate String   @map("subject_template")
  bodyTemplate    String   @map("body_template")
  isActive        Boolean  @default(true) @map("is_active")
  effectiveFrom   DateTime @default(now()) @map("effective_from")
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  partner InsurancePartner? @relation(fields: [insurerKey], references: [key], onDelete: SetNull)

  @@index([insurerKey])
  @@index([isActive])
  @@map("insurance_inquiry_templates")
}

model VehicleInsuranceRecord {
  id                String                 @id @default(uuid())
  organizationId    String                 @map("organization_id")
  vehicleId         String                 @map("vehicle_id")
  insurerName       String?                @map("insurer_name")
  policyNumber      String?                @map("policy_number")
  insuranceType     String?                @map("insurance_type")
  validFrom         DateTime?              @map("valid_from")
  validUntil        DateTime?              @map("valid_until")
  status            VehicleInsuranceStatus @default(MISSING)
  linkedDocumentIds String[]               @default([]) @map("linked_document_ids")
  notes             String?
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([vehicleId])
  @@index([status])
  @@map("vehicle_insurance_records")
}

model InsuranceInquiry {
  id                      String                 @id @default(uuid())
  organizationId          String                 @map("organization_id")
  userId                  String                 @map("user_id")
  vehicleId               String                 @map("vehicle_id")
  inquiryType             String                 @map("inquiry_type")
  selectedHistoricalData  Json                   @map("selected_historical_data")
  selectedLiveData        Json                   @map("selected_live_data")
  selectedTimeRange       Json                   @map("selected_time_range")
  selectedInsuranceModels String[]               @default([]) @map("selected_insurance_models")
  reviewSnapshotJson      Json?                  @map("review_snapshot_json")
  status                  InsuranceInquiryStatus @default(DRAFT)
  correlationId           String                 @default(uuid()) @map("correlation_id")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")

  recipients             InsuranceInquiryRecipient[]
  authorizationLogs      InsuranceDataAuthorizationLog[]
  liveSharingPermissions InsuranceLiveSharingPermission[]

  @@index([organizationId])
  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@index([correlationId])
  @@map("insurance_inquiries")
}

model InsuranceInquiryRecipient {
  id                  String                         @id @default(uuid())
  inquiryId           String                         @map("inquiry_id")
  insurerId           String                         @map("insurer_id")
  channelType         InsuranceCommunicationChannel  @map("channel_type")
  deliveryStatus      InquiryRecipientDeliveryStatus @default(PENDING) @map("delivery_status")
  sentAt              DateTime?                      @map("sent_at")
  responseStatus      InquiryRecipientResponseStatus @default(AWAITING) @map("response_status")
  responseReceivedAt  DateTime?                      @map("response_received_at")
  failureReason       String?                        @map("failure_reason")
  externalReference   String?                        @map("external_reference")
  payloadSnapshotJson Json?                          @map("payload_snapshot_json")
  createdAt           DateTime                       @default(now()) @map("created_at")
  updatedAt           DateTime                       @updatedAt @map("updated_at")

  inquiry InsuranceInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  insurer InsurancePartner @relation(fields: [insurerId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([insurerId])
  @@index([deliveryStatus])
  @@map("insurance_inquiry_recipients")
}

model InsuranceDataAuthorizationLog {
  id                      String   @id @default(uuid())
  organizationId          String   @map("organization_id")
  userId                  String   @map("user_id")
  vehicleId               String   @map("vehicle_id")
  insurerId               String   @map("insurer_id")
  inquiryId               String?  @map("inquiry_id")
  disclosedHistoricalData Json     @map("disclosed_historical_data")
  authorizedLiveData      Json     @map("authorized_live_data")
  selectedTimeRange       Json     @map("selected_time_range")
  aggregationSettings     Json?    @map("aggregation_settings")
  purpose                 String
  noticeVersion           Int      @map("notice_version")
  noticeTitleSnapshot     String   @map("notice_title_snapshot")
  noticeBodySnapshot      String   @map("notice_body_snapshot")
  confirmedAt             DateTime @map("confirmed_at")
  correlationId           String   @map("correlation_id")
  sessionId               String?  @map("session_id")
  ipAddress               String?  @map("ip_address")
  userAgent               String?  @map("user_agent")
  transmissionChannel     String?  @map("transmission_channel")
  transmissionResult      String?  @map("transmission_result")
  failureReason           String?  @map("failure_reason")
  createdAt               DateTime @default(now()) @map("created_at")

  insurer InsurancePartner  @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  inquiry InsuranceInquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([vehicleId])
  @@index([insurerId])
  @@index([inquiryId])
  @@index([correlationId])
  @@index([confirmedAt])
  @@map("insurance_data_authorization_logs")
}

model InsuranceLiveSharingPermission {
  id                    String            @id @default(uuid())
  organizationId        String            @map("organization_id")
  vehicleId             String            @map("vehicle_id")
  insurerId             String            @map("insurer_id")
  inquiryId             String?           @map("inquiry_id")
  enabledDataCategories Json              @map("enabled_data_categories")
  aggregationSettings   Json?             @map("aggregation_settings")
  reportingFrequency    String?           @map("reporting_frequency")
  status                LiveSharingStatus @default(DRAFT)
  validFrom             DateTime          @default(now()) @map("valid_from")
  validUntil            DateTime?         @map("valid_until")
  revokedAt             DateTime?         @map("revoked_at")
  revokedBy             String?           @map("revoked_by")
  revokeReason          String?           @map("revoke_reason")
  createdBy             String            @map("created_by")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  insurer InsurancePartner  @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  inquiry InsuranceInquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vehicleId])
  @@index([insurerId])
  @@index([status])
  @@map("insurance_live_sharing_permissions")
}

