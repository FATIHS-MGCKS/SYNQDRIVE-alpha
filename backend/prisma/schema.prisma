model PlatformChangelog {
  id                  String   @id @default(uuid())
  version             String
  title               String
  summary             String[]
  reason              String?
  previousBehavior    String?  @map("previous_behavior")
  details             String?
  affectsArchitecture Boolean  @default(false) @map("affects_architecture")
