model BillingInvoice {
  id                   String             @id @default(uuid())
  subscriptionId       String             @map("subscription_id")
  stripeInvoiceId      String?            @map("stripe_invoice_id")
  stripeMode           BillingStripeMode? @map("stripe_mode")
  invoiceNumber        String?            @map("invoice_number")
  amountCents          Int                @map("amount_cents")
  netAmountCents       Int?               @map("net_amount_cents")
  discountAmountCents  Int?               @default(0) @map("discount_amount_cents")
  taxAmountCents       Int?               @map("tax_amount_cents")
  amountDueCents       Int?               @map("amount_due_cents")
  amountPaidCents      Int?               @map("amount_paid_cents")
  amountRemainingCents Int?               @map("amount_remaining_cents")
  currency             String             @default("EUR") @db.Char(3)
  status               InvoiceStatus      @default(DRAFT)
  periodStart          DateTime?          @map("period_start")
  periodEnd            DateTime?          @map("period_end")
  stripeCreatedAt      DateTime?          @map("stripe_created_at")
  finalizedAt          DateTime?          @map("finalized_at")
  invoiceDate          DateTime           @map("invoice_date")
  dueDate              DateTime?          @map("due_date")
  paidAt               DateTime?          @map("paid_at")
  voidedAt             DateTime?          @map("voided_at")
  hostedInvoiceUrl     String?            @map("hosted_invoice_url")
  invoicePdfUrl        String?            @map("invoice_pdf_url")
  customerSnapshotJson Json?              @map("customer_snapshot_json")
  companySnapshotJson  Json?              @map("company_snapshot_json")
  billingAddressJson   Json?              @map("billing_address_json")
  taxIdSnapshot        String?            @map("tax_id_snapshot")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  subscription   BillingSubscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  lines          BillingInvoiceLine[]
  payments       BillingPayment[]
  refunds        BillingRefund[]
  creditNotes    BillingCreditNote[]
  disputes       BillingDispute[]
  outboundEmails OutboundEmail[]

  @@unique([stripeInvoiceId, stripeMode])
  @@index([subscriptionId])
  @@index([invoiceNumber])
  @@map("billing_invoices")
}

/// Immutable invoice line once created (financial snapshot).
model BillingInvoiceLine {
  id                  String             @id @default(uuid())
  invoiceId           String             @map("invoice_id")
  subscriptionItemId  String?            @map("subscription_item_id")
  usageSnapshotId     String?            @map("usage_snapshot_id")
  description         String
  quantity            Int
  unitAmountCents     Int?               @map("unit_amount_cents")
  discountCents       Int?               @default(0) @map("discount_cents")
  subtotalCents       Int                @map("subtotal_cents")
  netCents            Int?               @map("net_cents")
  taxRateBps          Int?               @map("tax_rate_bps")
  taxCents            Int?               @map("tax_cents")
  totalCents          Int                @map("total_cents")
  productSnapshotJson Json?              @map("product_snapshot_json")
  priceSnapshotJson   Json?              @map("price_snapshot_json")
  discountDetailsJson Json?              @map("discount_details_json")
  taxDetailsJson      Json?              @map("tax_details_json")
  stripeInvoiceLineId String?            @map("stripe_invoice_line_id")
  stripeMode          BillingStripeMode? @map("stripe_mode")
  periodStart         DateTime?          @map("period_start")
  periodEnd           DateTime?          @map("period_end")
  createdAt           DateTime           @default(now()) @map("created_at")

  invoice          BillingInvoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscriptionItem BillingSubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: SetNull)
  usageSnapshot    BillingUsageSnapshot?    @relation(fields: [usageSnapshotId], references: [id], onDelete: SetNull)

  @@unique([stripeInvoiceLineId, stripeMode])
  @@index([invoiceId])
  @@index([subscriptionItemId])
  @@index([usageSnapshotId])
  @@map("billing_invoice_lines")
}

/// Usage snapshot for a billing period — locked rows are immutable.
model BillingUsageSnapshot {
  id                    String                        @id @default(uuid())
  organizationId        String                        @map("organization_id")
  subscriptionItemId    String?                       @map("subscription_item_id")
  periodStart           DateTime                      @map("period_start")
  periodEnd             DateTime                      @map("period_end")
  connectedVehicleCount Int                           @map("connected_vehicle_count")
  billableVehicleCount  Int                           @map("billable_vehicle_count")
  calculatedQuantity    Int?                          @map("calculated_quantity")
  calculationBasis      BillingUsageSnapshotBasis?    @map("calculation_basis")
  billableVehicleIds    Json                          @map("billable_vehicle_ids")
  excludedVehicleIds    Json                          @default("[]") @map("excluded_vehicle_ids")
  excludedReasonSummary Json?                         @map("excluded_reason_summary")
  priceBookId           String?                       @map("price_book_id")
  priceVersionId        String?                       @map("price_version_id")
  priceTierId           String?                       @map("price_tier_id")
  unitPriceCents        Int?                          @map("unit_price_cents")
  subtotalCents         Int?                          @map("subtotal_cents")
  taxCents              Int?                          @map("tax_cents")
  totalCents            Int?                          @map("total_cents")
  currency              String                        @default("EUR") @db.Char(3)
  calculationStatus     BillingUsageCalculationStatus @map("calculation_status")
  idempotencyKey        String?                       @unique @map("idempotency_key")
  discountSnapshotJson  Json?                         @map("discount_snapshot_json")
  prorationDetailsJson  Json?                         @map("proration_details_json")
  sourceHash            String?                       @map("source_hash")
  sourceRevision        Int?                          @map("source_revision")
  lockedAt              DateTime?                     @map("locked_at")
  createdByUserId       String?                       @map("created_by_user_id")
  createdAt             DateTime                      @default(now()) @map("created_at")

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionItem BillingSubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: SetNull)
  priceBook        BillingPriceBook?        @relation(fields: [priceBookId], references: [id], onDelete: SetNull)
  priceVersion     BillingPriceVersion?     @relation(fields: [priceVersionId], references: [id], onDelete: SetNull)
  priceTier        BillingPriceTier?        @relation(fields: [priceTierId], references: [id], onDelete: SetNull)
  createdByUser    User?                    @relation("BillingUsageSnapshotsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  invoiceLines     BillingInvoiceLine[]

  @@index([organizationId, periodStart])
  @@index([subscriptionItemId, periodStart])
  @@index([priceVersionId])
  @@index([lockedAt])
  @@map("billing_usage_snapshots")
}

/// Append-only assignment of a vehicle to a subscription item for billing.
model BillingBillableVehicleAssignment {
  id                 String                                 @id @default(uuid())
