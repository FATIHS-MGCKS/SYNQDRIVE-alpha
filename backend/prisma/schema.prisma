model OutboundEmailEvent {
  id                    String                 @id @default(uuid())
  outboundEmailId       String                 @map("outbound_email_id")
  eventType             OutboundEmailEventType @map("event_type")
  payload               Json?
  webhookIdempotencyKey String?                @map("webhook_idempotency_key")
