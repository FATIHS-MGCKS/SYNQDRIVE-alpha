/// SaaS payment aggregate for a billing invoice.
model BillingPayment {
  id                    String                    @id @default(uuid())
  invoiceId             String                    @map("invoice_id")
  amountCents           Int                       @map("amount_cents")
  currency              String                    @default("EUR") @db.Char(3)
  status                BillingPaymentStatus      @default(PENDING)
  provider              BillingPaymentProvider    @default(STRIPE)
  stripePaymentIntentId String?                   @map("stripe_payment_intent_id")
  stripeChargeId        String?                   @map("stripe_charge_id")
  stripePaymentMethodId String?                   @map("stripe_payment_method_id")
  stripeMode            BillingStripeMode?        @map("stripe_mode")
  attemptCount          Int                       @default(0) @map("attempt_count")
  refundedAmountCents   Int                       @default(0) @map("refunded_amount_cents")
  remainingAmountCents  Int?                      @map("remaining_amount_cents")
  succeededAt           DateTime?                 @map("succeeded_at")
  failedAt              DateTime?                 @map("failed_at")
  cancelledAt           DateTime?                 @map("cancelled_at")
  manualPaymentType     BillingManualPaymentType? @map("manual_payment_type")
  manualReference       String?                   @map("manual_reference")
  manualReceiptNote     String?                   @map("manual_receipt_note")
  recordedByUserId      String?                   @map("recorded_by_user_id")
  idempotencyKey        String?                   @unique @map("idempotency_key")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  invoice    BillingInvoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User?                   @relation("BillingPaymentsRecorded", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  attempts   BillingPaymentAttempt[]
  refunds    BillingRefund[]
  disputes   BillingDispute[]

  @@unique([stripePaymentIntentId, stripeMode])
  @@unique([stripeChargeId, stripeMode])
  @@index([invoiceId, status])
  @@index([provider, status])
  @@map("billing_payments")
}

/// Append-only payment attempt log.
model BillingPaymentAttempt {
  id               String                      @id @default(uuid())
  paymentId        String                      @map("payment_id")
  attemptNumber    Int                         @map("attempt_number")
  amountCents      Int                         @map("amount_cents")
  status           BillingPaymentAttemptStatus @default(PENDING)
  provider         BillingPaymentProvider      @default(STRIPE)
  stripeChargeId   String?                     @map("stripe_charge_id")
  stripeMode       BillingStripeMode?          @map("stripe_mode")
  errorCode        String?                     @map("error_code")
  declineCode      String?                     @map("decline_code")
  errorMessage     String?                     @map("error_message")
  safeErrorMessage String?                     @map("safe_error_message")
  nextRetryAt      DateTime?                   @map("next_retry_at")
  idempotencyKey   String?                     @unique @map("idempotency_key")
  attemptedAt      DateTime                    @default(now()) @map("attempted_at")
  createdAt        DateTime                    @default(now()) @map("created_at")

  payment BillingPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, attemptNumber])
  @@unique([stripeChargeId, stripeMode])
  @@index([paymentId, attemptedAt])
  @@map("billing_payment_attempts")
}

/// Append-only refund record.
model BillingRefund {
  id             String              @id @default(uuid())
  paymentId      String              @map("payment_id")
  invoiceId      String?             @map("invoice_id")
  amountCents    Int                 @map("amount_cents")
  currency       String              @default("EUR") @db.Char(3)
  status         BillingRefundStatus @default(PENDING)
  isPartial      Boolean             @default(false) @map("is_partial")
  reason         String?
  stripeRefundId String?             @map("stripe_refund_id")
  stripeMode     BillingStripeMode?  @map("stripe_mode")
  refundedAt     DateTime?           @map("refunded_at")
  idempotencyKey String?             @unique @map("idempotency_key")
  createdAt      DateTime            @default(now()) @map("created_at")

  payment     BillingPayment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice     BillingInvoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  creditNotes BillingCreditNote[]

  @@unique([stripeRefundId, stripeMode])
  @@index([paymentId, createdAt])
  @@index([invoiceId])
  @@map("billing_refunds")
}

/// Append-only credit note linked to invoice/refund.
model BillingCreditNote {
  id                 String                  @id @default(uuid())
  invoiceId          String                  @map("invoice_id")
  refundId           String?                 @map("refund_id")
  amountCents        Int                     @map("amount_cents")
  currency           String                  @default("EUR") @db.Char(3)
  status             BillingCreditNoteStatus @default(DRAFT)
  reason             String?
  stripeCreditNoteId String?                 @map("stripe_credit_note_id")
  stripeMode         BillingStripeMode?      @map("stripe_mode")
  hostedUrl          String?                 @map("hosted_url")
  pdfUrl             String?                 @map("pdf_url")
  issuedAt           DateTime?               @map("issued_at")
  voidedAt           DateTime?               @map("voided_at")
  idempotencyKey     String?                 @unique @map("idempotency_key")
  createdAt          DateTime                @default(now()) @map("created_at")

  invoice BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  refund  BillingRefund? @relation(fields: [refundId], references: [id], onDelete: SetNull)

  @@unique([stripeCreditNoteId, stripeMode])
  @@index([invoiceId, status])
  @@index([refundId])
  @@map("billing_credit_notes")
}

/// Stripe charge dispute mirror — safe metadata only.
model BillingDispute {
  id              String               @id @default(uuid())
  organizationId  String               @map("organization_id")
  paymentId       String?              @map("payment_id")
  invoiceId       String?              @map("invoice_id")
  amountCents     Int                  @map("amount_cents")
  currency        String               @default("EUR") @db.Char(3)
  status          BillingDisputeStatus
  reason          String?
  stripeDisputeId String?              @map("stripe_dispute_id")
  stripeChargeId  String?              @map("stripe_charge_id")
  stripeMode      BillingStripeMode?   @map("stripe_mode")
  openedAt        DateTime?            @map("opened_at")
  closedAt        DateTime?            @map("closed_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      BillingPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  invoice      BillingInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([stripeDisputeId, stripeMode])
  @@index([organizationId, status])
  @@index([stripeChargeId, stripeMode])
  @@map("billing_disputes")
}

/// Billing domain event outbox — payload immutable after insert; delivery state may advance.
model BillingDomainEventOutbox {
  id             String                         @id @default(uuid())
  eventType      String                         @map("event_type")
  aggregateType  String                         @map("aggregate_type")
  aggregateId    String                         @map("aggregate_id")
  organizationId String?                        @map("organization_id")
  payloadVersion Int                            @default(1) @map("payload_version")
  payload        Json
  occurredAt     DateTime                       @map("occurred_at")
  publishedAt    DateTime?                      @map("published_at")
  status         BillingDomainEventOutboxStatus @default(PENDING)
  retryCount     Int                            @default(0) @map("retry_count")
  nextRetryAt    DateTime?                      @map("next_retry_at")
  lastError      String?                        @map("last_error")
  lockedAt       DateTime?                      @map("locked_at")
  lockOwner      String?                        @map("lock_owner")
  idempotencyKey String                         @unique @map("idempotency_key")
  createdAt      DateTime                       @default(now()) @map("created_at")

  deliveries BillingDomainEventOutboxDelivery[]

  @@index([status, occurredAt])
  @@index([status, nextRetryAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType, occurredAt])
  @@index([organizationId, occurredAt])
  @@map("billing_domain_event_outbox")
}

/// Per-consumer delivery state — enables multiple downstream consumers later.
model BillingDomainEventOutboxDelivery {
  id            String                                 @id @default(uuid())
  outboxEventId String                                 @map("outbox_event_id")
  consumerId    String                                 @map("consumer_id")
  status        BillingDomainEventOutboxDeliveryStatus @default(PENDING)
  retryCount    Int                                    @default(0) @map("retry_count")
  nextRetryAt   DateTime?                              @map("next_retry_at")
  lastError     String?                                @map("last_error")
  deliveredAt   DateTime?                              @map("delivered_at")
  lockedAt      DateTime?                              @map("locked_at")
  lockOwner     String?                                @map("lock_owner")
  createdAt     DateTime                               @default(now()) @map("created_at")
  updatedAt     DateTime                               @updatedAt @map("updated_at")

  outboxEvent    BillingDomainEventOutbox @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)
  outboundEmails OutboundEmail[]

  @@unique([outboxEventId, consumerId])
  @@index([status, nextRetryAt])
  @@index([consumerId, status])
  @@map("billing_domain_event_outbox_deliveries")
}

model BillingPaymentMethod {
