  sentAiSuggestion WhatsAppAiSuggestion?  @relation("SentAiMessage")

  @@index([conversationId, createdAt])
  @@index([organizationId])
  @@index([providerMessageId])
  @@map("whatsapp_messages")
}

model WhatsAppWebhookEvent {
