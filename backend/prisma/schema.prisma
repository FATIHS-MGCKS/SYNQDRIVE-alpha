// ── Notification Engine (V4.9.351) — persistent lifecycle notifications ──
// Partial unique index on (organization_id, fingerprint, lifecycle_generation)
// for active statuses is defined in migration SQL — Prisma does not support partial indexes.

model Notification {
  id                  String                 @id @default(uuid())
  organizationId      String                 @map("organization_id")
  fingerprint         String
  lifecycleGeneration Int                    @default(1) @map("lifecycle_generation")
  eventType           String                 @map("event_type")
  eventKind           NotificationEventKind  @map("event_kind")
  conditionCode       String                 @map("condition_code")
  domain              NotificationDomain
  severity            NotificationSeverity
  status              NotificationStatus     @default(OPEN)
  entityType          NotificationEntityType @map("entity_type")
  entityId            String                 @map("entity_id")
  titleKey            String                 @map("title_key")
  bodyKey             String                 @map("body_key")
  templateParams      Json                   @default("{}") @map("template_params")
  actionType          NotificationActionType @map("action_type")
  actionTarget        Json                   @default("{}") @map("action_target")
  sourceType          NotificationSourceType @map("source_type")
  primarySourceRef    String                 @map("primary_source_ref")
  /// Optional backfill bridge to legacy DashboardInsight.id — not a FK to preserve migration independence.
  legacyInsightId     String?                @map("legacy_insight_id")
  firstSeenAt         DateTime               @map("first_seen_at")
  lastSeenAt          DateTime               @map("last_seen_at")
  occurrenceCount     Int                    @default(1) @map("occurrence_count")
  reopenCount         Int                    @default(0) @map("reopen_count")
  acknowledgedAt      DateTime?              @map("acknowledged_at")
  snoozedUntil        DateTime?              @map("snoozed_until")
  resolvedAt          DateTime?              @map("resolved_at")
  archivedAt          DateTime?              @map("archived_at")
  expiresAt           DateTime?              @map("expires_at")
  version             Int                    @default(1)
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  occurrences    NotificationOccurrence[]
  receipts       NotificationReceipt[]
  deliveryOutbox NotificationDeliveryOutbox[]

  @@index([organizationId, status, lastSeenAt])
  @@index([organizationId, severity, status])
  @@index([organizationId, domain, status])
  @@index([entityType, entityId])
  @@index([fingerprint])
  @@index([expiresAt])
  @@index([resolvedAt])
  @@index([organizationId, fingerprint, lifecycleGeneration])
  @@map("notifications")
}

model NotificationOccurrence {
  id                   String                 @id @default(uuid())
  notificationId       String                 @map("notification_id")
  organizationId       String                 @map("organization_id")
  occurredAt           DateTime               @map("occurred_at")
  detectedAt           DateTime               @default(now()) @map("detected_at")
  sourceType           NotificationSourceType @map("source_type")
  sourceRef            String                 @map("source_ref")
  severityAtOccurrence NotificationSeverity   @map("severity_at_occurrence")
  payload              Json?                  @map("payload")
  createdAt            DateTime               @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([notificationId, occurredAt])
  @@index([organizationId])
  @@map("notification_occurrences")
}

model NotificationReceipt {
  id             String    @id @default(uuid())
  notificationId String    @map("notification_id")
  userId         String    @map("user_id")
  organizationId String    @map("organization_id")
  readAt         DateTime? @map("read_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  snoozedUntil   DateTime? @map("snoozed_until")
  hiddenAt       DateTime? @map("hidden_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([organizationId])
  @@map("notification_receipts")
}

model NotificationDeliveryOutbox {
  id                  String                           @id @default(uuid())
  organizationId      String                           @map("organization_id")
  notificationId      String                           @map("notification_id")
  lifecycleGeneration Int                              @map("lifecycle_generation")
  eventType           String                           @map("event_type")
  deliveryTransition  NotificationDeliveryTransition   @map("delivery_transition")
  channel             NotificationDeliveryChannel
  recipientId         String?                          @map("recipient_id")
  audienceKey         String                           @map("audience_key")
