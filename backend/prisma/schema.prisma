model WhatsAppConversation {
  id                     String                     @id @default(uuid())
  organizationId         String                     @map("organization_id")
  contactPhone           String                     @map("contact_phone")
  contactPhoneNormalized String                     @map("contact_phone_normalized")
  contactName            String?                    @map("contact_name")
  phoneNumberId          String?                    @map("phone_number_id")
  customerId             String?                    @map("customer_id")
  bookingId              String?                    @map("booking_id")
  vehicleId              String?                    @map("vehicle_id")
  lastMessageAt          DateTime?                  @map("last_message_at")
  lastMessagePreview     String?                    @map("last_message_preview")
  lastCustomerMessageAt  DateTime?                  @map("last_customer_message_at")
  unreadCount            Int                        @default(0) @map("unread_count")
