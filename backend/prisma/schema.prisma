// ------------------------------------------------
// CUSTOMERS (rental/org-scoped)
// ------------------------------------------------

model Customer {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  email          String?
  phone          String?
  licenseNumber  String?        @map("license_number")
  dateOfBirth    DateTime?      @map("date_of_birth")
  address        String?
  city           String?
  country        String?
  status         CustomerStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings              Booking[]
  rentalDrivingAnalyses RentalDrivingAnalysis[]

  @@index([organizationId])
  @@index([email])
  @@map("customers")
}

// ------------------------------------------------
// BOOKINGS
// ------------------------------------------------

model Booking {
  id               String        @id @default(uuid())
  organizationId   String        @map("organization_id")
  customerId       String        @map("customer_id")
  vehicleId        String        @map("vehicle_id")
  pickupStationId  String?       @map("pickup_station_id")
  returnStationId  String?       @map("return_station_id")
  startDate        DateTime      @map("start_date")
  endDate          DateTime      @map("end_date")
  dailyRateCents   Int?          @map("daily_rate_cents")
  totalPriceCents  Int?          @map("total_price_cents")
  kmIncluded       Int?          @map("km_included")
  kmDriven         Int?          @map("km_driven")
  insuranceOptions Json?         @map("insurance_options")
  extrasJson       Json?         @map("extras_json")
  currency         String        @default("eur")
  status           BookingStatus @default(PENDING)
  notes            String?
  cancelledAt      DateTime?     @map("cancelled_at")
  completedAt      DateTime?     @map("completed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer              Customer               @relation(fields: [customerId], references: [id])
  vehicle               Vehicle                @relation(fields: [vehicleId], references: [id])
  rentalDrivingAnalysis RentalDrivingAnalysis?

  @@index([organizationId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
  // Service-window detector and availability lookups filter by
  // vehicleId + status + startDate.
  @@index([vehicleId, status, startDate])
  @@index([organizationId, status])
  @@map("bookings")
}

// ------------------------------------------------
// RENTAL DRIVING ANALYSIS (stored per completed rental period)
// ------------------------------------------------

model RentalDrivingAnalysis {
  id                  String   @id @default(uuid())
  organizationId      String   @map("organization_id")
  bookingId           String   @unique @map("booking_id")
  vehicleId           String   @map("vehicle_id")
  driverId            String   @map("driver_id")
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  payload             Json     @map("payload")
  overallLevel        String   @map("overall_level")
  driverStyleCategory String   @map("driver_style_category")
  riskLevel           String   @map("risk_level")
  drivingScore        Float?   @map("driving_score")
  drivingEventsCount  Int?     @map("driving_events_count")
  abuseDetectionCount Int?     @map("abuse_detection_count")
  wearImpact          String?  @map("wear_impact")
  createdAt           DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Customer     @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([periodStart, periodEnd])
  @@map("rental_driving_analyses")
}

// ------------------------------------------------
// ACTIVITY LOG
// ------------------------------------------------

model ActivityLog {
  id             String         @id @default(uuid())
  organizationId String?        @map("organization_id")
  userId         String?        @map("user_id")
  action         ActivityAction
  entity         ActivityEntity
  entityId       String?        @map("entity_id")
  description    String
  // Extended fields for trust/audit layer
  changeSummary  String?        @map("change_summary") // brief human-readable what changed
  route          String?        @map("route") // HTTP route that triggered the action
  userAgent      String?        @map("user_agent")
  level          String?        @map("level") // INFO | WARN | CRITICAL
  metaJson       Json?          @map("meta_json")
  ipAddress      String?        @map("ip_address")
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([entity, action])
  @@index([createdAt])
  @@index([level])
  // Per-org timeline is the dominant ActivityLog access pattern.
  @@index([organizationId, createdAt])
  @@map("activity_logs")
}

// ------------------------------------------------
// SUPPORT TICKETS
// ------------------------------------------------

model SupportTicket {
