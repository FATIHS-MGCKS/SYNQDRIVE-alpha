// ------------------------------------------------
// TASKS
// ------------------------------------------------

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model OrgTask {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  title           String
  description     String?
  category        String?
  status          TaskStatus   @default(OPEN)
  priority        TaskPriority @default(MEDIUM)
  vehicleId       String?      @map("vehicle_id")
  fineId          String?      @map("fine_id")
  invoiceId       String?      @map("invoice_id")
  assignedTo      String?      @map("assigned_to")
  dueDate         DateTime?    @map("due_date")
  completedAt     DateTime?    @map("completed_at")
  createdByUserId String?      @map("created_by_user_id")
  updatedByUserId String?      @map("updated_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  fine    Fine?       @relation(fields: [fineId], references: [id], onDelete: SetNull)
  invoice OrgInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([fineId])
  @@index([invoiceId])
  @@index([createdByUserId])
  // Task list is per-org filtered by status; dueDate is the common sort.
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@map("org_tasks")
}

// ------------------------------------------------
// ORG INVOICES
// ------------------------------------------------

enum OrgInvoiceType {
  OUTGOING_BOOKING
  OUTGOING_MANUAL
  INCOMING_VENDOR
  INCOMING_UPLOADED
}

enum OrgInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model OrgInvoice {
  id             String           @id @default(uuid())
  invoiceNumber  Int              @unique @default(autoincrement()) @map("invoice_number")
  organizationId String           @map("organization_id")
  type           OrgInvoiceType
  customerId     String?          @map("customer_id")
  vendorName     String?          @map("vendor_name")
  bookingId      String?          @map("booking_id")
  vehicleId      String?          @map("vehicle_id")
  title          String
  description    String?
  lineItems      Json?            @map("line_items")
  subtotalCents  Int              @default(0) @map("subtotal_cents")
  taxCents       Int              @default(0) @map("tax_cents")
  totalCents     Int              @map("total_cents")
  currency       String           @default("EUR")
  invoiceDate    DateTime         @default(now()) @map("invoice_date")
  dueDate        DateTime?        @map("due_date")
  status         OrgInvoiceStatus @default(DRAFT)
  templateId     String?          @map("template_id")
  imageUrl       String?          @map("image_url")
  extractedData  Json?            @map("extracted_data")
  notes          String?
  paidAt         DateTime?        @map("paid_at")
  createdAt      DateTime         @default(now()) @map("created_at")
