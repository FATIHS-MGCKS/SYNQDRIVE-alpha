  classificationMode        DocumentExtractionClassificationMode @default(MANUAL) @map("classification_mode")
  detectedDocumentType      DocumentExtractionType?              @map("detected_document_type")
  classificationConfidence  Decimal?                             @map("classification_confidence") @db.Decimal(5, 4)
  status                    DocumentExtractionStatus             @default(PENDING) @map("status")
  processingStage           DocumentExtractionStage              @default(UPLOAD) @map("processing_stage")
  errorPhase                DocumentExtractionErrorPhase?        @map("error_phase")
  errorCode                 String?                              @map("error_code")
  processingAttempts        Int                                  @default(0) @map("processing_attempts")
  ocrProvider               String?                              @map("ocr_provider")
  ocrModel                  String?                              @map("ocr_model")
  extractionProvider        String?                              @map("extraction_provider")
  extractionModel           String?                              @map("extraction_model")
  ocrPageCount              Int?                                 @map("ocr_page_count")
  sourceFileName            String?                              @map("source_file_name")
  sourceFileUrl             String?                              @map("source_file_url")
  // Private object-storage key for the stored upload (NOT publicly served).
  // sourceFileUrl is kept for backward compatibility / domain apply links.
  objectKey                 String?                              @map("object_key")
  storageProvider           String?                              @map("storage_provider")
  mimeType                  String?                              @map("mime_type")
  sizeBytes                 Int?                                 @map("size_bytes")
  extractedData             Json?                                @map("extracted_data")
  // Plausibility result produced by the worker (informational; never blocks storage).
  plausibility              Json?                                @map("plausibility")
  confirmedData             Json?                                @map("confirmed_data")
  errorMessage              String?                              @map("error_message")
  queuedAt                  DateTime?                            @map("queued_at")
  processedAt               DateTime?                            @map("processed_at")
  appliedAt                 DateTime?                            @map("applied_at")
  processingStartedAt       DateTime?                            @map("processing_started_at")
  ocrCompletedAt            DateTime?                            @map("ocr_completed_at")
  classificationCompletedAt DateTime?                            @map("classification_completed_at")
  extractionCompletedAt     DateTime?                            @map("extraction_completed_at")
  processingCompletedAt     DateTime?                            @map("processing_completed_at")
  nextRetryAt               DateTime?                            @map("next_retry_at")
  cancelledAt               DateTime?                            @map("cancelled_at")
  cancelledById             String?                              @map("cancelled_by_id")
  confirmedById             String?                              @map("confirmed_by_id")
  appliedById               String?                              @map("applied_by_id")
  fileDeletedById           String?                              @map("file_deleted_by_id")
  fileDeletedAt             DateTime?                            @map("file_deleted_at")
  createdById               String?                              @map("created_by_id")
  serviceEventId            String?                              @map("service_event_id")
  createdAt                 DateTime                             @default(now()) @map("created_at")
  updatedAt                 DateTime                             @updatedAt @map("updated_at")

  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  batteryEvidence BatteryEvidence[]
  brakeEvidence   BrakeEvidence[]

  @@index([vehicleId])
  @@index([status])
  @@index([organizationId, createdAt])
  @@index([vehicleId, createdAt])
  @@index([status, updatedAt])
  @@map("vehicle_document_extractions")
}

// ------------------------------------------------
// VEHICLE ENRICHMENT JOBS
// ------------------------------------------------

model VehicleEnrichmentJob {
  id           String              @id @default(uuid())
  vehicleId    String?             @map("vehicle_id")
  jobType      EnrichmentJobType   @map("job_type")
  status       EnrichmentJobStatus @default(PENDING)
  attempts     Int                 @default(0)
  resultJson   Json?               @map("result_json")
  errorMessage String?             @map("error_message")
  startedAt    DateTime?           @map("started_at")
  completedAt  DateTime?           @map("completed_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([status])
  @@index([jobType])
  @@map("vehicle_enrichment_jobs")
}

// ------------------------------------------------
// DIMO TELEMETRY — LATEST STATE
// ------------------------------------------------

model VehicleLatestState {
  id                                    String    @id @default(uuid())
  vehicleId                             String    @unique @map("vehicle_id")
  dimoTokenId                           Int?      @map("dimo_token_id")
  source                                String    @default("dimo")
  lastSeenAt                            DateTime? @map("last_seen_at")
  online                                Boolean   @default(false)
  latitude                              Float?
  longitude                             Float?
  speedKmh                              Float?    @map("speed_kmh")
  odometerKm                            Float?    @map("odometer_km")
  oilLevelRelative                      Float?    @map("oil_level_relative")
  defLevel                              Float?    @map("def_level")
  rangeKm                               Float?    @map("range_km")
  tirePressureFl                        Float?    @map("tire_pressure_fl")
  tirePressureFr                        Float?    @map("tire_pressure_fr")
  tirePressureRl                        Float?    @map("tire_pressure_rl")
  tirePressureRr                        Float?    @map("tire_pressure_rr")
  tireHealthPercent                     Float?    @map("tire_health_percent")
  evSoc                                 Float?    @map("ev_soc")
  /// Traction battery power (kW). DIMO: powertrainTractionBatteryCurrentPower in W → /1000. Positive = into battery (charge/regen); negative = out (motoring).
  tractionBatteryPowerKw                Float?    @map("traction_battery_power_kw")
  /// Provider-reported HV battery SOH (%) when available.
  tractionBatterySohPercent             Float?    @map("traction_battery_soh_percent")
  /// Average HV battery temperature in Celsius.
  tractionBatteryTemperatureC           Float?    @map("traction_battery_temperature_c")
  /// Charging power in kW while charging.
  tractionBatteryChargingPowerKw        Float?    @map("traction_battery_charging_power_kw")
  /// Added charging energy for current session in kWh.
  tractionBatteryAddedEnergyKwh         Float?    @map("traction_battery_added_energy_kwh")
  /// Whether charging is currently active.
  tractionBatteryIsCharging             Boolean?  @map("traction_battery_is_charging")
  /// Whether charging cable is currently connected.
  tractionBatteryChargingCableConnected Boolean?  @map("traction_battery_charging_cable_connected")
  /// Current HV battery voltage.
  tractionBatteryCurrentVoltage         Float?    @map("traction_battery_current_voltage")
  /// Provider-reported gross HV capacity in kWh.
  tractionBatteryGrossCapacityKwh       Float?    @map("traction_battery_gross_capacity_kwh")
  /// Provider-reported current HV battery energy in kWh.
  tractionBatteryCurrentEnergyKwh       Float?    @map("traction_battery_current_energy_kwh")
  isIgnitionOn                          Boolean?  @map("is_ignition_on")
  engineLoad                            Float?    @map("engine_load")
  lvBatteryVoltage                      Float?    @map("lv_battery_voltage")
  fuelLevelRelative                     Float?    @map("fuel_level_relative")
  fuelLevelAbsolute                     Float?    @map("fuel_level_absolute")
  coolantTempC                          Float?    @map("coolant_temp_c")
  brakePadPercent                       Float?    @map("brake_pad_percent")
  engineOilPercent                      Float?    @map("engine_oil_percent")
  obdDtcList                            Json?     @map("obd_dtc_list")
  lastDtcPollAt                         DateTime? @map("last_dtc_poll_at")
  lastDtcSuccessfulCheckAt              DateTime? @map("last_dtc_successful_check_at")
  dtcPollStatus                         String?   @map("dtc_poll_status")
  dtcPollError                          String?   @map("dtc_poll_error")
  rawPayloadJson                        Json?     @map("raw_payload_json")
  // Provenance fields — identify where this state came from
  providerSource                        String?   @map("provider_source") // e.g. DIMO | HIGH_MOBILITY
  providerFetchedAt                     DateTime? @map("provider_fetched_at") // when the data was fetched from provider
  sourceTimestamp                       DateTime? @map("source_timestamp") // timestamp reported by the provider signal itself
  syncJobRef                            String?   @map("sync_job_ref") // poll log id / worker run ref
  providerBindingId                     String?   @map("provider_binding_id") // VehicleDataSourceLink.id that sourced this
  updatedAt                             DateTime  @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_latest_states")
}

// ------------------------------------------------
// DIMO TELEMETRY — POSITION UPDATES
// ------------------------------------------------

model VehiclePositionUpdate {
  id         String   @id @default(uuid())
  vehicleId  String   @map("vehicle_id")
  latitude   Float
  longitude  Float
  source     String   @default("dimo")
  recordedAt DateTime @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, recordedAt])
  @@map("vehicle_position_updates")
}

// ------------------------------------------------
// DIMO TELEMETRY — ANALYTICS CACHE
// ------------------------------------------------

model AnalyticsCache {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  chartType   String   @map("chart_type")
  rangeFrom   DateTime @map("range_from")
  rangeTo     DateTime @map("range_to")
  interval    String?
  source      String   @default("dimo")
  cacheKey    String   @unique @map("cache_key")
  payloadJson Json     @map("payload_json")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([cacheKey])
  @@index([expiresAt])
  @@map("analytics_cache")
}

// ------------------------------------------------
// DIMO TELEMETRY — POLL LOGS
// ------------------------------------------------

model DimoPollLog {
  id             String          @id @default(uuid())
  vehicleId      String?         @map("vehicle_id")
  jobType        DimoPollJobType @map("job_type")
  status         DimoPollStatus
  startedAt      DateTime        @map("started_at")
  finishedAt     DateTime?       @map("finished_at")
  durationMs     Int?            @map("duration_ms")
  tokenRefreshed Boolean         @default(false) @map("token_refreshed")
  errorMessage   String?         @map("error_message")
  errorCode      String?         @map("error_code")
  retryCount     Int             @default(0) @map("retry_count")
  metaJson       Json?           @map("meta_json")
  createdAt      DateTime        @default(now()) @map("created_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([jobType])
  @@index([createdAt])
  // Admin dashboard paginates polls per vehicle by createdAt desc.
  @@index([vehicleId, createdAt])
  @@map("dimo_poll_logs")
}

// ------------------------------------------------
// INTEGRATIONS
// ------------------------------------------------

model Integration {
  id           String           @id @default(uuid())
  type         IntegrationType
  scope        IntegrationScope
  name         String
  description  String?
  configSchema Json?            @map("config_schema")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  orgIntegrations OrganizationIntegration[]

  @@unique([type, scope])
  @@map("integrations")
}

model OrganizationIntegration {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  integrationId  String            @map("integration_id")
  status         IntegrationStatus @default(INACTIVE)
  credentials    Json?
  configJson     Json?             @map("config_json")
  lastSyncAt     DateTime?         @map("last_sync_at")
  errorMessage   String?           @map("error_message")
  connectedAt    DateTime?         @map("connected_at")
  disconnectedAt DateTime?         @map("disconnected_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  Integration  @relation(fields: [integrationId], references: [id])

  @@unique([organizationId, integrationId])
  @@index([organizationId])
  @@map("organization_integrations")
}

// ------------------------------------------------
// BILLING
// ------------------------------------------------

/// Canonical SaaS billing product catalog (distinct from org licensing `products`).
model BillingCatalogProduct {
  id                 String               @id @default(uuid())
  key                String               @unique
  name               String
  description        String?
  productRole        BillingProductRole   @map("product_role")
  status             BillingCatalogStatus @default(ACTIVE)
  sortOrder          Int                  @default(0) @map("sort_order")
  allowMultipleItems Boolean              @default(false) @map("allow_multiple_items")
  metadata           Json?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  priceBooks            BillingPriceBook[]
  stripeMappings        BillingStripePriceMapping[]
  stripeCatalogMappings BillingStripeCatalogMapping[]
  subscriptionItems     BillingSubscriptionItem[]

  @@index([status, sortOrder])
  @@map("billing_catalog_products")
}

model BillingPriceBook {
  id               String                 @id @default(uuid())
  name             String
  productKey       String                 @map("product_key")
  billingProductId String?                @map("billing_product_id")
  billingModel     BillingModel           @default(PER_CONNECTED_VEHICLE) @map("billing_model")
  interval         BillingInterval        @default(MONTHLY)
  currency         String                 @default("EUR") @db.Char(3)
  status           BillingPriceBookStatus @default(ACTIVE)
  internalLabel    String?                @map("internal_label")
  isDefault        Boolean                @default(false) @map("is_default")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  billingProduct        BillingCatalogProduct?             @relation(fields: [billingProductId], references: [id], onDelete: SetNull)
  versions              BillingPriceVersion[]
  usageSnapshots        BillingUsageSnapshot[]
  orgPriceOverrides     BillingOrganizationPriceOverride[]
  subscriptions         BillingSubscription[]
  subscriptionItems     BillingSubscriptionItem[]
  stripeMappings        BillingStripePriceMapping[]
  stripeCatalogMappings BillingStripeCatalogMapping[]

  @@index([productKey])
  @@index([billingProductId])
  @@index([isDefault])
  @@index([status])
  @@map("billing_price_books")
}

model BillingPriceVersion {
  id                String                    @id @default(uuid())
  priceBookId       String                    @map("price_book_id")
  versionNumber     Int                       @map("version_number")
  versionLabel      String?                   @map("version_label")
  status            BillingPriceVersionStatus @default(DRAFT)
  effectiveFrom     DateTime?                 @map("effective_from")
  effectiveTo       DateTime?                 @map("effective_to")
  tierMode          BillingTierMode           @default(VOLUME) @map("tier_mode")
  createdByUserId   String?                   @map("created_by_user_id")
  publishedByUserId String?                   @map("published_by_user_id")
  publishedAt       DateTime?                 @map("published_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  priceBook             BillingPriceBook                   @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  createdByUser         User?                              @relation("BillingPriceVersionsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedByUser       User?                              @relation("BillingPriceVersionsPublished", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  tiers                 BillingPriceTier[]
  usageSnapshots        BillingUsageSnapshot[]
  orgPriceOverrides     BillingOrganizationPriceOverride[]
  subscriptions         BillingSubscription[]
  subscriptionItems     BillingSubscriptionItem[]
  stripeCatalogMappings BillingStripeCatalogMapping[]

  @@unique([priceBookId, versionNumber])
  @@index([priceBookId, status])
  @@index([status, publishedAt])
  @@map("billing_price_versions")
}

/// Quantity tiers for a price version. `minVehicles`/`maxVehicles` are the billable quantity axis for per-vehicle SaaS pricing.
model BillingPriceTier {
  id             String   @id @default(uuid())
  priceVersionId String   @map("price_version_id")
  minVehicles    Int      @map("min_vehicles")
  maxVehicles    Int?     @map("max_vehicles")
  unitPriceCents Int?     @map("unit_price_cents")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceVersion      BillingPriceVersion       @relation(fields: [priceVersionId], references: [id], onDelete: Cascade)
  usageSnapshots    BillingUsageSnapshot[]
  subscriptionItems BillingSubscriptionItem[]

  @@index([priceVersionId, sortOrder])
  @@map("billing_price_tiers")
}

/// Stripe Product/Price mapping per pricebook. TEST and LIVE are strictly separated.
model BillingStripePriceMapping {
  id               String                     @id @default(uuid())
  priceBookId      String                     @map("price_book_id")
  billingProductId String?                    @map("billing_product_id")
  stripeMode       BillingStripeMode          @map("stripe_mode")
  stripeProductId  String?                    @map("stripe_product_id")
  stripePriceId    String?                    @map("stripe_price_id")
  mappingStatus    BillingStripeMappingStatus @default(PENDING) @map("mapping_status")
  lastSyncedAt     DateTime?                  @map("last_synced_at")
  lastError        String?                    @map("last_error")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  priceBook      BillingPriceBook       @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  billingProduct BillingCatalogProduct? @relation(fields: [billingProductId], references: [id], onDelete: SetNull)

  @@unique([priceBookId, stripeMode])
  @@unique([stripePriceId, stripeMode])
  @@index([billingProductId])
  @@index([mappingStatus])
  @@index([stripeProductId, stripeMode])
  @@map("billing_stripe_price_mappings")
}

/// Explicit Stripe catalog mapping per billing product + published price version and mode.
model BillingStripeCatalogMapping {
  id                 String                     @id @default(uuid())
  billingProductId   String                     @map("billing_product_id")
  priceVersionId     String                     @map("price_version_id")
  priceBookId        String                     @map("price_book_id")
  stripeMode         BillingStripeMode          @map("stripe_mode")
  stripeProductId    String                     @map("stripe_product_id")
  stripePriceId      String                     @map("stripe_price_id")
  currency           String                     @db.Char(3)
  billingInterval    BillingInterval            @map("billing_interval")
  billingModel       BillingModel               @default(PER_CONNECTED_VEHICLE) @map("billing_model")
  stripePresentation String                     @default("recurring_per_unit") @map("stripe_presentation")
  mappingStatus      BillingStripeMappingStatus @default(PENDING) @map("mapping_status")
  lastVerifiedAt     DateTime?                  @map("last_verified_at")
  lastError          String?                    @map("last_error")
  disabledAt         DateTime?                  @map("disabled_at")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  billingProduct BillingCatalogProduct @relation(fields: [billingProductId], references: [id], onDelete: Restrict)
  priceVersion   BillingPriceVersion   @relation(fields: [priceVersionId], references: [id], onDelete: Cascade)
  priceBook      BillingPriceBook      @relation(fields: [priceBookId], references: [id], onDelete: Cascade)

  @@unique([priceVersionId, stripeMode])
  @@unique([stripePriceId, stripeMode])
  @@index([billingProductId, stripeMode])
  @@index([priceBookId, stripeMode])
  @@index([mappingStatus])
  @@map("billing_stripe_catalog_mappings")
}

model BillingSubscription {
  id                   String                     @id @default(uuid())
  organizationId       String                     @map("organization_id")
  stripeSubscriptionId String?                    @map("stripe_subscription_id")
  stripeCustomerId     String?                    @map("stripe_customer_id")
  stripeMode           BillingStripeMode?         @map("stripe_mode")
  status               BillingStatus              @default(ACTIVE)
  trialStartAt         DateTime?                  @map("trial_start_at")
  trialEndAt           DateTime?                  @map("trial_end_at")
  startedAt            DateTime?                  @map("started_at")
  endedAt              DateTime?                  @map("ended_at")
  cancelAt             DateTime?                  @map("cancel_at")
  currentPeriodStart   DateTime?                  @map("current_period_start")
  currentPeriodEnd     DateTime?                  @map("current_period_end")
  cancelAtPeriodEnd    Boolean                    @default(false) @map("cancel_at_period_end")
  billingAnchorDay     Int?                       @map("billing_anchor_day")
  currency             String                     @default("EUR") @db.Char(3)
  priceBookId          String?                    @map("price_book_id")
  priceVersionId       String?                    @map("price_version_id")
  lockVersion          Int                        @default(0) @map("lock_version")
  stripeSyncStatus     BillingStripeMappingStatus @default(PENDING) @map("stripe_sync_status")
  lastStripeSyncedAt   DateTime?                  @map("last_stripe_synced_at")
  lastStripeSyncError  String?                    @map("last_stripe_sync_error")
  createdByUserId      String?                    @map("created_by_user_id")
  updatedByUserId      String?                    @map("updated_by_user_id")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  priceBook      BillingPriceBook?         @relation(fields: [priceBookId], references: [id], onDelete: SetNull)
  priceVersion   BillingPriceVersion?      @relation(fields: [priceVersionId], references: [id], onDelete: SetNull)
  createdByUser  User?                     @relation("BillingSubscriptionsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser  User?                     @relation("BillingSubscriptionsUpdated", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  invoices       BillingInvoice[]
  items          BillingSubscriptionItem[]
  discounts      BillingDiscount[]
  quantityEvents BillingQuantityEvent[]
  outboundEmails OutboundEmail[]

  reconciliationDrifts BillingReconciliationDrift[]

  @@unique([stripeSubscriptionId, stripeMode])
  @@unique([stripeCustomerId, stripeMode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([priceBookId])
  @@index([stripeSyncStatus])
  @@map("billing_subscriptions")
}

/// Contract line item — base plan (Rental/Fleet) or add-on. Historical ENDED items do not block new tariffs.
model BillingSubscriptionItem {
  id                       String                        @id @default(uuid())
  subscriptionId           String                        @map("subscription_id")
  organizationId           String                        @map("organization_id")
  billingProductId         String                        @map("billing_product_id")
  itemRole                 BillingSubscriptionItemRole   @map("item_role")
  priceBookId              String?                       @map("price_book_id")
  priceVersionId           String?                       @map("price_version_id")
  priceTierId              String?                       @map("price_tier_id")
  quantity                 Int                           @default(0)
  validFrom                DateTime                      @map("valid_from")
  validTo                  DateTime?                     @map("valid_to")
  status                   BillingSubscriptionItemStatus @default(DRAFT)
  stripeSubscriptionItemId String?                       @map("stripe_subscription_item_id")
  stripeMode               BillingStripeMode?            @map("stripe_mode")
  prorationBehavior        BillingProrationBehavior      @default(CREATE_PRORATIONS) @map("proration_behavior")
  metadata                 Json?
  createdAt                DateTime                      @default(now()) @map("created_at")
  updatedAt                DateTime                      @updatedAt @map("updated_at")

  subscription               BillingSubscription                @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization               Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingProduct             BillingCatalogProduct              @relation(fields: [billingProductId], references: [id], onDelete: Restrict)
  priceBook                  BillingPriceBook?                  @relation(fields: [priceBookId], references: [id], onDelete: SetNull)
  priceVersion               BillingPriceVersion?               @relation(fields: [priceVersionId], references: [id], onDelete: SetNull)
  priceTier                  BillingPriceTier?                  @relation(fields: [priceTierId], references: [id], onDelete: SetNull)
  discounts                  BillingDiscount[]
  quantityEvents             BillingQuantityEvent[]
  usageSnapshots             BillingUsageSnapshot[]
  billableVehicleAssignments BillingBillableVehicleAssignment[]
  invoiceLines               BillingInvoiceLine[]

  @@unique([stripeSubscriptionItemId, stripeMode])
  @@index([subscriptionId, status])
  @@index([organizationId, itemRole, status])
  @@index([billingProductId])
  @@index([priceVersionId])
  @@map("billing_subscription_items")
}

/// Subscription-level discount (replaces ad-hoc overrides over time; legacy overrides remain).
model BillingDiscount {
  id                    String                @id @default(uuid())
  subscriptionId        String                @map("subscription_id")
  subscriptionItemId    String?               @map("subscription_item_id")
  discountType          BillingDiscountType   @map("discount_type")
  percentBps            Int?                  @map("percent_bps")
  fixedAmountCents      Int?                  @map("fixed_amount_cents")
  currency              String?               @db.Char(3)
  validFrom             DateTime              @map("valid_from")
  validTo               DateTime?             @map("valid_to")
  reason                String?
  status                BillingDiscountStatus @default(ACTIVE)
  stripeMode            BillingStripeMode?    @map("stripe_mode")
  stripeCouponId        String?               @map("stripe_coupon_id")
  stripePromotionCodeId String?               @map("stripe_promotion_code_id")
  createdByUserId       String?               @map("created_by_user_id")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  subscription     BillingSubscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionItem BillingSubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: SetNull)
  createdByUser    User?                    @relation("BillingDiscountsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([stripeCouponId, stripeMode])
  @@unique([stripePromotionCodeId, stripeMode])
  @@index([subscriptionId, status])
  @@index([subscriptionItemId])
