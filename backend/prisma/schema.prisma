  engineLoad                            Float?    @map("engine_load")
  lvBatteryVoltage                      Float?    @map("lv_battery_voltage")
  fuelLevelRelative                     Float?    @map("fuel_level_relative")
  fuelLevelAbsolute                     Float?    @map("fuel_level_absolute")
  coolantTempC                          Float?    @map("coolant_temp_c")
  brakePadPercent                       Float?    @map("brake_pad_percent")
  engineOilPercent                      Float?    @map("engine_oil_percent")
  obdDtcList                            Json?     @map("obd_dtc_list")
  lastDtcPollAt                         DateTime? @map("last_dtc_poll_at")
  lastDtcSuccessfulCheckAt              DateTime? @map("last_dtc_successful_check_at")
  dtcPollStatus                         String?   @map("dtc_poll_status")
  dtcPollError                          String?   @map("dtc_poll_error")
  rawPayloadJson                        Json?     @map("raw_payload_json")
  // Provenance fields — identify where this state came from
  providerSource                        String?   @map("provider_source") // e.g. DIMO | HIGH_MOBILITY
  providerFetchedAt                     DateTime? @map("provider_fetched_at") // when the data was fetched from provider
  sourceTimestamp                       DateTime? @map("source_timestamp") // timestamp reported by the provider signal itself
  syncJobRef                            String?   @map("sync_job_ref") // poll log id / worker run ref
  providerBindingId                     String?   @map("provider_binding_id") // VehicleDataSourceLink.id that sourced this
  updatedAt                             DateTime  @updatedAt @map("updated_at")

