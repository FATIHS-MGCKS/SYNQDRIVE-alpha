  SERVICE_PARTNER
  PAINT_SHOP
  BODY_REPAIR
  AUTO_GLASS
  TIRE_DEALER
  PARTS_DEALER
  DETAILING
  TUV_STATION
  ONLINE_SUPPLIER
  OTHER
}

enum VendorSourceType {
