// ── Brake Health V2 ────────────────────────────────────────────────────────────
//
// Achsweise (front/rear) pad + disc state per vehicle.
// Only populated AFTER a valid brake service anchor exists.

model BrakeHealthCurrent {
  vehicleId      String  @id @map("vehicle_id")
  organizationId String? @map("organization_id")

  isInitialized Boolean @default(false) @map("is_initialized")

  // Anchor data
  anchorServiceDate DateTime? @map("anchor_service_date")
  anchorOdometerKm  Float?    @map("anchor_odometer_km")

  // Front pads
  frontPadAnchorMm        Float? @map("front_pad_anchor_mm")
  frontPadEstimatedMm     Float? @map("front_pad_estimated_mm")
  frontPadHealthPct       Float? @map("front_pad_health_pct")
  frontPadRemainingKm     Float? @map("front_pad_remaining_km")
  frontPadWearRateMmPerKm Float? @map("front_pad_wear_rate_mm_per_km")
  frontPadKFactor         Float  @default(1.0) @map("front_pad_k_factor")

  // Rear pads
  rearPadAnchorMm        Float? @map("rear_pad_anchor_mm")
  rearPadEstimatedMm     Float? @map("rear_pad_estimated_mm")
  rearPadHealthPct       Float? @map("rear_pad_health_pct")
  rearPadRemainingKm     Float? @map("rear_pad_remaining_km")
  rearPadWearRateMmPerKm Float? @map("rear_pad_wear_rate_mm_per_km")
  rearPadKFactor         Float  @default(1.0) @map("rear_pad_k_factor")

  // Front discs
  frontDiscAnchorMm        Float? @map("front_disc_anchor_mm")
  frontDiscEstimatedMm     Float? @map("front_disc_estimated_mm")
  frontDiscHealthPct       Float? @map("front_disc_health_pct")
  frontDiscRemainingKm     Float? @map("front_disc_remaining_km")
  frontDiscWearRateMmPerKm Float? @map("front_disc_wear_rate_mm_per_km")
  frontDiscKFactor         Float  @default(1.0) @map("front_disc_k_factor")

  // Rear discs
  rearDiscAnchorMm        Float? @map("rear_disc_anchor_mm")
  rearDiscEstimatedMm     Float? @map("rear_disc_estimated_mm")
  rearDiscHealthPct       Float? @map("rear_disc_health_pct")
  rearDiscRemainingKm     Float? @map("rear_disc_remaining_km")
  rearDiscWearRateMmPerKm Float? @map("rear_disc_wear_rate_mm_per_km")
  rearDiscKFactor         Float  @default(1.0) @map("rear_disc_k_factor")

  // Set-level
  padsHealthPct    Float? @map("pads_health_pct")
  padsRemainingKm  Float? @map("pads_remaining_km")
  discsHealthPct   Float? @map("discs_health_pct")
  discsRemainingKm Float? @map("discs_remaining_km")

  confidenceScore Float?  @map("confidence_score")
  confidenceLabel String? @map("confidence_label")
  hasAlert        Boolean @default(false) @map("has_alert")

  stateClass             String? @map("state_class")
  anchorValidationStatus String? @map("anchor_validation_status")
  modelCoverageRatio     Float?  @map("model_coverage_ratio")
  modeledDistanceKm      Float?  @map("modeled_distance_km")
  modeledTripCount       Int?    @map("modeled_trip_count")
  modelingSource         String? @map("modeling_source")
  baselineWarnings       Json?   @map("baseline_warnings")

  distanceSinceAnchorKm Float? @map("distance_since_anchor_km")
  calibrationCount      Int    @default(0) @map("calibration_count")
  modelVersion          String @default("1.0.0") @map("model_version")

  lastRecalculatedAt DateTime? @map("last_recalculated_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId])
  @@map("brake_health_current")
}

// ------------------------------------------------
// VEHICLE DTC EVENTS (Error Codes)
// ------------------------------------------------

model VehicleDtcEvent {
  id              String      @id @default(uuid())
  vehicleId       String      @map("vehicle_id")
  dtcCode         String      @map("dtc_code")
  description     String?
  severity        DtcSeverity @default(WARNING)
  isActive        Boolean     @default(true) @map("is_active")
  firstSeenAt     DateTime    @map("first_seen_at")
  lastSeenAt      DateTime    @map("last_seen_at")
  clearedAt       DateTime?   @map("cleared_at")
  occurrenceCount Int         @default(1) @map("occurrence_count")
  rawPayload      Json?       @map("raw_payload")
  createdAt       DateTime    @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([dtcCode])
  @@index([isActive])
  @@index([firstSeenAt])
  // Hot queries: `findByVehicle` orders by lastSeenAt desc; summary counts
  // active faults for a vehicle. Composite indexes avoid a heap fetch + sort.
  @@index([vehicleId, lastSeenAt])
  @@index([vehicleId, isActive])
  @@map("vehicle_dtc_events")
}

