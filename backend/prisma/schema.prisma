  fileName            String   @map("file_name")
  mimeType            String   @map("mime_type")
  sizeBytes           Int?     @map("size_bytes")
  documentType        String?  @map("document_type")
  createdAt           DateTime @default(now()) @map("created_at")

  outboundEmail     OutboundEmail      @relation(fields: [outboundEmailId], references: [id], onDelete: Cascade)
  generatedDocument GeneratedDocument? @relation(fields: [generatedDocumentId], references: [id], onDelete: SetNull)

  @@index([outboundEmailId])
  @@index([generatedDocumentId])
  @@map("outbound_email_attachments")
