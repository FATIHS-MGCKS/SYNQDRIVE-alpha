  valueType            BatteryEvidenceValueType  @map("value_type")
  numericValue         Float                     @map("numeric_value")
  unit                 String?
  observedAt           DateTime                  @map("observed_at")
  provider             String?
  confidence           String?
  quality              String?
  documentExtractionId String?                   @map("document_extraction_id")
  serviceEventId       String?                   @map("service_event_id")
  metadataJson         Json?                     @map("metadata_json")
  createdAt            DateTime                  @default(now()) @map("created_at")

  vehicle            Vehicle                    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentExtraction VehicleDocumentExtraction? @relation(fields: [documentExtractionId], references: [id], onDelete: SetNull)
  serviceEvent       VehicleServiceEvent?       @relation(fields: [serviceEventId], references: [id], onDelete: SetNull)

  @@unique([vehicleId, scope, valueType, sourceType, observedAt], name: "battery_evidence_dedup_key", map: "battery_evidence_dedup_key")
  @@index([vehicleId, scope, valueType, observedAt])
  @@index([sourceType, observedAt])
  @@index([documentExtractionId])
  @@index([serviceEventId])
  @@map("battery_evidence")
}

// ------------------------------------------------
// BRAKE EVIDENCE (evidence-based brake condition)
// ------------------------------------------------
// Provenance store for real brake observations. Only MEASURED / DOCUMENTED /
// SENSOR / MANUAL sources may carry real mm values; TELEMATICS_ESTIMATION never
// invents wheel mm. Mirrors the BatteryEvidence pattern and feeds the canonical
// BrakeHealthService read model (data basis, confidence, CRITICAL safety
// signals) without becoming a second wear truth.

enum BrakeEvidenceSource {
  MANUAL_MEASUREMENT
  WORKSHOP_REPORT
  AI_UPLOAD
  SERVICE_INVOICE
  INSPECTION_PROTOCOL
  DTC_SIGNAL
  BRAKE_WEAR_SENSOR
  TELEMATICS_ESTIMATION
}

enum BrakeAxle {
  FRONT
  REAR
  UNKNOWN
}

enum BrakeWheelPosition {
  FRONT_LEFT
  FRONT_RIGHT
  REAR_LEFT
  REAR_RIGHT
}

enum BrakeComponentStatus {
  GOOD
  WATCH
  WARNING
  CRITICAL
  UNKNOWN
}

enum BrakeEvidenceConfidence {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

model BrakeEvidence {
  id                     String                  @id @default(uuid())
  vehicleId              String                  @map("vehicle_id")
  source                 BrakeEvidenceSource
  axle                   BrakeAxle               @default(UNKNOWN)
  wheelPosition          BrakeWheelPosition?     @map("wheel_position")
  measuredPadMm          Float?                  @map("measured_pad_mm")
  measuredDiscMm         Float?                  @map("measured_disc_mm")
  discCondition          BrakeComponentStatus?   @map("disc_condition")
  brakeFluidStatus       BrakeComponentStatus?   @map("brake_fluid_status")
  /// Confirmed "replace immediately" flag from a workshop/AI document.
  immediateReplacement   Boolean?                @map("immediate_replacement")
  /// Optional DTC severity when source = DTC_SIGNAL (INFO/WARNING/CRITICAL).
  dtcSeverity            String?                 @map("dtc_severity")
  mileageAtMeasurementKm Int?                    @map("mileage_at_measurement_km")
  measuredAt             DateTime?               @map("measured_at")
  confidence             BrakeEvidenceConfidence @default(UNKNOWN)
  notes                  String?
  documentExtractionId   String?                 @map("document_extraction_id")
  serviceEventId         String?                 @map("service_event_id")
  createdById            String?                 @map("created_by_id")
  createdAt              DateTime                @default(now()) @map("created_at")

  vehicle            Vehicle                    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentExtraction VehicleDocumentExtraction? @relation(fields: [documentExtractionId], references: [id], onDelete: SetNull)
  serviceEvent       VehicleServiceEvent?       @relation(fields: [serviceEventId], references: [id], onDelete: SetNull)

  @@index([vehicleId, axle, measuredAt])
  @@index([vehicleId, source, measuredAt])
  @@index([documentExtractionId])
  @@index([serviceEventId])
  @@map("brake_evidence")
}

// ------------------------------------------------
// BRAKE TRIP METRICS
// ------------------------------------------------

model BrakeTripMetric {
  id                 String   @id @default(uuid())
  vehicleId          String   @map("vehicle_id")
  tripId             String?  @map("trip_id")
  brakeEnergyKj      Float?   @map("brake_energy_kj")
  hardBrakeCount     Int      @default(0) @map("hard_brake_count")
