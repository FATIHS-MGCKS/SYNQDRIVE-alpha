// ------------------------------------------------
// VEHICLE TRIPS
// ------------------------------------------------

enum TripStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

/// Identifies the pipeline that created a canonical trip record.
/// V2_LIVE = created by the live FSM detection engine.
/// REPAIRED = created by the reconciliation/repair layer after the fact.
enum TripSource {
  V2_LIVE
  REPAIRED
}

enum TripAssignmentStatus {
  ASSIGNED_DRIVER
  ASSIGNED_USER
  ASSIGNED_BOOKING_CUSTOMER
  PRIVATE_UNASSIGNED
  UNKNOWN_ASSIGNMENT
}

enum TripAssignmentSubjectType {
  DRIVER
  USER
  BOOKING_CUSTOMER
}

model VehicleTrip {
  id                    String                     @id @default(uuid())
  vehicleId             String                     @map("vehicle_id")
  dimoSegmentId         String?                    @unique @map("dimo_segment_id")
  tripStatus            TripStatus                 @default(ONGOING) @map("trip_status")
  driverName            String?                    @map("driver_name")
  assignmentStatus      TripAssignmentStatus?      @map("assignment_status")
  assignmentSubjectType TripAssignmentSubjectType? @map("assignment_subject_type")
  assignmentSubjectId   String?                    @map("assignment_subject_id")
  assignedBookingId     String?                    @map("assigned_booking_id")
  isPrivateTrip         Boolean                    @default(false) @map("is_private_trip")
  startTime             DateTime                   @map("start_time")
  endTime               DateTime?                  @map("end_time")
  startLatitude         Float?                     @map("start_latitude")
  startLongitude        Float?                     @map("start_longitude")
  endLatitude           Float?                     @map("end_latitude")
  endLongitude          Float?                     @map("end_longitude")
  distanceKm            Float?                     @map("distance_km")
  durationMinutes       Float?                     @map("duration_minutes")
  avgSpeedKmh           Float?                     @map("avg_speed_kmh")
  maxSpeedKmh           Float?                     @map("max_speed_kmh")
  drivingScore          Float?                     @map("driving_score")

  fuelUsedLiters          Float?  @map("fuel_used_liters")
  avgConsumptionLPer100Km Float?  @map("avg_consumption_l_per_100km")
  fuelConfidence          String? @map("fuel_confidence")

  energyUsedKwh             Float?  @map("energy_used_kwh")
  avgConsumptionKwhPer100Km Float?  @map("avg_consumption_kwh_per_100km")
  energyConfidence          String? @map("energy_confidence")

  citySharePercent    Float? @map("city_share_percent")
  highwaySharePercent Float? @map("highway_share_percent")
  countrySharePercent Float? @map("country_share_percent")

  outsideTemperatureStartC Float? @map("outside_temperature_start_c")
  engineTempStartC         Float? @map("engine_temp_start_c")
  engineTempEndC           Float? @map("engine_temp_end_c")
  avgRpm                   Float? @map("avg_rpm")
  avgThrottlePosition      Float? @map("avg_throttle_position")
  avgEngineLoad            Float? @map("avg_engine_load")

  speedingPercent  Float? @map("speeding_percent")
  maxOverSpeedKmh  Float? @map("max_over_speed_kmh")
  speedingSegments Int?   @map("speeding_segments")

  speedingSectionsJson Json?  @map("speeding_sections_json")
  speedingSectionCount Int?   @map("speeding_section_count")
  speedingDistanceM    Int?   @map("speeding_distance_m")
  speedingDurationS    Int?   @map("speeding_duration_s")
  speedingExposurePct  Float? @map("speeding_exposure_pct")
  avgOverSpeedKmh      Float? @map("avg_over_speed_kmh")

  harshBrakeCount  Int @default(0) @map("harsh_brake_count")
  harshAccelCount  Int @default(0) @map("harsh_accel_count")
  harshCornerCount Int @default(0) @map("harsh_corner_count")

  accelerationEventCount  Int       @default(0) @map("acceleration_event_count")
  brakingEventCount       Int       @default(0) @map("braking_event_count")
  abuseEventCount         Int       @default(0) @map("abuse_event_count")
  hardAccelerationCount   Int       @default(0) @map("hard_acceleration_count")
  hardBrakingCount        Int       @default(0) @map("hard_braking_count")
  fullBrakingCount        Int       @default(0) @map("full_braking_count")
  totalAccelerationEvents Int       @default(0) @map("total_acceleration_events")
  hardAccelerationEvents  Int       @default(0) @map("hard_acceleration_events")
  totalBrakingEvents      Int       @default(0) @map("total_braking_events")
  hardBrakingEvents       Int       @default(0) @map("hard_braking_events")
  fullBrakingEvents       Int       @default(0) @map("full_braking_events")
  corneringEvents         Int       @default(0) @map("cornering_events")
  abuseEvents             Int       @default(0) @map("abuse_events")
  speedingEvents          Int       @default(0) @map("speeding_events")
  possibleImpactCount     Int       @default(0) @map("possible_impact_count")
  kickdownCount           Int       @default(0) @map("kickdown_count")
  coldEngineAbuseCount    Int       @default(0) @map("cold_engine_abuse_count")
  longIdleCount           Int       @default(0) @map("long_idle_count")
  abuseScore              Float?    @map("abuse_score")
  behaviorSummaryJson     Json?     @map("behavior_summary_json")
  behaviorEnrichedAt      DateTime? @map("behavior_enriched_at")

  // ── Enrichment status tracking ──────────────────────────────────────────
  // Values: PENDING | IN_PROGRESS | COMPLETED | SKIPPED_NO_HF_DATA | FAILED_TRANSIENT | FAILED_PERMANENT
  // String (not enum) to avoid costly ALTER TYPE migrations and allow extensibility.
  behaviorEnrichmentStatus    String?   @map("behavior_enrichment_status")
  behaviorEnrichmentAttempts  Int       @default(0) @map("behavior_enrichment_attempts")
  behaviorEnrichmentError     String?   @map("behavior_enrichment_error")
  behaviorEnrichmentStartedAt DateTime? @map("behavior_enrichment_started_at")
  drivingImpactComputedAt     DateTime? @map("driving_impact_computed_at")

  detectionProfile         VehicleDetectionProfile? @map("detection_profile")
  startDetectionMode       String?                  @map("start_detection_mode")
  endDetectionMode         String?                  @map("end_detection_mode")
  startConfidence          DetectionConfidence?     @map("start_confidence")
  endConfidence            DetectionConfidence?     @map("end_confidence")
  possibleStartAt          DateTime?                @map("possible_start_at")
  possibleEndAt            DateTime?                @map("possible_end_at")
  firstActivityAt          DateTime?                @map("first_activity_at")
  lastActivityAt           DateTime?                @map("last_activity_at")
  routeTrackingStartedAt   DateTime?                @map("route_tracking_started_at")
  drivingTrackingStartedAt DateTime?                @map("driving_tracking_started_at")
  rawDetectionMeta         Json?                    @map("raw_detection_meta")

  gapEnded   Boolean   @default(false) @map("gap_ended")
  enrichedAt DateTime? @map("enriched_at")

  // ── Canonical ownership and source ──────────────────────────────────────
  // tripSource identifies which pipeline created this trip.
  // isRepaired is true when a repair was applied after initial creation.
  tripSource        TripSource @default(V2_LIVE) @map("trip_source")
  isRepaired        Boolean    @default(false) @map("is_repaired")
  mergeParentTripId String?    @map("merge_parent_trip_id")

  // ── UI-facing readiness status ───────────────────────────────────────────
  // Simple string statuses for frontend display. Values:
  //   qualityStatus:         VERIFIED | LOW_DATA | ANOMALY
  //   behaviorSummaryStatus: PENDING | READY | SKIPPED | FAILED
  //   drivingImpactStatus:   PENDING | READY | SKIPPED | FAILED
  qualityStatus         String? @map("quality_status")
  behaviorSummaryStatus String? @map("behavior_summary_status")
  drivingImpactStatus   String? @map("driving_impact_status")

  createdAt DateTime @default(now()) @map("created_at")

  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  waypoints      VehicleTripWaypoint[]
  events         DrivingEvent[]
  behaviorEvents TripBehaviorEvent[]
  repairs        TripRepair[]

  @@index([vehicleId])
  @@index([startTime])
  @@index([tripStatus])
  @@index([tripSource])
  @@index([assignmentStatus, isPrivateTrip])
  @@index([assignmentSubjectType, assignmentSubjectId])
  @@index([assignedBookingId])
  @@index([behaviorEnrichmentStatus])
  // Composite index for the hot "trips by vehicle ordered by startTime desc"
  // query used by trips list, rental analysis, driver score and hydration.
  // PostgreSQL can walk this index in reverse for free, so no DESC clause.
  @@index([vehicleId, startTime])
  @@map("vehicle_trips")
}

model VehicleTripWaypoint {
  id         String   @id @default(uuid())
  tripId     String   @map("trip_id")
  latitude   Float
  longitude  Float
  speedKmh   Float?   @map("speed_kmh")
  heading    Float?
  recordedAt DateTime @map("recorded_at")

  trip VehicleTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([recordedAt])
  @@map("vehicle_trip_waypoints")
}

// ── Trip Behavior Events (post-trip HF enrichment) ──

enum BehaviorEventCategory {
  ACCELERATION
  BRAKING
  ABUSE
}

enum BehaviorEventClassification {
  LIGHT
  MODERATE
  HARD
  EXTREME
  WARNING
  SEVERE
  CRITICAL
}

model TripBehaviorEvent {
  id             String                      @id @default(uuid())
  organizationId String?                     @map("organization_id")
  vehicleId      String                      @map("vehicle_id")
  tripId         String                      @map("trip_id")
  eventCategory  BehaviorEventCategory       @map("event_category")
  eventType      String                      @map("event_type")
  classification BehaviorEventClassification @map("classification")
  startedAt      DateTime                    @map("started_at")
  endedAt        DateTime?                   @map("ended_at")
  durationMs     Int?                        @map("duration_ms")
  startSpeedKmh  Float?                      @map("start_speed_kmh")
  endSpeedKmh    Float?                      @map("end_speed_kmh")
  peakValue      Float?                      @map("peak_value")
  peakValueUnit  String?                     @map("peak_value_unit")
  peakG          Float?                      @map("peak_g")
  maxThrottlePos Float?                      @map("max_throttle_pos")
  maxEngineRpm   Float?                      @map("max_engine_rpm")
  maxCoolantTemp Float?                      @map("max_coolant_temp")
  metadataJson   Json?                       @map("metadata_json")
  createdAt      DateTime                    @default(now()) @map("created_at")

  vehicle Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([vehicleId])
  @@index([eventCategory])
  @@index([startedAt])
  // Analytics commonly groups behavior events by trip + category. This
  // composite serves that filter without a secondary scan.
  @@index([tripId, eventCategory])
  @@map("trip_behavior_events")
}

