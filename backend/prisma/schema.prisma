// ------------------------------------------------
// ORGANIZATIONS
// ------------------------------------------------

model Organization {
  id           String             @id @default(uuid())
  companyName  String             @map("company_name")
  shortCode    String?            @unique @map("short_code")
  businessType BusinessType       @map("business_type")
  address      String?
  city         String?
  country      String?
  phone        String?
  email        String?
  website      String?
  logoUrl      String?            @map("logo_url")
  status       OrganizationStatus @default(ACTIVE)
  lastActiveAt DateTime?          @map("last_active_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  memberships               OrganizationMembership[]
  organizationProducts      OrganizationProduct[]
  stations                  Station[]
  vehicles                  Vehicle[]
  vehicleComplaints         VehicleComplaint[]
  orgIntegrations           OrganizationIntegration[]
  subscriptions             BillingSubscription[]
  customers                 Customer[]
  bookings                  Booking[]
  activityLogs              ActivityLog[]
  rentalDrivingAnalyses     RentalDrivingAnalysis[]
  vendors                   Vendor[]
  chatAgent                 OrganizationChatAgent?
  chatMessages              ChatMessage[]
  whatsappConfig            OrgWhatsAppConfig?
  whatsappConversations     WhatsAppConversation[]
  whatsappMessages          WhatsAppMessage[]
  voiceAssistant            VoiceAssistant?
  voiceConversations        VoiceConversation[]
  insightPolicy             TenantInsightPolicy?
  insightRuns               DashboardInsightRun[]
  insights                  DashboardInsight[]
  servicePartnerAssignments TenantServicePartnerAssignment[]
  partnerDataAuthorizations PartnerDataAuthorization[]
  partnerServiceCases       PartnerServiceCase[]
  providerConsents          VehicleProviderConsent[]

  @@index([status])
  @@map("organizations")
}

// ------------------------------------------------
// USERS
// ------------------------------------------------

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String?
  firstName          String?          @map("first_name")
  lastName           String?          @map("last_name")
  passwordHash       String?          @map("password_hash")
  avatarUrl          String?          @map("avatar_url")
  authProviderId     String?          @unique @map("auth_provider_id")
  platformRole       UserPlatformRole @default(USER) @map("platform_role")
  status             UserStatus       @default(ACTIVE)
  phone              String?
  mobile             String?
  address            String?
  language           String?          @default("de")
  timezone           String?          @default("Europe/Berlin")
  dateFormat         String?          @default("DD.MM.YYYY") @map("date_format")
  mustChangePassword Boolean          @default(false) @map("must_change_password")
  lastLoginAt        DateTime?        @map("last_login_at")
  lastLoginIp        String?          @map("last_login_ip")
  lastLoginDevice    String?          @map("last_login_device")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  memberships   OrganizationMembership[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// ------------------------------------------------
// REFRESH TOKENS
// ------------------------------------------------

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash") // bcrypt hash of the actual token
  family     String    @map("family") // rotation family — revoke all on reuse detection
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by") // id of the next token in chain
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ------------------------------------------------
// ORGANIZATION MEMBERSHIPS
// ------------------------------------------------

model OrganizationMembership {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  organizationId   String           @map("organization_id")
  role             MembershipRole
  roleLabel        String?          @map("role_label")
  stationScope     String?          @map("station_scope")
  department       String?
  position         String?
  permissions      Json?
  fieldAgentAccess Boolean          @default(false) @map("field_agent_access")
  status           MembershipStatus @default(ACTIVE)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_memberships")
}

// ------------------------------------------------
// STATIONS
// ------------------------------------------------

model Station {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  name           String
  address        String?
  city           String?
  country        String?
  latitude       Float?
  longitude      Float?
  status         StationStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]

  @@index([organizationId])
  @@map("stations")
}

// ------------------------------------------------
// PRODUCTS & LICENSING
// ------------------------------------------------

model Product {
  id          String      @id @default(uuid())
  slug        ProductSlug @unique
  name        String
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")

  organizationProducts OrganizationProduct[]

  @@map("products")
}

model OrganizationProduct {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  productId      String           @map("product_id")
  status         OrgProductStatus @default(ACTIVE)
  plan           OrgProductPlan   @default(STARTER)
  activatedAt    DateTime?        @map("activated_at")
  expiresAt      DateTime?        @map("expires_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@unique([organizationId, productId])
  @@index([organizationId])
  @@map("organization_products")
}

// ------------------------------------------------
// VEHICLES (registered SynqDrive vehicles)
// ------------------------------------------------

model Vehicle {
  id                                String            @id @default(uuid())
  organizationId                    String            @map("organization_id")
  stationId                         String?           @map("station_id")
  dimoVehicleId                     String?           @map("dimo_vehicle_id")
  vin                               String
  make                              String
  model                             String
  year                              Int
  vehicleName                       String?           @map("vehicle_name")
  fuelType                          FuelType          @map("fuel_type")
  transmission                      TransmissionType?
  driveType                         DriveType?        @map("drive_type")
  vehicleType                       VehicleType?      @map("vehicle_type")
  color                             String?
  licensePlate                      String?           @map("license_plate")
  mileageKm                         Int?              @map("mileage_km")
  dailyRateEur                      Float?            @map("daily_rate_eur")
  weeklyRateEur                     Float?            @map("weekly_rate_eur")
  monthlyRateEur                    Float?            @map("monthly_rate_eur")
  extraKmPrice                      Float?            @map("extra_km_price")
  imageUrl                          String?           @map("image_url")
  status                            VehicleStatus     @default(AVAILABLE)
  cleaningStatus                    CleaningStatus    @default(CLEAN) @map("cleaning_status")
  healthStatus                      HealthStatus      @default(GOOD) @map("health_status")
  notes                             String?
  leasingRateCents                  Int?              @map("leasing_rate_cents")
  insuranceCostCents                Int?              @map("insurance_cost_cents")
  taxCostCents                      Int?              @map("tax_cost_cents")
  curbWeightKg                      Float?            @map("curb_weight_kg")
  frontWeightDistributionPct        Float?            @map("front_weight_distribution_pct")
  idleRpm                           Int?              @map("idle_rpm")
  maxRpm                            Int?              @map("max_rpm")
  serviceIntervalKm                 Int?              @map("service_interval_km")
  serviceIntervalMonths             Int?              @map("service_interval_months")
  brakeForceFrontPercent            Float?            @map("brake_force_front_percent")
  lastServiceDate                   DateTime?         @map("last_service_date")
  lastServiceOdometerKm             Int?              @map("last_service_odometer_km")
  nextServiceDueDate                DateTime?         @map("next_service_due_date")
  serviceIntervalManufacturerKm     Int?              @map("service_interval_manufacturer_km")
  serviceIntervalManufacturerMonths Int?              @map("service_interval_manufacturer_months")
  lastOilChangeDate                 DateTime?         @map("last_oil_change_date")
  lastOilChangeOdometerKm           Int?              @map("last_oil_change_odometer_km")
  oilChangeIntervalKm               Int?              @map("oil_change_interval_km")
  oilChangeIntervalMonths           Int?              @map("oil_change_interval_months")
  hvBatteryCapacityKwh              Float?            @map("hv_battery_capacity_kwh")
  tankCapacityLiters                Float?            @map("tank_capacity_liters")

  // ── V3 Hardware type ───────────────────────────────────────────────────────
  // Drives the source split for Driving Events (LTE_R1 → Telemetry API Events,
  // SMART5 → HF time-series reconstruction). Defaults to UNKNOWN for all
  // existing vehicles; eligible vehicles can be backfilled to LTE_R1 via the
  // admin backfill endpoint.
  hardwareType HardwareType @default(UNKNOWN) @map("hardware_type")

  lastTuvDate     DateTime? @map("last_tuv_date")
  nextTuvDate     DateTime? @map("next_tuv_date")
  lastBokraftDate DateTime? @map("last_bokraft_date")
  nextBokraftDate DateTime? @map("next_bokraft_date")
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization           Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  station                Station?                     @relation(fields: [stationId], references: [id], onDelete: SetNull)
  dimoVehicle            DimoVehicle?                 @relation(fields: [dimoVehicleId], references: [id], onDelete: SetNull)
  batterySpecs           VehicleBatterySpec[]
  tireSetups             VehicleTireSetup[]
  tires                  Tire[]
  tirePositionHistory    TirePositionHistory[]
  tireEvents             TireEvent[]
  tireHealthSnapshots    TireHealthSnapshot[]
  tireWearDataPoints     TireWearDataPoint[]
  brakeSpecs             VehicleBrakeReferenceSpec[]
  serviceEvents          VehicleServiceEvent[]
  enrichmentJobs         VehicleEnrichmentJob[]
  latestState            VehicleLatestState?
  positionUpdates        VehiclePositionUpdate[]
  analyticsCacheEntries  AnalyticsCache[]
  pollLogs               DimoPollLog[]
  bookings               Booking[]
  drivingEvents          DrivingEvent[]
  batterySnapshots       BatteryHealthSnapshot[]
  hvBatterySnapshots     HvBatteryHealthSnapshot[]
  hvBatteryHealthCurrent HvBatteryHealthCurrent?
  batteryFeatures        BatteryFeatures?
  batteryEvidence        BatteryEvidence[]
  brakeTripMetrics       BrakeTripMetric[]
  brakeHealthCurrent     BrakeHealthCurrent?
  dtcEvents              VehicleDtcEvent[]
  tripDrivingImpacts     TripDrivingImpact[]
  drivingImpactCurrent   VehicleDrivingImpactCurrent?
  damages                VehicleDamage[]
  rentalDrivingAnalyses  RentalDrivingAnalysis[]
  trips                  VehicleTrip[]
  tripDetectionState     VehicleTripDetectionState?
  tripTrackingRuns       VehicleTripTrackingRun[]
  tripBehaviorEvents     TripBehaviorEvent[]
  tripRepairs            TripRepair[]
  logbookConfig          VehicleLogbookConfig?
  documentExtractions    VehicleDocumentExtraction[]
  vendorVehicles         VendorVehicle[]
  complaints             VehicleComplaint[]
  partnerServiceCases    PartnerServiceCase[]
  dataSourceLinks        VehicleDataSourceLink[]
  hmSignalGroupStates    HmSignalGroupState[]
  providerConsents       VehicleProviderConsent[]

  @@unique([vin, organizationId])
  @@index([organizationId])
  @@index([stationId])
  @@index([status])
  @@map("vehicles")
}

enum ComplaintUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintLifecycleStatus {
  ACTIVE
  RESOLVED
}

enum ComplaintSource {
  FIELD_AGENT
  MANUAL
}

model VehicleComplaint {
  id              String                   @id @default(uuid())
  organizationId  String                   @map("organization_id")
  vehicleId       String                   @map("vehicle_id")
  createdByUserId String?                  @map("created_by_user_id")
  description     String
  urgency         ComplaintUrgency         @default(MEDIUM)
  region          String?
  status          ComplaintLifecycleStatus @default(ACTIVE)
  source          ComplaintSource          @default(MANUAL)
  resolvedAt      DateTime?                @map("resolved_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([organizationId])
  @@map("vehicle_complaints")
}

// ------------------------------------------------
// DIMO MIRRORED VEHICLES
// ------------------------------------------------

model DimoVehicle {
  id               String               @id @default(uuid())
  externalId       String               @unique @map("external_id")
  tokenId          Int?                 @unique @map("token_id")
  vin              String?
  make             String?
  model            String?
  year             Int?
  fuelType         String?              @map("fuel_type")
  powertrainType   String?              @map("powertrain_type")
  odometerKm       Float?               @map("odometer_km")
  batteryPercent   Float?               @map("battery_percent")
  fuelPercent      Float?               @map("fuel_percent")
  lastSignal       DateTime?            @map("last_signal")
  connectionStatus DimoConnectionStatus @default(PENDING) @map("connection_status")
  rawJson          Json?                @map("raw_json")
  syncedAt         DateTime?            @map("synced_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  registeredVehicles Vehicle[]

  @@index([vin])
  @@index([connectionStatus])
  @@map("dimo_vehicles")
}

// ------------------------------------------------
// VEHICLE PROVIDER CONSENT / ACCESS GRANTS
// ------------------------------------------------
// Canonical ledger of every provider access grant for a vehicle.
// Records who granted access, via which mechanism, and current status.
// One row per grant event — revocation creates a new row or updates status.

enum VehicleProviderConsentStatus {
  ACTIVE
  REVOKED
  EXPIRED
  REJECTED
  PENDING
}

enum VehicleProviderConsentGrantType {
  DIMO_OAUTH // DIMO vehicle linked via OAuth token flow
  DIMO_DIRECT // DIMO vehicle linked directly by admin
  HM_FLEET_CLEARANCE // High Mobility fleet clearance (webhook-approved)
  HM_MANUAL // High Mobility manually approved by admin
  MANUAL // manually recorded by platform admin
}

model VehicleProviderConsent {
  id                       String                          @id @default(uuid())
  vehicleId                String                          @map("vehicle_id")
  organizationId           String                          @map("organization_id")
  provider                 String                          @map("provider") // DIMO | HIGH_MOBILITY | ...
  grantType                VehicleProviderConsentGrantType @map("grant_type")
  status                   VehicleProviderConsentStatus    @default(ACTIVE) @map("status")
  scopes                   String[]                        @map("scopes") // list of accessible signals/permissions
  grantedByUserId          String?                         @map("granted_by_user_id") // internal user who triggered grant
  grantedByExternalSubject String?                         @map("granted_by_external_subject") // e.g. vehicle owner DID / external identity
  grantedAt                DateTime                        @default(now()) @map("granted_at")
  expiresAt                DateTime?                       @map("expires_at")
  revokedAt                DateTime?                       @map("revoked_at")
  revokedByUserId          String?                         @map("revoked_by_user_id")
