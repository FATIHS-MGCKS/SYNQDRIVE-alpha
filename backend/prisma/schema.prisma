  BOOKING_STATUS
  BOOKING_CHANGE
  PICKUP_INFO
  RETURN_INFO
  DOCUMENTS
  PAYMENT
  DEPOSIT
  DAMAGE
  ACCIDENT
  VEHICLE_STATUS
  VEHICLE_WARNING
  LOCATION
  SUPPORT
  COMPLAINT
  OPT_OUT
  UNKNOWN
}

