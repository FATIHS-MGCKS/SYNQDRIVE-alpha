  maxDecelerationMs2 Float?   @map("max_deceleration_ms2")
  brakeDurationSec   Int?     @map("brake_duration_sec")
  distanceKm         Float?   @map("distance_km")
  recordedAt         DateTime @map("recorded_at")
  createdAt          DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([recordedAt])
  @@map("brake_trip_metrics")
}

// ── Brake Health V2 ────────────────────────────────────────────────────────────
//
// Achsweise (front/rear) pad + disc state per vehicle.
// Only populated AFTER a valid brake service anchor exists.

model BrakeHealthCurrent {
  vehicleId      String  @id @map("vehicle_id")
  organizationId String? @map("organization_id")

  isInitialized Boolean @default(false) @map("is_initialized")

  // Anchor data
  anchorServiceDate DateTime? @map("anchor_service_date")
  anchorOdometerKm  Float?    @map("anchor_odometer_km")

  // Front pads
  frontPadAnchorMm        Float? @map("front_pad_anchor_mm")
  frontPadEstimatedMm     Float? @map("front_pad_estimated_mm")
  frontPadHealthPct       Float? @map("front_pad_health_pct")
  frontPadRemainingKm     Float? @map("front_pad_remaining_km")
  frontPadWearRateMmPerKm Float? @map("front_pad_wear_rate_mm_per_km")
  frontPadKFactor         Float  @default(1.0) @map("front_pad_k_factor")

  // Rear pads
  rearPadAnchorMm        Float? @map("rear_pad_anchor_mm")
  rearPadEstimatedMm     Float? @map("rear_pad_estimated_mm")
  rearPadHealthPct       Float? @map("rear_pad_health_pct")
  rearPadRemainingKm     Float? @map("rear_pad_remaining_km")
  rearPadWearRateMmPerKm Float? @map("rear_pad_wear_rate_mm_per_km")
  rearPadKFactor         Float  @default(1.0) @map("rear_pad_k_factor")

  // Front discs
  frontDiscAnchorMm        Float? @map("front_disc_anchor_mm")
  frontDiscEstimatedMm     Float? @map("front_disc_estimated_mm")
  frontDiscHealthPct       Float? @map("front_disc_health_pct")
  frontDiscRemainingKm     Float? @map("front_disc_remaining_km")
  frontDiscWearRateMmPerKm Float? @map("front_disc_wear_rate_mm_per_km")
  frontDiscKFactor         Float  @default(1.0) @map("front_disc_k_factor")

  // Rear discs
  rearDiscAnchorMm        Float? @map("rear_disc_anchor_mm")
  rearDiscEstimatedMm     Float? @map("rear_disc_estimated_mm")
  rearDiscHealthPct       Float? @map("rear_disc_health_pct")
  rearDiscRemainingKm     Float? @map("rear_disc_remaining_km")
  rearDiscWearRateMmPerKm Float? @map("rear_disc_wear_rate_mm_per_km")
  rearDiscKFactor         Float  @default(1.0) @map("rear_disc_k_factor")

  // Set-level
  padsHealthPct    Float? @map("pads_health_pct")
  padsRemainingKm  Float? @map("pads_remaining_km")
  discsHealthPct   Float? @map("discs_health_pct")
  discsRemainingKm Float? @map("discs_remaining_km")

  confidenceScore Float?  @map("confidence_score")
  confidenceLabel String? @map("confidence_label")
  hasAlert        Boolean @default(false) @map("has_alert")

  stateClass             String? @map("state_class")
  anchorValidationStatus String? @map("anchor_validation_status")
  modelCoverageRatio     Float?  @map("model_coverage_ratio")
  modeledDistanceKm      Float?  @map("modeled_distance_km")
  modeledTripCount       Int?    @map("modeled_trip_count")
  modelingSource         String? @map("modeling_source")
  baselineWarnings       Json?   @map("baseline_warnings")

  distanceSinceAnchorKm Float? @map("distance_since_anchor_km")
  calibrationCount      Int    @default(0) @map("calibration_count")
  modelVersion          String @default("1.0.0") @map("model_version")

  lastRecalculatedAt DateTime? @map("last_recalculated_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId])
  @@map("brake_health_current")
}

// ------------------------------------------------
// VEHICLE DTC EVENTS (Error Codes)
// ------------------------------------------------

model VehicleDtcEvent {
  id              String      @id @default(uuid())
  vehicleId       String      @map("vehicle_id")
  dtcCode         String      @map("dtc_code")
  description     String?
  severity        DtcSeverity @default(WARNING)
  isActive        Boolean     @default(true) @map("is_active")
  firstSeenAt     DateTime    @map("first_seen_at")
  lastSeenAt      DateTime    @map("last_seen_at")
  clearedAt       DateTime?   @map("cleared_at")
  occurrenceCount Int         @default(1) @map("occurrence_count")
  rawPayload      Json?       @map("raw_payload")
  createdAt       DateTime    @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([dtcCode])
  @@index([isActive])
  @@index([firstSeenAt])
  // Hot queries: `findByVehicle` orders by lastSeenAt desc; summary counts
  // active faults for a vehicle. Composite indexes avoid a heap fetch + sort.
  @@index([vehicleId, lastSeenAt])
  @@index([vehicleId, isActive])
  @@map("vehicle_dtc_events")
}

// ------------------------------------------------
// DTC KNOWLEDGE BASE (AI-enriched, reusable)
// ------------------------------------------------
// Two compact tables only — generic per-code knowledge and optional
// make/model/year/fuel-specific knowledge. Queue/job state lives in the
// `enrichmentStatus` fields (NO separate job table by design). Stores only
// short, summarized, reusable knowledge — never raw web pages, HTML dumps,
// long prompts, or full AI transcripts. Status fields use plain strings to
// keep the migration small (values documented inline).

model DtcKnowledge {
  id                      String    @id @default(uuid())
  code                    String
  normalizedCode          String    @map("normalized_code")
  language                String    @default("de")
  systemCategory          String?   @map("system_category") // POWERTRAIN, BODY, CHASSIS, NETWORK, UNKNOWN
  standardType            String?   @map("standard_type") // GENERIC, MANUFACTURER_SPECIFIC, UNKNOWN
  title                   String?
  shortDescription        String?   @map("short_description")
  possibleCauses          Json?     @map("possible_causes")
  possibleEffects         Json?     @map("possible_effects")
  technicalUrgency        String?   @map("technical_urgency") // LOW, MEDIUM, HIGH, CRITICAL, UNKNOWN
  rentalUrgency           String?   @map("rental_urgency") // LOW, MEDIUM, HIGH, CRITICAL, UNKNOWN
  rentalRecommendation    String?   @map("rental_recommendation") // RENTABLE, CHECK_BEFORE_NEXT_RENTAL, BLOCK_UNTIL_INSPECTED, DO_NOT_RENT, UNKNOWN
  recommendedAction       String?   @map("recommended_action")
  sourceType              String?   @map("source_type") // SAE, WEB, MIXED, AI_GENERATED, UNKNOWN
  sources                 Json?
  enrichmentStatus        String    @default("MISSING") @map("enrichment_status") // MISSING, QUEUED, PROCESSING, READY, FAILED
  aiGenerated             Boolean   @default(false) @map("ai_generated")
  needsReview             Boolean   @default(false) @map("needs_review")
  lastVerifiedAt          DateTime? @map("last_verified_at")
  lastEnrichmentAttemptAt DateTime? @map("last_enrichment_attempt_at")
  enrichmentError         String?   @map("enrichment_error")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  vehicleKnowledge DtcVehicleKnowledge[]

  @@unique([normalizedCode, language])
  @@index([normalizedCode])
  @@index([enrichmentStatus])
  @@map("dtc_knowledge")
}

model DtcVehicleKnowledge {
  id             String        @id @default(uuid())
  dtcKnowledgeId String?       @map("dtc_knowledge_id")
  dtcKnowledge   DtcKnowledge? @relation(fields: [dtcKnowledgeId], references: [id], onDelete: SetNull)

  code           String
  normalizedCode String  @map("normalized_code")
  language       String  @default("de")
  make           String?
  model          String?
  year           Int?
  fuelType       String? @map("fuel_type")
  engineCode     String? @map("engine_code")

  vehicleSpecificTitle        String?   @map("vehicle_specific_title")
  vehicleSpecificDescription  String?   @map("vehicle_specific_description")
  vehicleSpecificEffects      Json?     @map("vehicle_specific_effects")
  vehicleSpecificUrgency      String?   @map("vehicle_specific_urgency") // LOW, MEDIUM, HIGH, CRITICAL, UNKNOWN
  vehicleRentalRecommendation String?   @map("vehicle_rental_recommendation") // RENTABLE, CHECK_BEFORE_NEXT_RENTAL, BLOCK_UNTIL_INSPECTED, DO_NOT_RENT, UNKNOWN
  recommendedAction           String?   @map("recommended_action")
  sourceType                  String?   @map("source_type") // WEB, OEM, MIXED, AI_GENERATED, UNKNOWN
  sources                     Json?
  enrichmentStatus            String    @default("MISSING") @map("enrichment_status") // MISSING, QUEUED, PROCESSING, READY, FAILED
  aiGenerated                 Boolean   @default(false) @map("ai_generated")
  needsReview                 Boolean   @default(false) @map("needs_review")
  lastVerifiedAt              DateTime? @map("last_verified_at")
  lastEnrichmentAttemptAt     DateTime? @map("last_enrichment_attempt_at")
  enrichmentError             String?   @map("enrichment_error")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@index([normalizedCode])
  @@index([normalizedCode, make, model, year])
  @@index([enrichmentStatus])
  @@map("dtc_vehicle_knowledge")
}

// ------------------------------------------------
// VEHICLE DAMAGES
// ------------------------------------------------

model VehicleDamage {
  id                     String                @id @default(uuid())
  vehicleId              String                @map("vehicle_id")
  damageType             DamageType            @map("damage_type")
  severity               DamageSeverity        @default(MINOR)
  status                 DamageStatus          @default(OPEN)
  description            String?
  locationView           DamageLocationView    @default(UNKNOWN) @map("location_view")
  locationX              Float?                @map("location_x")
  locationY              Float?                @map("location_y")
  locationLabel          String?               @map("location_label")
  estimatedCostCents     Int?                  @map("estimated_cost_cents")
  repairCostCents        Int?                  @map("repair_cost_cents")
  chargedToCustomerCents Int?                  @map("charged_to_customer_cents")
  depositHoldCents       Int?                  @map("deposit_hold_cents")
  source                 DamageSource          @default(MANUAL)
  rentalImpact           DamageRentalImpact    @default(NONE) @map("rental_impact")
  evidenceStatus         DamageEvidenceStatus  @default(MISSING) @map("evidence_status")
  liabilityStatus        DamageLiabilityStatus @default(NOT_APPLICABLE) @map("liability_status")
  liabilityNote          String?               @map("liability_note")
  bookingId              String?               @map("booking_id")
  customerId             String?               @map("customer_id")
  handoverProtocolId     String?               @map("handover_protocol_id")
  taskId                 String?               @map("task_id")
  reportedBy             String?               @map("reported_by")
  repairStartedAt        DateTime?             @map("repair_started_at")
  repairedAt             DateTime?             @map("repaired_at")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  vehicle          Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  booking          Booking?                 @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer         Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  handoverProtocol BookingHandoverProtocol? @relation(fields: [handoverProtocolId], references: [id], onDelete: SetNull)
  task             OrgTask?                 @relation(fields: [taskId], references: [id], onDelete: SetNull)
  images           VehicleDamageImage[]

  @@index([vehicleId])
  @@index([damageType])
  @@index([status])
  @@index([bookingId])
  @@index([customerId])
  @@index([handoverProtocolId])
  @@index([taskId])
  @@map("vehicle_damages")
}

model VehicleDamageImage {
  id         String   @id @default(uuid())
  damageId   String   @map("damage_id")
  imageData  String   @map("image_data")
  mimeType   String?  @map("mime_type")
  caption    String?
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  damage VehicleDamage @relation(fields: [damageId], references: [id], onDelete: Cascade)

  @@index([damageId])
  @@map("vehicle_damage_images")
}

// ------------------------------------------------
// VEHICLE EXTERIOR IMAGES (Damage Map)
// ------------------------------------------------
//
// V4.7.50 — Five canonical exterior photo slots per vehicle (FRONT, LEFT,
// RIGHT, REAR, ROOF) used by the Rental Damages page to render a vehicle-
// specific damage map carousel. Uploaded by Master-Admin operators either
// during vehicle registration (VehicleRegistrationModal) or post-hoc on
// the Master-Admin vehicle detail drawer (PlatformVehiclesView). Damage
// pins are overlaid by the Rental UI per active view.
enum VehicleExteriorView {
  FRONT
  LEFT
  RIGHT
  REAR
  ROOF
}

model VehicleExteriorImage {
  id               String              @id @default(uuid())
  vehicleId        String              @map("vehicle_id")
  view             VehicleExteriorView
  imageData        String              @map("image_data") // base64 data URI
  caption          String?
  uploadedByUserId String?             @map("uploaded_by_user_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, view])
  @@index([vehicleId])
  @@map("vehicle_exterior_images")
}

model VehicleExteriorModelImage {
  id               String              @id @default(uuid())
  modelKey         String              @map("model_key")
  make             String
  model            String
  view             VehicleExteriorView
  imageData        String              @map("image_data") // compressed base64 data URI
  caption          String?
  sourceVehicleId  String?             @map("source_vehicle_id")
  uploadedByUserId String?             @map("uploaded_by_user_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@unique([modelKey, view])
  @@index([modelKey])
  @@index([make, model])
  @@map("vehicle_exterior_model_images")
}

// ------------------------------------------------
// VEHICLE TRIPS
// ------------------------------------------------

enum TripStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

/// Identifies the pipeline that created a canonical trip record.
/// V2_LIVE = created by the live FSM detection engine.
/// REPAIRED = created by the reconciliation/repair layer after the fact.
enum TripSource {
  V2_LIVE
  REPAIRED
}

enum TripAssignmentStatus {
  ASSIGNED_DRIVER
  ASSIGNED_BOOKING_CUSTOMER
  PRIVATE_UNASSIGNED
  UNKNOWN_ASSIGNMENT
}

enum TripAssignmentSubjectType {
  DRIVER
  BOOKING_CUSTOMER
}

enum TripBookingLinkSource {
  EXPLICIT
  TIME_WINDOW
}

model VehicleTrip {
  id                    String                     @id @default(uuid())
  vehicleId             String                     @map("vehicle_id")
  dimoSegmentId         String?                    @unique @map("dimo_segment_id")
  tripStatus            TripStatus                 @default(ONGOING) @map("trip_status")
  driverName            String?                    @map("driver_name")
  assignmentStatus      TripAssignmentStatus?      @map("assignment_status")
  assignmentSubjectType TripAssignmentSubjectType? @map("assignment_subject_type")
  assignmentSubjectId   String?                    @map("assignment_subject_id")
  assignedBookingId     String?                    @map("assigned_booking_id")
  bookingLinkSource     TripBookingLinkSource?     @map("booking_link_source")
  isPrivateTrip         Boolean                    @default(false) @map("is_private_trip")
  startTime             DateTime                   @map("start_time")
  endTime               DateTime?                  @map("end_time")
  startLatitude         Float?                     @map("start_latitude")
  startLongitude        Float?                     @map("start_longitude")
  endLatitude           Float?                     @map("end_latitude")
  endLongitude          Float?                     @map("end_longitude")
  distanceKm            Float?                     @map("distance_km")
  durationMinutes       Float?                     @map("duration_minutes")
  avgSpeedKmh           Float?                     @map("avg_speed_kmh")
  maxSpeedKmh           Float?                     @map("max_speed_kmh")
  drivingScore          Float?                     @map("driving_score")

  fuelUsedLiters          Float?  @map("fuel_used_liters")
  avgConsumptionLPer100Km Float?  @map("avg_consumption_l_per_100km")
  fuelConfidence          String? @map("fuel_confidence")

  energyUsedKwh             Float?  @map("energy_used_kwh")
  avgConsumptionKwhPer100Km Float?  @map("avg_consumption_kwh_per_100km")
  energyConfidence          String? @map("energy_confidence")

  citySharePercent    Float? @map("city_share_percent")
  highwaySharePercent Float? @map("highway_share_percent")
  countrySharePercent Float? @map("country_share_percent")

  outsideTemperatureStartC Float? @map("outside_temperature_start_c")
  engineTempStartC         Float? @map("engine_temp_start_c")
  engineTempEndC           Float? @map("engine_temp_end_c")
  avgRpm                   Float? @map("avg_rpm")
  avgThrottlePosition      Float? @map("avg_throttle_position")
  avgEngineLoad            Float? @map("avg_engine_load")

  speedingPercent  Float? @map("speeding_percent")
  maxOverSpeedKmh  Float? @map("max_over_speed_kmh")
  speedingSegments Int?   @map("speeding_segments")

  speedingSectionsJson Json?  @map("speeding_sections_json")
  speedingSectionCount Int?   @map("speeding_section_count")
  speedingDistanceM    Int?   @map("speeding_distance_m")
  speedingDurationS    Int?   @map("speeding_duration_s")
  speedingExposurePct  Float? @map("speeding_exposure_pct")
  avgOverSpeedKmh      Float? @map("avg_over_speed_kmh")

  harshBrakeCount  Int @default(0) @map("harsh_brake_count")
  harshAccelCount  Int @default(0) @map("harsh_accel_count")
  harshCornerCount Int @default(0) @map("harsh_corner_count")

  accelerationEventCount  Int       @default(0) @map("acceleration_event_count")
  brakingEventCount       Int       @default(0) @map("braking_event_count")
  abuseEventCount         Int       @default(0) @map("abuse_event_count")
  hardAccelerationCount   Int       @default(0) @map("hard_acceleration_count")
  hardBrakingCount        Int       @default(0) @map("hard_braking_count")
  fullBrakingCount        Int       @default(0) @map("full_braking_count")
  totalAccelerationEvents Int       @default(0) @map("total_acceleration_events")
  hardAccelerationEvents  Int       @default(0) @map("hard_acceleration_events")
  totalBrakingEvents      Int       @default(0) @map("total_braking_events")
  hardBrakingEvents       Int       @default(0) @map("hard_braking_events")
  fullBrakingEvents       Int       @default(0) @map("full_braking_events")
  corneringEvents         Int       @default(0) @map("cornering_events")
  abuseEvents             Int       @default(0) @map("abuse_events")
  speedingEvents          Int       @default(0) @map("speeding_events")
  possibleImpactCount     Int       @default(0) @map("possible_impact_count")
  kickdownCount           Int       @default(0) @map("kickdown_count")
  coldEngineAbuseCount    Int       @default(0) @map("cold_engine_abuse_count")
  longIdleCount           Int       @default(0) @map("long_idle_count")
  abuseScore              Float?    @map("abuse_score")
  behaviorSummaryJson     Json?     @map("behavior_summary_json")
  behaviorEnrichedAt      DateTime? @map("behavior_enriched_at")

  // ── Enrichment status tracking ──────────────────────────────────────────
  // Values: PENDING | IN_PROGRESS | COMPLETED | SKIPPED_NO_HF_DATA | FAILED_TRANSIENT | FAILED_PERMANENT
  // String (not enum) to avoid costly ALTER TYPE migrations and allow extensibility.
  behaviorEnrichmentStatus    String?   @map("behavior_enrichment_status")
  behaviorEnrichmentAttempts  Int       @default(0) @map("behavior_enrichment_attempts")
  behaviorEnrichmentError     String?   @map("behavior_enrichment_error")
  behaviorEnrichmentStartedAt DateTime? @map("behavior_enrichment_started_at")
  drivingImpactComputedAt     DateTime? @map("driving_impact_computed_at")

  // ── Canonical post-trip analysis status (separate from trip COMPLETED) ───
  // Values: PENDING | IN_PROGRESS | PARTIAL | COMPLETED | FAILED | SKIPPED
  tripAnalysisStatus   String?   @map("trip_analysis_status")
  analysisQueuedAt     DateTime? @map("analysis_queued_at")
  analysisStartedAt    DateTime? @map("analysis_started_at")
  analysisPartialAt    DateTime? @map("analysis_partial_at")
  analysisCompletedAt  DateTime? @map("analysis_completed_at")
  analysisFailedAt     DateTime? @map("analysis_failed_at")
  analysisFailedReason String?   @map("analysis_failed_reason")
  analysisLatencyMs    Int?      @map("analysis_latency_ms")
  analysisStagesJson   Json?     @map("analysis_stages_json")

  detectionProfile         VehicleDetectionProfile? @map("detection_profile")
  startDetectionMode       String?                  @map("start_detection_mode")
  endDetectionMode         String?                  @map("end_detection_mode")
  startConfidence          DetectionConfidence?     @map("start_confidence")
  endConfidence            DetectionConfidence?     @map("end_confidence")
  possibleStartAt          DateTime?                @map("possible_start_at")
  possibleEndAt            DateTime?                @map("possible_end_at")
  firstActivityAt          DateTime?                @map("first_activity_at")
  lastActivityAt           DateTime?                @map("last_activity_at")
  routeTrackingStartedAt   DateTime?                @map("route_tracking_started_at")
  drivingTrackingStartedAt DateTime?                @map("driving_tracking_started_at")
  rawDetectionMeta         Json?                    @map("raw_detection_meta")

  gapEnded   Boolean   @default(false) @map("gap_ended")
  enrichedAt DateTime? @map("enriched_at")

  // ── Canonical ownership and source ──────────────────────────────────────
  // tripSource identifies which pipeline created this trip.
  // isRepaired is true when a repair was applied after initial creation.
  tripSource        TripSource @default(V2_LIVE) @map("trip_source")
  isRepaired        Boolean    @default(false) @map("is_repaired")
  mergeParentTripId String?    @map("merge_parent_trip_id")

  // ── UI-facing readiness status ───────────────────────────────────────────
  // Simple string statuses for frontend display. Values:
  //   qualityStatus:         VERIFIED | LOW_DATA | ANOMALY
  //   behaviorSummaryStatus: PENDING | READY | SKIPPED | FAILED
  //   drivingImpactStatus:   PENDING | READY | SKIPPED | FAILED
  qualityStatus         String? @map("quality_status")
  behaviorSummaryStatus String? @map("behavior_summary_status")
  drivingImpactStatus   String? @map("driving_impact_status")

  createdAt DateTime @default(now()) @map("created_at")

  vehicle                 Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  waypoints               VehicleTripWaypoint[]
  events                  DrivingEvent[]
  behaviorEvents          TripBehaviorEvent[]
  misuseCases             MisuseCase[]
  tripAssessabilities     TripAssessability[]
  drivingEvidence         DrivingEvidence[]
  drivingAnalysisRuns     DrivingAnalysisRun[]
  drivingIntelligenceJobs DrivingIntelligenceJob[]
  repairs                 TripRepair[]
  rpmWebhookCandidates    RpmWebhookCandidate[]

  @@index([vehicleId])
  @@index([startTime])
  @@index([tripStatus])
  @@index([tripSource])
  @@index([assignmentStatus, isPrivateTrip])
  @@index([assignmentSubjectType, assignmentSubjectId])
  @@index([assignedBookingId])
  @@index([behaviorEnrichmentStatus])
  @@index([tripAnalysisStatus])
  // Composite index for the hot "trips by vehicle ordered by startTime desc"
  // query used by trips list, rental analysis, driver score and hydration.
  // PostgreSQL can walk this index in reverse for free, so no DESC clause.
  @@index([vehicleId, startTime])
  @@map("vehicle_trips")
}

model VehicleTripWaypoint {
  id         String   @id @default(uuid())
  tripId     String   @map("trip_id")
  latitude   Float
  longitude  Float
  speedKmh   Float?   @map("speed_kmh")
  heading    Float?
  recordedAt DateTime @map("recorded_at")

  trip VehicleTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([recordedAt])
  @@map("vehicle_trip_waypoints")
}

// ── Vehicle Energy Events (Refuel + Recharge, detected via DIMO segments) ──
// Canonical contract: DIMO's native RefuelDetector / RechargeDetector emit
// segments via the same `segments(mechanism: refuel|recharge)` GraphQL query
// that we already consume for trip detection. We persist each segment as a
// first-class event so the Trips-Tab timeline can render "refill / recharge
// between trips" without merging trip-side heuristics into the same table.

enum EnergyEventKind {
  REFUEL
  RECHARGE
}

enum EnergyEventConfidence {
  HIGH
  MEDIUM
  LOW
}

model VehicleEnergyEvent {
  id                 String                @id @default(uuid())
  vehicleId          String                @map("vehicle_id")
  dimoSegmentId      String                @unique @map("dimo_segment_id")
  kind               EnergyEventKind
  detectionMechanism String                @map("detection_mechanism")
  startTime          DateTime              @map("start_time")
  endTime            DateTime              @map("end_time")
  durationSeconds    Int                   @map("duration_seconds")
  startLatitude      Float?                @map("start_latitude")
  startLongitude     Float?                @map("start_longitude")
  endLatitude        Float?                @map("end_latitude")
  endLongitude       Float?                @map("end_longitude")
  fuelDeltaLiters    Float?                @map("fuel_delta_liters")
  fuelDeltaPercent   Float?                @map("fuel_delta_percent")
  socDeltaPercent    Float?                @map("soc_delta_percent")
  energyDeltaKwh     Float?                @map("energy_delta_kwh")
  odometerStartKm    Float?                @map("odometer_start_km")
  odometerEndKm      Float?                @map("odometer_end_km")
  confidence         EnergyEventConfidence @default(MEDIUM)
  rawDetectionMeta   Json?                 @map("raw_detection_meta")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([vehicleId, startTime])
  @@index([kind])
  @@map("vehicle_energy_events")
}

// ── Trip Behavior Events (post-trip HF enrichment) ──

enum BehaviorEventCategory {
  ACCELERATION
  BRAKING
  ABUSE
}

enum BehaviorEventClassification {
  LIGHT
  MODERATE
  HARD
  EXTREME
  WARNING
  SEVERE
  CRITICAL
}

model TripBehaviorEvent {
  id             String                      @id @default(uuid())
  organizationId String?                     @map("organization_id")
  vehicleId      String                      @map("vehicle_id")
  tripId         String                      @map("trip_id")
  eventCategory  BehaviorEventCategory       @map("event_category")
  eventType      String                      @map("event_type")
  classification BehaviorEventClassification @map("classification")
  startedAt      DateTime                    @map("started_at")
  endedAt        DateTime?                   @map("ended_at")
  durationMs     Int?                        @map("duration_ms")
  startSpeedKmh  Float?                      @map("start_speed_kmh")
  endSpeedKmh    Float?                      @map("end_speed_kmh")
  peakValue      Float?                      @map("peak_value")
  peakValueUnit  String?                     @map("peak_value_unit")
  peakG          Float?                      @map("peak_g")
  maxThrottlePos Float?                      @map("max_throttle_pos")
  maxEngineRpm   Float?                      @map("max_engine_rpm")
  maxCoolantTemp Float?                      @map("max_coolant_temp")
  metadataJson   Json?                       @map("metadata_json")
  createdAt      DateTime                    @default(now()) @map("created_at")

  vehicle Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([vehicleId])
  @@index([eventCategory])
  @@index([startedAt])
  // Analytics commonly groups behavior events by trip + category. This
  // composite serves that filter without a secondary scan.
  @@index([tripId, eventCategory])
  @@map("trip_behavior_events")
}

