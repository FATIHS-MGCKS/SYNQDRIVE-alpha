// ── V3 Hardware types ────────────────────────────────────────────────────────
// LTE_R1: DIMO LTE dongle — reports native driving events via Telemetry API.
//         Driving Events are sourced from DIMO Telemetry API Events.
// SMART5: SynqDrive SMART5 hardware — Driving Events derived from local HF
//         time-series reconstruction.
// UNKNOWN: default for existing vehicles not yet classified.
enum HardwareType {
  LTE_R1
  SMART5
  UNKNOWN
}

// ── Driving Event source ─────────────────────────────────────────────────────
// TELEMETRY_EVENTS: event ingested from DIMO Telemetry API (LTE_R1 path).
// HF_DERIVED:       event reconstructed from local HF time-series (SMART5 path).
enum DrivingEventSource {
  TELEMETRY_EVENTS
  HF_DERIVED
}

