// ------------------------------------------------
// SynqDrive Prisma Schema
// Aligned with Phase 2 Database Design
// ------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

