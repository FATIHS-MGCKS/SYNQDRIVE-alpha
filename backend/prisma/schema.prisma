// ------------------------------------------------
// DRIVING EVENTS
// ------------------------------------------------

model DrivingEvent {
  id             String             @id @default(uuid())
  vehicleId      String             @map("vehicle_id")
  organizationId String?            @map("organization_id")
  eventType      DrivingEventType   @map("event_type")
  // V3: which hardware/pipeline produced this event
  source         DrivingEventSource @default(TELEMETRY_EVENTS) @map("source")
  severity       Float              @default(0)
  latitude       Float?
  longitude      Float?
  speedKmh       Float?             @map("speed_kmh")
  deltaKmh       Float?             @map("delta_kmh")
  durationMs     Int?               @map("duration_ms")
  driverName     String?            @map("driver_name")
  tripId         String?            @map("trip_id")
  // V3: contextual enrichment (e.g. coldEngine badge from HF context on LTE_R1)
  metadataJson   Json?              @map("metadata_json")
  recordedAt     DateTime           @map("recorded_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  vehicle Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([recordedAt])
  @@index([eventType])
  @@index([tripId])
  @@index([source])
  // Most driving-event reads are per-vehicle over a time range (analytics,
  // enrichment recovery) or per-trip (rental analysis). Composite indexes.
  @@index([vehicleId, recordedAt])
  @@index([tripId, eventType])
  @@map("driving_events")
}

// ── RPM webhook candidate intake (re-enabled V4.9.197) ────────────────────────
// DIMO Developer Console supports vss.powertrainCombustionEngineSpeed triggers.
model RpmWebhookCandidate {
  id                    String                    @id @default(uuid())
  organizationId        String                    @map("organization_id")
  vehicleId             String                    @map("vehicle_id")
  tripId                String?                   @map("trip_id")
  tokenId               Int                       @map("token_id")
  provider              String                    @default("DIMO")
  triggerType           TelemetryTriggerType      @default(RPM_THRESHOLD) @map("trigger_type")
  threshold             Int                       @default(4000)
  observedValue         Float                     @map("observed_value")
  observedAt            DateTime                  @map("observed_at")
  // Idempotency bucket = floor(observedAt_ms / dedupWindowMs). Repeated firings
  // inside the same window share a bucket and collapse via the unique index.
  dedupBucket           BigInt                    @map("dedup_bucket")
  rawPayloadJson        Json                      @map("raw_payload_json")
  status                RpmWebhookCandidateStatus @default(RECEIVED)
  contextAssessmentJson Json?                     @map("context_assessment_json")
  error                 String?
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  vehicle Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip    VehicleTrip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([provider, vehicleId, triggerType, dedupBucket])
  @@index([vehicleId])
  @@index([organizationId])
  @@index([observedAt])
  @@index([status])
  @@index([tripId])
  @@map("rpm_webhook_candidates")
}

