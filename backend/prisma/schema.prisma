// ════════════════════════════════════════════════════════
// AI VOICE ASSISTANT (ElevenLabs Conversational AI)
// ════════════════════════════════════════════════════════

enum VoiceAssistantStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum VoiceConnectionStatus {
  NOT_CONFIGURED
  DEGRADED
  CONNECTED
  ERROR
}

enum VoiceConversationDirection {
  INBOUND
  OUTBOUND
}

enum VoiceConversationStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum VoiceConversationOutcome {
  RESOLVED
  ESCALATED
  FAILED
  ABANDONED
}

model VoiceAssistant {
  id             String       @id @default(uuid())
  organizationId String       @unique @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String  @default("AI Assistant")
  role            String?
  personality     String?
  language        String  @default("en")
  voiceId         String? @map("voice_id")
  voiceName       String? @map("voice_name")
  greetingMessage String? @map("greeting_message")

  systemPrompt      String? @map("system_prompt") @db.Text
  companyContext    String? @map("company_context") @db.Text
  businessRules     String? @map("business_rules") @db.Text
  forbiddenActions  String? @map("forbidden_actions") @db.Text
  knowledgeSnippets String? @map("knowledge_snippets") @db.Text

  provider                String                @default("elevenlabs")
  elevenLabsAgentId       String?               @map("elevenlabs_agent_id")
  elevenLabsPhoneNumberId String?               @map("elevenlabs_phone_number_id")
  phoneNumberId           String?               @map("phone_number_id")
  phoneNumber             String?               @map("phone_number")
  connectionStatus        VoiceConnectionStatus @default(NOT_CONFIGURED) @map("connection_status")
  lastProvisionedAt       DateTime?             @map("last_provisioned_at")
  lastSyncedAt            DateTime?             @map("last_synced_at")
  telephonyEnabled        Boolean               @default(false) @map("telephony_enabled")
  inboundEnabled          Boolean               @default(true) @map("inbound_enabled")
  outboundEnabled         Boolean               @default(false) @map("outbound_enabled")

  permAnswerQuestions     Boolean @default(true) @map("perm_answer_questions")
  permManageBookings      Boolean @default(false) @map("perm_manage_bookings")
  permCreateBookingDrafts Boolean @default(false) @map("perm_create_booking_drafts")
  permCancelBookings      Boolean @default(false) @map("perm_cancel_bookings")
  permCreateTasks         Boolean @default(false) @map("perm_create_tasks")
  permWorkshopHandling    Boolean @default(false) @map("perm_workshop_handling")
  permBreakdownSupport    Boolean @default(false) @map("perm_breakdown_support")
  permContactCustomers    Boolean @default(false) @map("perm_contact_customers")
  permContactVendors      Boolean @default(false) @map("perm_contact_vendors")
  permModifyRecords       Boolean @default(false) @map("perm_modify_records")
  permCreateActions       Boolean @default(false) @map("perm_create_actions")
  permEmergencyHandling   Boolean @default(false) @map("perm_emergency_handling")

  toolPermissions Json? @map("tool_permissions")

  escalationPhone      String? @map("escalation_phone")
  escalationUserId     String? @map("escalation_user_id")
  escalationDepartment String? @map("escalation_department")
  escalateOnLowConf    Boolean @default(true) @map("escalate_on_low_conf")
  escalateOnSensitive  Boolean @default(true) @map("escalate_on_sensitive")
  escalateOnRequest    Boolean @default(true) @map("escalate_on_request")
  fallbackMessage      String? @map("fallback_message")
  escalationTriggers   Json?   @map("escalation_triggers")

  businessHoursStart    String? @map("business_hours_start")
  businessHoursEnd      String? @map("business_hours_end")
  businessHoursTimezone String? @map("business_hours_timezone")
  afterHoursMessage     String? @map("after_hours_message")
  businessHours         Json?   @map("business_hours")

  status VoiceAssistantStatus @default(DRAFT)

  totalCalls           Int   @default(0) @map("total_calls")
  answeredCalls        Int   @default(0) @map("answered_calls")
  missedCalls          Int   @default(0) @map("missed_calls")
  escalatedCalls       Int   @default(0) @map("escalated_calls")
  totalTalkTimeSeconds Int   @default(0) @map("total_talk_time_seconds")
  totalTalkMinutes     Float @default(0) @map("total_talk_minutes")

  conversations VoiceConversation[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  activatedAt   DateTime? @map("activated_at")
  deactivatedAt DateTime? @map("deactivated_at")

  @@index([status])
  @@map("voice_assistants")
}

model VoiceConversation {
  id               String          @id @default(uuid())
  organizationId   String          @map("organization_id")
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  voiceAssistantId String?         @map("voice_assistant_id")
  voiceAssistant   VoiceAssistant? @relation(fields: [voiceAssistantId], references: [id], onDelete: SetNull)

  providerConversationId String?                    @map("provider_conversation_id")
  elevenLabsConvId       String?                    @map("elevenlabs_conv_id")
  providerAgentId        String?                    @map("provider_agent_id")
  callerNumber           String?                    @map("caller_number")
  direction              VoiceConversationDirection @default(INBOUND)
  durationSeconds        Int?                       @map("duration_seconds")
  status                 VoiceConversationStatus    @default(COMPLETED)
  outcome                VoiceConversationOutcome   @default(RESOLVED)
  transcript             String?                    @db.Text
  summary                String?
  escalationReason       String?                    @map("escalation_reason")
  actionsPerformed       String[]                   @map("actions_performed")
  errorMessage           String?                    @map("error_message")
  metadata               Json?

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([organizationId, startedAt])
  @@index([voiceAssistantId])
  @@index([outcome])
  @@index([providerConversationId])
  @@index([elevenLabsConvId])
  @@map("voice_conversations")
}

// ── V2 Trip Detection State Machine ──

model VehicleTripDetectionState {
  id             String  @id @default(uuid())
  vehicleId      String  @unique @map("vehicle_id")
  organizationId String? @map("organization_id")

  state            TripDetectionState      @default(RESTING)
  detectionProfile VehicleDetectionProfile @default(UNKNOWN) @map("detection_profile")

  activeTripId           String?   @map("active_trip_id")
  possibleStartAt        DateTime? @map("possible_start_at")
  possibleEndAt          DateTime? @map("possible_end_at")
  lastActivityAt         DateTime? @map("last_activity_at")
  lastSnapshotEvidenceAt DateTime? @map("last_snapshot_evidence_at")

  lastCoreProcessedAt    DateTime? @map("last_core_processed_at")
  lastRouteProcessedAt   DateTime? @map("last_route_processed_at")
  lastDrivingProcessedAt DateTime? @map("last_driving_processed_at")

  workerLockedUntil DateTime? @map("worker_locked_until")
  workerRunToken    String?   @map("worker_run_token")

  startDetectionMode String?              @map("start_detection_mode")
  startConfidence    DetectionConfidence? @map("start_confidence")
  endDetectionMode   String?              @map("end_detection_mode")
  endConfidence      DetectionConfidence? @map("end_confidence")

  lastEvidenceSummary Json? @map("last_evidence_summary")

  startOdometerKm Float? @map("start_odometer_km")
  startFuelLevel  Float? @map("start_fuel_level")
  startEvSoc      Float? @map("start_ev_soc")

  // ── V2 Trip End — improved end detection fields ──
  lastMeaningfulMovementAt DateTime? @map("last_meaningful_movement_at")
  endValidationAttempts    Int       @default(0) @map("end_validation_attempts")
  cusumValidatedAt         DateTime? @map("cusum_validated_at")
  cusumSegmentStart        DateTime? @map("cusum_segment_start")
  cusumSegmentEnd          DateTime? @map("cusum_segment_end")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([organizationId])
  @@index([workerLockedUntil])
  @@map("vehicle_trip_detection_states")
}

/// Per-vehicle logbook activation config for the Master Admin debugging tool.
model VehicleLogbookConfig {
