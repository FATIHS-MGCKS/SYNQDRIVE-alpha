# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/
.next/
out/

# Compiled frontend SPA served by the backend (regenerated by the deploy build).
# Vite builds directly into this dir (frontend/vite.config.ts: outDir
# '../backend/public', emptyOutDir: true), so `npm --prefix frontend run build`
# fully replaces it. Never commit these artifacts.
backend/public/

# Cursor MCP config — contains provider secrets (DIMO private key, Hostinger token).
# NEVER commit. Use .cursor/mcp.json.example for a redacted template.
.cursor/mcp.json

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example
!**/.env.example
!**/.env.voice-staging.example

# DIMO AI Agent local test payloads — never commit real API keys or wallets
test-agent.json
*agent*.local.json
*secrets*.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Prisma generated
backend/src/generated/

# NestJS cache
backend/.tsbuildinfo

# Test coverage
coverage/

# Certificates / keys
*.pem
*.key
*.crt
*.p12
*.pfx
*.cert

# Temporary
*.tmp
*.temp
.cache/

# Figma reference assets (large, binary)
figma-ref/

# MCP build artifacts
mcp-dimo-main/node_modules/
mcp-dimo-main/dist/

# Local runtime uploads (customer documents, org logos, etc.)
backend/uploads/

# AI Document Upload — local object storage (private, never served publicly).
# Default dir: backend/storage/documents (document-extraction.config.ts).
# NOTE: do NOT use bare `storage/` — it ignores source packages under backend/src/**/storage/.
/backend/storage/
uploads/
.local-storage/

# Database dumps and binary backups
*.dump
*.sql.gz
*.bak

# Local analysis / debug script output
backend/*-output.txt
backend/analyze-*.txt
